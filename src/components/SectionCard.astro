---
const INFO_TOOLTIPS: Record<string, string> = {
  'overview': 'High-level summary of all metrics. Shows AI readiness, citation rate, traffic, and site health at a glance.',
  'ai-readiness': 'How ready your site is for AI citation. Scores schema markup, E-E-A-T signals, content structure, and citation potential. Pages with schema have 2.5x higher AI citation rates.',
  'ai-citations': 'How often AI models mention your brand when asked industry questions. Tested across ChatGPT and Claude with real search queries. 0% means AI doesn\'t recommend you for any industry queries yet.',
  'competitors': 'Who ranks in Google for your target queries vs you. Shows visibility percentage and average position for each competitor.',
  'recommendations': 'Prioritised fixes to improve your AI search visibility. Generated from all data sources. Copy any fix to Claude Code to action it.',
  'seo-health': 'Technical health of your site — missing H1 tags, meta descriptions, broken links, schema coverage. Issues here affect both traditional SEO and AI visibility.',
  'traffic': 'Website visitors from Google Analytics over the last 30 days. Shows users, sessions, pageviews, bounce rate, top pages, and traffic sources.',
  'search-performance': 'Clicks and impressions from Google Search Console and Bing Webmaster Tools. Shows what queries bring people to your site and your average position.',
  'content-gaps': 'Queries where you get impressions but not clicks — people see you in search results but don\'t click. Improving titles and descriptions for these queries is a quick win.',
  'new-pages': 'Content added since we started working together, categorised by type (blog, question, guide, etc.). Shows the content investment over time.',
  'site-tree': 'Visual hierarchy of your site structure. Shows how pages are organised and how deep they are from the homepage. Shallow, well-structured sites are easier for AI to understand.',
  'internal-links': 'Map of how pages link to each other. Shows which pages get the most internal links (important pages) and orphan pages with no links pointing to them.',
  'site-speed': 'Google Lighthouse performance scores on mobile. Performance, SEO, accessibility, and best practices. Fast sites (under 0.4s FCP) get 3x more AI citations.',
  'crawl-activity': 'How often search engine and AI bots visit your site. Shows Bing crawl frequency, pages indexed, and which AI crawlers have access.',
  'uptime': 'Whether your site is online and how fast it responds. Monitors response time and uptime percentage. Slow sites (over 2 seconds) get fewer AI citations.',
  'crawl-status': 'When the last site crawl happened and what it found. Shows pages crawled, issues detected, and schema coverage.',
  'positive-signals': 'What\'s working well — pages with good schema, strong content, proper linking, multi-modal content. These are the foundations AI citation is built on.',
};

interface Props {
  id: string;
  label: string;
  description: string;
  status?: 'healthy' | 'warning' | 'error' | 'pending' | 'not-connected';
  statusText?: string;
  metric?: string;
  metricLabel?: string;
  lastUpdated?: string;
  clientId?: string;
  chartData?: string;
  change?: number | null;
  changeLabel?: string;
  issueCount?: number;
}

const {
  id,
  label,
  description,
  status = 'not-connected',
  statusText = 'Not connected',
  metric,
  metricLabel,
  lastUpdated,
  clientId,
  chartData,
  change,
  changeLabel,
  issueCount,
} = Astro.props;

const statusColors = {
  healthy: 'bg-green-500/10 border-green-500/30 text-green-400',
  warning: 'bg-yellow-500/10 border-yellow-500/30 text-yellow-400',
  error: 'bg-red-500/10 border-red-500/30 text-red-400',
  pending: 'bg-blue-500/10 border-blue-500/30 text-blue-400',
  'not-connected': 'bg-gray-500/10 border-gray-500/30 text-gray-500',
};

const dotColors = {
  healthy: 'bg-green-400',
  warning: 'bg-yellow-400',
  error: 'bg-red-400',
  pending: 'bg-blue-400',
  'not-connected': 'bg-gray-600',
};

const hasDetail = status !== 'not-connected' && clientId;
const href = `/agency/${clientId}/${id}`;
const tooltip = INFO_TOOLTIPS[id] || '';
---

<div class={`rounded-lg border ${statusColors[status]} transition`} data-section={id}>
  <div
    class={`p-5 ${hasDetail ? 'cursor-pointer hover:brightness-125' : ''}`}
    data-card-toggle={hasDetail ? id : undefined}
    data-card-href={hasDetail ? href : undefined}
  >
    <div class="flex items-start justify-between mb-3">
      <div class="flex items-start gap-2">
        <div>
          <h3 class="text-white font-semibold text-sm">{label}</h3>
          <p class="text-xs text-gray-400 mt-0.5">{description}</p>
        </div>
        {tooltip && (
          <button
            class="info-btn flex-shrink-0 w-4 h-4 rounded-full bg-gray-700 text-gray-400 text-[9px] hover:bg-gray-600 hover:text-white transition mt-0.5"
            data-tooltip={tooltip}
            onclick="event.stopPropagation(); const tip = this.nextElementSibling; tip.classList.toggle('hidden');"
          >i</button>
        )}
        {tooltip && (
          <div class="hidden absolute z-20 mt-6 ml-[-120px] w-64 p-3 rounded-lg bg-gray-800 border border-gray-700 text-xs text-gray-300 leading-relaxed shadow-xl">
            {tooltip}
            <div class="mt-2 text-[10px] text-gray-500 cursor-pointer" onclick="event.stopPropagation(); this.parentElement.classList.add('hidden');">Click to close</div>
          </div>
        )}
      </div>
      <div class="flex items-center gap-2">
        {issueCount !== undefined && issueCount > 0 && (
          <span class="text-[10px] px-1.5 py-0.5 rounded bg-red-900/50 text-red-300">
            {issueCount} fixes
          </span>
        )}
        <span class={`w-2 h-2 rounded-full ${dotColors[status]}`}></span>
      </div>
    </div>

    {metric && (
      <div class="mt-4 flex items-end gap-3">
        <div>
          <p class="text-2xl font-bold text-white">{metric}</p>
          {metricLabel && <p class="text-xs text-gray-400 mt-0.5">{metricLabel}</p>}
        </div>
        {change !== undefined && change !== null && (
          <div class={`flex items-center gap-1 px-2 py-1 rounded text-xs font-medium ${change > 0 ? 'bg-green-900/40 text-green-400' : change < 0 ? 'bg-red-900/40 text-red-400' : 'bg-gray-800 text-gray-500'}`}>
            {change > 0 ? '↑' : change < 0 ? '↓' : '→'}
            {change !== 0 ? Math.abs(change) : '0'}
            {changeLabel && <span class="text-[10px] opacity-70">{changeLabel}</span>}
          </div>
        )}
      </div>
    )}

    {lastUpdated && (
      <div class="flex items-center justify-between mt-3">
        <p class="text-xs text-gray-600">Last updated: {lastUpdated}</p>
        {hasDetail && (
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-500 expand-label">Click to expand</span>
            <a href={href} class="text-xs text-gray-600 hover:text-gray-400" onclick="event.stopPropagation();">Full view →</a>
          </div>
        )}
      </div>
    )}
  </div>

  {hasDetail && chartData && (
    <div class="chart-panel hidden border-t border-gray-800/50 p-5" data-chart-panel={id}>
      <canvas data-chart-canvas={id} height="180"></canvas>
    </div>
  )}

  <slot />
</div>

<script>
  document.querySelectorAll('[data-card-toggle]').forEach(card => {
    card.addEventListener('click', (e) => {
      const id = card.getAttribute('data-card-toggle');
      const panel = document.querySelector(`[data-chart-panel="${id}"]`);
      const label = card.querySelector('.expand-label');

      if (panel) {
        panel.classList.toggle('hidden');
        if (label) {
          label.textContent = panel.classList.contains('hidden') ? 'Click to expand' : 'Click to collapse';
        }
        if (!panel.classList.contains('hidden') && !panel.dataset.rendered) {
          panel.dataset.rendered = 'true';
          panel.dispatchEvent(new CustomEvent('render-chart', { detail: { id } }));
        }
      } else {
        window.location.href = card.getAttribute('data-card-href');
      }
    });
  });
</script>
