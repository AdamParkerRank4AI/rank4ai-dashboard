---
interface Props {
  id: string;
  label: string;
  description: string;
  status?: 'healthy' | 'warning' | 'error' | 'pending' | 'not-connected';
  statusText?: string;
  metric?: string;
  metricLabel?: string;
  lastUpdated?: string;
  clientId?: string;
  chartData?: string;
  change?: number | null;
  changeLabel?: string;
  issueCount?: number;
}

const {
  id,
  label,
  description,
  status = 'not-connected',
  statusText = 'Not connected',
  metric,
  metricLabel,
  lastUpdated,
  clientId,
  chartData,
  change,
  changeLabel,
  issueCount,
} = Astro.props;

const statusColors = {
  healthy: 'bg-green-500/10 border-green-500/30 text-green-400',
  warning: 'bg-yellow-500/10 border-yellow-500/30 text-yellow-400',
  error: 'bg-red-500/10 border-red-500/30 text-red-400',
  pending: 'bg-blue-500/10 border-blue-500/30 text-blue-400',
  'not-connected': 'bg-gray-500/10 border-gray-500/30 text-gray-500',
};

const dotColors = {
  healthy: 'bg-green-400',
  warning: 'bg-yellow-400',
  error: 'bg-red-400',
  pending: 'bg-blue-400',
  'not-connected': 'bg-gray-600',
};

const hasDetail = status !== 'not-connected' && clientId;
const href = `/agency/${clientId}/${id}`;
---

<div class={`rounded-lg border ${statusColors[status]} transition`} data-section={id}>
  <div
    class={`p-5 ${hasDetail ? 'cursor-pointer hover:brightness-125' : ''}`}
    data-card-toggle={hasDetail ? id : undefined}
    data-card-href={hasDetail ? href : undefined}
  >
    <div class="flex items-start justify-between mb-3">
      <div>
        <h3 class="text-white font-semibold text-sm">{label}</h3>
        <p class="text-xs text-gray-400 mt-0.5">{description}</p>
      </div>
      <div class="flex items-center gap-2">
        {issueCount !== undefined && issueCount > 0 && (
          <span class="text-[10px] px-1.5 py-0.5 rounded bg-red-900/50 text-red-300">
            {issueCount} fixes
          </span>
        )}
        <span class={`w-2 h-2 rounded-full ${dotColors[status]}`}></span>
      </div>
    </div>

    {metric && (
      <div class="mt-4 flex items-end gap-3">
        <div>
          <p class="text-2xl font-bold text-white">{metric}</p>
          {metricLabel && <p class="text-xs text-gray-400 mt-0.5">{metricLabel}</p>}
        </div>
        {change !== undefined && change !== null && (
          <div class={`flex items-center gap-1 px-2 py-1 rounded text-xs font-medium ${change > 0 ? 'bg-green-900/40 text-green-400' : change < 0 ? 'bg-red-900/40 text-red-400' : 'bg-gray-800 text-gray-500'}`}>
            {change > 0 ? '↑' : change < 0 ? '↓' : '→'}
            {change !== 0 ? Math.abs(change) : '0'}
            {changeLabel && <span class="text-[10px] opacity-70">{changeLabel}</span>}
          </div>
        )}
      </div>
    )}

    {lastUpdated && (
      <div class="flex items-center justify-between mt-3">
        <p class="text-xs text-gray-600">Last updated: {lastUpdated}</p>
        {hasDetail && (
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-500 expand-label">Click to expand</span>
            <a href={href} class="text-xs text-gray-600 hover:text-gray-400" onclick="event.stopPropagation();">Full view →</a>
          </div>
        )}
      </div>
    )}
  </div>

  {hasDetail && chartData && (
    <div class="chart-panel hidden border-t border-gray-800/50 p-5" data-chart-panel={id}>
      <canvas data-chart-canvas={id} height="180"></canvas>
    </div>
  )}

  <slot />
</div>

<script>
  document.querySelectorAll('[data-card-toggle]').forEach(card => {
    card.addEventListener('click', (e) => {
      const id = card.getAttribute('data-card-toggle');
      const panel = document.querySelector(`[data-chart-panel="${id}"]`);
      const label = card.querySelector('.expand-label');

      if (panel) {
        panel.classList.toggle('hidden');
        if (label) {
          label.textContent = panel.classList.contains('hidden') ? 'Click to expand' : 'Click to collapse';
        }
        if (!panel.classList.contains('hidden') && !panel.dataset.rendered) {
          panel.dataset.rendered = 'true';
          panel.dispatchEvent(new CustomEvent('render-chart', { detail: { id } }));
        }
      } else {
        window.location.href = card.getAttribute('data-card-href');
      }
    });
  });
</script>
