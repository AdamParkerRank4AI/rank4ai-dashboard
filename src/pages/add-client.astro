---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Add Client">
  <div class="max-w-lg">
    <div class="mb-6">
      <a href="/" class="text-sm text-gray-400 hover:text-gray-300 transition">
        &larr; Back to Dashboard
      </a>
    </div>

    <h1 class="text-2xl font-bold text-white mb-2">Add New Client</h1>
    <p class="text-gray-400 mb-8">Add a new client site to monitor.</p>

    <div class="p-6 rounded-lg bg-gray-900 border border-gray-800">
      <p class="text-sm text-gray-300 mb-4">To add a new client:</p>
      <ol class="space-y-3 text-sm text-gray-400">
        <li class="flex gap-3">
          <span class="text-blue-400 font-mono">1.</span>
          <span>Edit <code class="text-blue-400">src/data/clients.json</code></span>
        </li>
        <li class="flex gap-3">
          <span class="text-blue-400 font-mono">2.</span>
          <span>Add a new client object with id, name, domain</span>
        </li>
        <li class="flex gap-3">
          <span class="text-blue-400 font-mono">3.</span>
          <span>Set <code class="text-blue-400">clientViewSections</code> to choose what the client sees</span>
        </li>
        <li class="flex gap-3">
          <span class="text-blue-400 font-mono">4.</span>
          <span>Push to GitHub — Cloudflare Pages auto-deploys</span>
        </li>
      </ol>

      <div class="mt-6 p-4 rounded bg-gray-800 border border-gray-700">
        <p class="text-xs text-gray-500 font-mono mb-2">Example entry:</p>
        <pre class="text-xs text-green-400 overflow-x-auto"><code>{`{
  "id": "new-client",
  "name": "New Client",
  "domain": "newclient.com",
  "clientViewSections": [
    "seo-health",
    "traffic",
    "uptime"
  ],
  "allSections": [
    "overview",
    "seo-health",
    "site-tree",
    "internal-links",
    "ai-citations",
    "rank-tracking",
    "traffic",
    "uptime",
    "content-gaps",
    "positive-signals"
  ]
}`}</code></pre>
      </div>

      <p class="text-xs text-gray-600 mt-4">
        A form-based client creator will be added when the dashboard gets a backend.
      </p>
    </div>
  </div>
</DashboardLayout>
