---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import clients from '../data/clients.json';
import fs from 'node:fs';
import path from 'node:path';

function loadJson(filename: string) {
  try {
    const filePath = path.join(process.cwd(), 'src', 'data', 'live', filename);
    if (fs.existsSync(filePath)) {
      return JSON.parse(fs.readFileSync(filePath, 'utf-8'));
    }
  } catch {}
  return null;
}

// Build stamp so Adam can verify a fresh deploy is live
const BUILD_TIMESTAMP = new Date().toLocaleString('en-GB', {
  timeZone: 'Europe/London',
  day: '2-digit', month: 'short', year: 'numeric',
  hour: '2-digit', minute: '2-digit',
});
const BUILD_LABEL = 'Daily Audit + Push Live wired';

const ga4 = loadJson('ga4.json') || {};
const gsc = loadJson('gsc.json') || {};
const recs = loadJson('recommendations.json') || {};
const uptime = loadJson('uptime.json') || {};
const audit = loadJson('ai_audit.json') || {};
const citations = loadJson('citation_results.json') || {};
const botHits = loadJson('bot_hits.json') || {};
const changelog = loadJson('site_changelog.json') || {};
const bing = loadJson('bing.json') || {};
const crawlActivity = loadJson('crawl_activity.json') || {};
const aioSerp = loadJson('ai_overview_serp.json') || {};
const freshness = loadJson('data_freshness.json') || null;

// Separate our sites from client sites
const ourSites = clients.filter((c: any) => c.staging);
const clientSites = clients.filter((c: any) => !c.staging);

// Build health data per client
const healthData: Record<string, any> = {};
for (const c of clients) {
  const crawl = loadJson(`crawl_${c.id}.json`);
  const r = recs[c.id] || {};
  const g = ga4[c.id] || {};
  const u = uptime[c.id] || {};
  const a = audit[c.id] || {};
  const cit = citations[c.id] || {};
  const bh = botHits[c.id] || {};
  const aio = aioSerp[c.id] || {};
  const cl = changelog[c.id === 'market-invoice' ? 'market-invoice' : c.id === 'seocompare' ? 'seocompare' : 'rank4ai-dashboard'] || {};

  const botTotal = (bh.days || []).reduce((sum: number, d: any) => sum + (d.total || 0), 0);
  const citSummary = cit.summary || {};

  healthData[c.id] = {
    pages: crawl?.pages_crawled || 0,
    // Google SEO
    users: g.overview?.active_users || 0,
    sessions: g.overview?.sessions || 0,
    clicks: gsc[c.id]?.totals?.clicks || 0,
    impressions: gsc[c.id]?.totals?.impressions || 0,
    avgPosition: gsc[c.id]?.totals?.position || null,
    // AI Citations
    citRate: cit.overall_rate || 0,
    citClaude: citSummary.claude?.rate || 0,
    citChatgpt: citSummary.chatgpt?.rate || 0,
    citGemini: citSummary.gemini?.rate || 0,
    // Bing + Copilot — crawl_activity.bing_indexed = last daily snapshot from Bing Webmaster
    bingIndexed: (crawlActivity[c.id] || {}).bing_indexed || 0,
    bingQueries: (bing[c.id] || {}).top_queries?.length || 0,
    // AI Overviews (Google)
    aioDetected: aio.ai_overviews_detected || 0,
    aioTotal: aio.total_queries || 0,
    // Scores
    aiScore: a.overall_score || null,
    recsTotal: r.total || 0,
    recsCritical: r.critical || 0,
    recsHigh: r.high || 0,
    upStatus: u.status || null,
    upMs: u.response_time_ms || null,
    botHits: botTotal,
    lastCommit: cl.recent_commits?.[0]?.message || null,
    lastCommitDate: cl.recent_commits?.[0]?.date?.slice(0, 10) || null,
  };
}

// Get last refresh time from any file
let lastRefresh = '--';
try {
  const recPath = path.join(process.cwd(), 'src', 'data', 'live', 'recommendations.json');
  if (fs.existsSync(recPath)) {
    const recData = JSON.parse(fs.readFileSync(recPath, 'utf-8'));
    const firstClient = Object.keys(recData)[0];
    if (firstClient && recData[firstClient]?.generated_at) {
      lastRefresh = new Date(recData[firstClient].generated_at).toLocaleString('en-GB', {
        day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit'
      });
    }
  }
} catch {}

// Full categorised changelog
const fullChangelog = loadJson('full_changelog.json') || [];
const allCommits = fullChangelog;

// Overall stats
const totalPages = Object.values(healthData).reduce((sum: number, d: any) => sum + d.pages, 0);
const totalUsers = Object.values(healthData).reduce((sum: number, d: any) => sum + d.users, 0);
const totalRecs = Object.values(healthData).reduce((sum: number, d: any) => sum + d.recsTotal, 0);
const totalCritical = Object.values(healthData).reduce((sum: number, d: any) => sum + d.recsCritical, 0);
const totalImpressions = Object.values(healthData).reduce((sum: number, d: any) => sum + d.impressions, 0);
const totalClicks = Object.values(healthData).reduce((sum: number, d: any) => sum + d.clicks, 0);
const avgCitRate = clientSites.length > 0 ? Math.round(clientSites.reduce((sum: number, c: any) => sum + (healthData[c.id]?.citRate || 0), 0) / clientSites.length * 10) / 10 : 0;
---

<DashboardLayout title="Dashboard">
  <!-- Build verification banner — visible deploy stamp -->
  <div class="bg-green-900/30 border border-green-700 rounded-lg px-4 py-2 mb-4 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <span class="text-2xl">✓</span>
      <div>
        <div class="text-sm font-semibold text-green-200">Build live</div>
        <div class="text-xs text-green-400/80">{BUILD_LABEL} · {BUILD_TIMESTAMP}</div>
      </div>
    </div>
    <a href="/agency/rank4ai/daily-audit" class="text-xs text-green-300 hover:text-green-100 underline">View Daily Audit →</a>
  </div>

  {freshness && (
    <div class={`rounded-lg px-4 py-2 mb-4 border ${
      (freshness.summary?.very_stale || freshness.summary?.missing) ? 'bg-red-900/30 border-red-800'
      : freshness.summary?.stale ? 'bg-yellow-900/30 border-yellow-800'
      : 'bg-gray-900 border-gray-700'
    }`}>
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="text-xs font-semibold text-gray-300 uppercase tracking-wider">Data feeds</span>
          <span class="text-xs text-green-400">{freshness.summary?.fresh || 0} fresh</span>
          {freshness.summary?.stale ? <span class="text-xs text-yellow-400">· {freshness.summary.stale} stale</span> : null}
          {freshness.summary?.very_stale ? <span class="text-xs text-red-400">· {freshness.summary.very_stale} very stale</span> : null}
          {freshness.summary?.missing ? <span class="text-xs text-red-500">· {freshness.summary.missing} missing</span> : null}
        </div>
        <details class="text-xs">
          <summary class="cursor-pointer text-gray-400 hover:text-white">Details</summary>
          <div class="absolute right-8 mt-2 bg-gray-800 border border-gray-700 rounded-lg p-3 shadow-xl z-50 min-w-[400px] max-h-[400px] overflow-y-auto">
            <table class="w-full text-xs">
              <thead>
                <tr class="text-left text-gray-500 border-b border-gray-700">
                  <th class="py-1 pr-2">Feed</th>
                  <th class="py-1 pr-2">Age</th>
                  <th class="py-1">Status</th>
                </tr>
              </thead>
              <tbody>
                {freshness.feeds?.map((f: any) => (
                  <tr class="border-b border-gray-800/50">
                    <td class="py-1 pr-2 text-gray-300">{f.label}</td>
                    <td class="py-1 pr-2 text-gray-400 whitespace-nowrap">{f.age_hours !== null ? `${f.age_hours}h` : 'n/a'}</td>
                    <td class="py-1">
                      {f.status === 'fresh' && <span class="text-green-400">✓ fresh</span>}
                      {f.status === 'stale' && <span class="text-yellow-400">◐ stale</span>}
                      {f.status === 'very_stale' && <span class="text-red-400">⚠ very stale</span>}
                      {f.status === 'missing' && <span class="text-red-500">✗ missing</span>}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </details>
      </div>
    </div>
  )}

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-bold text-white">Dashboard</h1>
      <p class="text-xs text-gray-500">Last refresh: {lastRefresh}</p>
    </div>
    <div class="flex gap-2">
      <button id="refresh-btn" class="px-3 py-1.5 bg-blue-600 text-white rounded text-sm hover:bg-blue-500 transition">
        Refresh All Data
      </button>
      <a href="/crm" class="px-3 py-1.5 bg-gray-800 text-gray-300 rounded text-sm hover:bg-gray-700 transition">
        CRM Pipeline
      </a>
    </div>
  </div>

  <!-- Overall stats -->
  {/* Three channel overview */}
  <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-6">
    {/* Google SEO */}
    <div class="bg-gray-800 border border-gray-700 rounded-lg p-4">
      <div class="text-[10px] text-gray-300 uppercase tracking-wider mb-2 font-medium">Google SEO</div>
      <div class="flex items-end gap-4">
        <div>
          <div class="text-2xl font-bold text-blue-400">{totalImpressions.toLocaleString()}</div>
          <div class="text-[10px] text-gray-400">impressions</div>
        </div>
        <div>
          <div class="text-lg font-bold text-white">{totalClicks}</div>
          <div class="text-[10px] text-gray-400">clicks</div>
        </div>
        <div>
          <div class="text-lg font-bold text-white">{totalUsers.toLocaleString()}</div>
          <div class="text-[10px] text-gray-400">users</div>
        </div>
      </div>
    </div>
    {/* AI Search */}
    <div class="bg-gray-800 border border-purple-800/40 rounded-lg p-4">
      <div class="text-[10px] text-purple-300 uppercase tracking-wider mb-2 font-medium">AI Search Citations</div>
      <div class="flex items-end gap-4">
        <div>
          <div class={`text-2xl font-bold ${avgCitRate > 0 ? 'text-purple-400' : 'text-gray-400'}`}>{avgCitRate}%</div>
          <div class="text-[10px] text-gray-400">avg citation rate</div>
        </div>
        <div>
          <div class="text-lg font-bold text-white">{totalPages.toLocaleString()}</div>
          <div class="text-[10px] text-gray-400">pages</div>
        </div>
      </div>
    </div>
    {/* Google AI Overviews */}
    <div class="bg-gray-800 border border-cyan-800/40 rounded-lg p-4">
      <div class="text-[10px] text-cyan-300 uppercase tracking-wider mb-2 font-medium">Google AI Overviews</div>
      <div class="flex items-end gap-4">
        <div>
          <div class={`text-2xl font-bold ${totalCritical > 0 ? 'text-red-400' : totalRecs > 0 ? 'text-yellow-400' : 'text-green-400'}`}>{totalRecs}</div>
          <div class="text-[10px] text-gray-400">fixes needed</div>
        </div>
        <div>
          <div class="text-lg font-bold text-purple-400">{allCommits.filter(c => c.date?.slice(0, 10) === new Date().toISOString().slice(0, 10)).length}</div>
          <div class="text-[10px] text-gray-400">changes today</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Client Sites -->
  <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Client Sites</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 mb-8">
    {clientSites.map((client: any) => {
      const h = healthData[client.id];
      const statusColor = h.upStatus === 200 ? 'bg-green-400' : h.upStatus ? 'bg-red-400' : 'bg-gray-600';
      return (
        <a href={`/agency/${client.id}`} class="block bg-gray-800 border border-gray-700 rounded-lg p-4 hover:border-blue-500/50 transition group">
          <div class="flex items-start justify-between mb-3">
            <div>
              <h3 class="text-white font-semibold group-hover:text-blue-400 transition">{client.name}</h3>
              <p class="text-xs text-gray-400">{client.domain} · {h.pages} pages</p>
            </div>
            <div class="flex items-center gap-2">
              {h.recsCritical > 0 && <span class="text-[9px] px-1.5 py-0.5 rounded bg-red-900 text-red-300">{h.recsCritical} critical</span>}
              {h.recsTotal > 0 && !h.recsCritical && <span class="text-[9px] px-1.5 py-0.5 rounded bg-yellow-900 text-yellow-300">{h.recsTotal} fixes</span>}
              <span class={`w-2.5 h-2.5 rounded-full ${statusColor}`}></span>
            </div>
          </div>

          {/* Three channels */}
          <div class="space-y-2 mb-3">
            {/* Google SEO */}
            <div class="bg-gray-700/40 rounded-lg px-3 py-2">
              <div class="flex items-center justify-between mb-1">
                <div class="text-[9px] text-gray-300 uppercase tracking-wider font-medium">Google SEO</div>
                <div class="text-[8px] text-gray-500">via Search Console</div>
              </div>
              <div class="flex items-center justify-between">
                <div class="flex gap-4">
                  <div>
                    <span class="text-sm font-bold text-blue-400">{h.impressions.toLocaleString()}</span>
                    <span class="text-[9px] text-gray-400 ml-1">impressions</span>
                  </div>
                  <div>
                    <span class="text-sm font-bold text-white">{h.clicks}</span>
                    <span class="text-[9px] text-gray-400 ml-1">clicks</span>
                  </div>
                </div>
                {h.avgPosition && (
                  <span class="text-[10px] text-gray-500">pos <span class="text-white font-medium">{h.avgPosition}</span></span>
                )}
              </div>
            </div>

            {/* Bing + Copilot */}
            <div class="bg-blue-900/20 rounded-lg px-3 py-2 border border-blue-800/30">
              <div class="flex items-center justify-between mb-1">
                <div class="text-[9px] text-blue-300 uppercase tracking-wider font-medium">Bing + Copilot</div>
                <div class="text-[8px] text-gray-500">via Webmaster Tools</div>
              </div>
              <div class="flex items-center justify-between">
                <div class="flex gap-4">
                  <div>
                    <span class={`text-sm font-bold ${h.bingIndexed > 0 ? 'text-blue-300' : 'text-gray-600'}`}>{h.bingIndexed}</span>
                    <span class="text-[9px] text-gray-400 ml-1">indexed</span>
                  </div>
                  <div>
                    <span class="text-sm font-bold text-white">{h.bingQueries}</span>
                    <span class="text-[9px] text-gray-400 ml-1">queries</span>
                  </div>
                </div>
                <span class="text-[9px] text-gray-500">feeds Copilot + ChatGPT</span>
              </div>
            </div>

            {/* AI Search Citations */}
            <div class="bg-purple-900/20 rounded-lg px-3 py-2 border border-purple-800/30">
              <div class="flex items-center justify-between mb-1">
                <div class="text-[9px] text-purple-300 uppercase tracking-wider font-medium">AI Search Citations</div>
                <div class="text-[8px] text-gray-500">via API testing</div>
              </div>
              <div class="flex items-center justify-between">
                <div class="flex gap-3">
                  <div>
                    <span class="text-[10px] text-gray-400">Claude</span>
                    <span class={`text-sm font-bold ml-1 ${h.citClaude > 0 ? 'text-green-400' : 'text-gray-600'}`}>{h.citClaude}%</span>
                  </div>
                  <div>
                    <span class="text-[10px] text-gray-400">ChatGPT</span>
                    <span class={`text-sm font-bold ml-1 ${h.citChatgpt > 0 ? 'text-green-400' : 'text-gray-600'}`}>{h.citChatgpt}%</span>
                  </div>
                  <div>
                    <span class="text-[10px] text-gray-400">Gemini</span>
                    <span class={`text-sm font-bold ml-1 ${h.citGemini > 0 ? 'text-green-400' : 'text-gray-600'}`}>{h.citGemini}%</span>
                  </div>
                </div>
              </div>
            </div>

            {/* Google AI Overviews */}
            <div class="bg-cyan-900/20 rounded-lg px-3 py-2 border border-cyan-800/30">
              <div class="flex items-center justify-between mb-1">
                <div class="text-[9px] text-cyan-300 uppercase tracking-wider font-medium">Google AI Overviews</div>
                <div class="text-[8px] text-gray-500">via DataForSEO</div>
              </div>
              <div class="flex items-center justify-between">
                <div>
                  <span class={`text-sm font-bold ${h.aioDetected > 0 ? 'text-cyan-400' : 'text-gray-600'}`}>{h.aioDetected}/{h.aioTotal}</span>
                  <span class="text-[9px] text-gray-400 ml-1">queries trigger AI Overview</span>
                </div>
                <span class={`text-[10px] font-medium ${h.aiScore >= 70 ? 'text-green-400' : h.aiScore >= 40 ? 'text-yellow-400' : h.aiScore ? 'text-red-400' : 'text-gray-600'}`}>
                  AI Ready: {h.aiScore || '--'}/100
                </span>
              </div>
            </div>
          </div>

          <div class="flex items-center justify-between text-[10px] text-gray-500">
            <div class="flex gap-3">
              <span>{h.users.toLocaleString()} users</span>
              <span>{h.botHits} bot hits</span>
            </div>
            {h.lastCommitDate && <span>{h.lastCommitDate}</span>}
          </div>
        </a>
      );
    })}
  </div>

  <!-- Our Sites -->
  <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Our Sites</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 mb-8">
    {ourSites.map((client: any) => {
      const h = healthData[client.id];
      return (
        <a href={`/agency/${client.id}`} class="block bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-gray-700 transition group opacity-80">
          <div class="flex items-start justify-between mb-2">
            <div>
              <h3 class="text-gray-300 font-semibold group-hover:text-white transition text-sm">{client.name}</h3>
              <p class="text-[10px] text-gray-600">{client.domain}</p>
            </div>
            {client.staging && <span class="text-[8px] px-1.5 py-0.5 rounded bg-yellow-900/50 text-yellow-400 uppercase">Staging</span>}
          </div>
          <div class="flex gap-4 text-[10px] text-gray-500">
            <span>{h.pages} pages</span>
            {h.recsTotal > 0 && <span class="text-yellow-500">{h.recsTotal} fixes</span>}
            {h.users > 0 && <span>{h.users} users</span>}
          </div>
        </a>
      );
    })}
  </div>

  <!-- Two column: Activity Feed + Site Changes -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Activity Feed -->
    <div class="bg-gray-800 border border-gray-700 rounded-lg p-5">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-sm font-semibold text-gray-400">Site Changes</h3>
        <div class="flex gap-1">
          <button class="changelog-filter text-[9px] px-2 py-0.5 rounded bg-gray-800 text-gray-400" data-filter="all">All</button>
          <button class="changelog-filter text-[9px] px-2 py-0.5 rounded bg-gray-800 text-gray-400" data-filter="marketinvoice.co.uk">MI</button>
          <button class="changelog-filter text-[9px] px-2 py-0.5 rounded bg-gray-800 text-gray-400" data-filter="seocompare.co.uk">SEO</button>
          <button class="changelog-filter text-[9px] px-2 py-0.5 rounded bg-gray-800 text-gray-400" data-filter="dashboard">Dash</button>
        </div>
      </div>
      <div class="space-y-2 max-h-[400px] overflow-y-auto" id="changelog-list">
        {allCommits.slice(0, 50).map((c: any) => {
          const siteColor = c.site === 'marketinvoice.co.uk' ? 'bg-teal-900 text-teal-300' : c.site === 'seocompare.co.uk' ? 'bg-yellow-900 text-yellow-300' : 'bg-gray-700 text-gray-300';
          const catColor = c.label === 'NEW' ? 'bg-green-900 text-green-300' : c.label === 'FIX' ? 'bg-red-900 text-red-300' : c.label === 'IMPROVEMENT' ? 'bg-blue-900 text-blue-300' : c.label === 'REMOVAL' ? 'bg-orange-900 text-orange-300' : c.label === 'CHANGE' ? 'bg-purple-900 text-purple-300' : 'bg-gray-800 text-gray-400';
          const isToday = c.date === new Date().toISOString().slice(0, 10);
          return (
            <div class={`changelog-item flex items-start gap-1.5 text-xs border-b border-gray-800/50 pb-2 ${isToday ? '' : 'opacity-60'}`} data-site={c.site}>
              <span class={`text-[8px] px-1 py-0.5 rounded ${siteColor} flex-shrink-0 mt-0.5`}>{c.site}</span>
              <span class={`text-[8px] px-1 py-0.5 rounded ${catColor} flex-shrink-0 mt-0.5`}>{c.label}</span>
              <div class="flex-1 min-w-0">
                <span class="text-gray-300 block truncate">{c.message}</span>
                <span class="text-gray-600">{c.date}</span>
              </div>
            </div>
          );
        })}
        {allCommits.length === 0 && <p class="text-xs text-gray-600">No changes tracked yet.</p>}
      </div>
      <div class="mt-3 pt-2 border-t border-gray-800 text-[10px] text-gray-600">
        {allCommits.length} total changes tracked
      </div>
    </div>

    <script>
      document.querySelectorAll('.changelog-filter').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var filter = btn.getAttribute('data-filter');
          document.querySelectorAll('.changelog-filter').forEach(function(b) { b.style.outline = ''; });
          btn.style.outline = '2px solid white';
          document.querySelectorAll('.changelog-item').forEach(function(item) {
            if (filter === 'all' || item.getAttribute('data-site') === filter) {
              item.style.display = '';
            } else {
              item.style.display = 'none';
            }
          });
        });
      });
    </script>

    <!-- Quick Status -->
    <div class="bg-gray-800 border border-gray-700 rounded-lg p-5">
      <h3 class="text-sm font-semibold text-gray-400 mb-4">System Status</h3>
      <div class="space-y-2">
        {clients.filter((c: any) => !c.staging).map((client: any) => {
          const h = healthData[client.id];
          const checks = [
            { label: 'GA4', ok: h.users > 0 },
            { label: 'GSC', ok: h.impressions > 0 },
            { label: 'Crawl', ok: h.pages > 0 },
            { label: 'AI Audit', ok: h.aiScore !== null },
            { label: 'Recs', ok: h.recsTotal >= 0 },
            { label: 'Uptime', ok: h.upStatus === 200 },
            { label: 'Bots', ok: h.botHits > 0 },
          ];
          return (
            <div class="border-b border-gray-800/50 pb-2">
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm text-white">{client.name}</span>
                <span class="text-[10px] text-gray-500">{checks.filter(c => c.ok).length}/{checks.length} connected</span>
              </div>
              <div class="flex gap-1">
                {checks.map(c => (
                  <span class={`text-[9px] px-1.5 py-0.5 rounded ${c.ok ? 'bg-green-900/50 text-green-400' : 'bg-red-900/50 text-red-400'}`}>{c.label}</span>
                ))}
              </div>
            </div>
          );
        })}
      </div>

      <h3 class="text-sm font-semibold text-gray-400 mt-6 mb-3">Automated Tasks</h3>
      <div class="text-xs text-gray-400 space-y-1" id="task-status">
        <p class="text-gray-600">Checking...</p>
      </div>

      <div class="mt-6 pt-4 border-t border-gray-800">
        <h3 class="text-sm font-semibold text-gray-400 mb-2">Quick Links</h3>
        <div class="flex flex-wrap gap-2">
          <a href="/crm" class="text-[10px] px-2 py-1 rounded bg-gray-800 text-gray-400 hover:text-white">CRM Pipeline</a>
          <a href="/add-client" class="text-[10px] px-2 py-1 rounded bg-gray-800 text-green-400 hover:text-green-300">+ Add Client</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Refresh button
    document.getElementById('refresh-btn')?.addEventListener('click', function() {
      var btn = this;
      btn.textContent = 'Refreshing...';
      btn.disabled = true;
      btn.style.opacity = '0.5';

      fetch('https://rank4ai-tracker.dawn-field-3d16.workers.dev/api/refresh-trigger', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'refresh' }),
      }).then(function() {
        btn.textContent = 'Refresh triggered — rebuilding...';
        setTimeout(function() {
          btn.textContent = 'Refresh All Data';
          btn.disabled = false;
          btn.style.opacity = '1';
        }, 5000);
      }).catch(function() {
        btn.textContent = 'Use terminal: python3 scripts/refresh_all.py';
        setTimeout(function() {
          btn.textContent = 'Refresh All Data';
          btn.disabled = false;
          btn.style.opacity = '1';
        }, 5000);
      });
    });
  </script>
</DashboardLayout>
