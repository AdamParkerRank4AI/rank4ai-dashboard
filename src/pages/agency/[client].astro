---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import SectionCard from '../../components/SectionCard.astro';
import AutomationCard from '../../components/AutomationCard.astro';
import clients from '../../data/clients.json';
import sections from '../../data/sections.json';
import automations from '../../data/automations.json';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  return clients.map((c) => ({ params: { client: c.id } }));
}

const { client: clientId } = Astro.params;
const client = clients.find((c) => c.id === clientId);

if (!client) {
  return Astro.redirect('/');
}

const auto = (automations as any)[clientId] || { stats: [], automated: [], batch: [], semi: [], pending: [], tokens: [], actions: [] };
const hasAutomations = auto.automated.length > 0 || auto.batch.length > 0 || auto.semi.length > 0;

// Load live data from JSON files
function loadJson(filename: string) {
  try {
    const filePath = path.join(process.cwd(), 'src', 'data', 'live', filename);
    if (fs.existsSync(filePath)) {
      return JSON.parse(fs.readFileSync(filePath, 'utf-8'));
    }
  } catch {}
  return null;
}

const uptimeData = loadJson('uptime.json');
const crawlData = loadJson(`crawl_${clientId}.json`);
const citationData = loadJson('promptfoo_citations.json') || loadJson('ai_citations.json');
const citationByType = loadJson('citations_by_type.json');
const ga4Data = loadJson('ga4.json');
const gscData = loadJson('gsc.json');
const bingData = loadJson('bing.json');
const auditData = loadJson('ai_audit.json');
const pagespeedData = loadJson('pagespeed.json');
const crawlActivityData = loadJson('crawl_activity.json');
const kgData = loadJson('knowledge_graph.json');
const nlpData = loadJson('nlp_entities.json');
const serpData = loadJson('serp_data.json');
const competitorData = loadJson('competitor_serp.json');
const recsData = loadJson('recommendations.json');
const historyData = loadJson('daily_history.json');
const newPagesData = loadJson('new_pages.json');
const snapshotDir = path.join(process.cwd(), 'src', 'data', 'snapshots', clientId || '');
let baseline: any = null;
try {
  const baselinePath = path.join(snapshotDir, 'baseline.json');
  if (fs.existsSync(baselinePath)) {
    baseline = JSON.parse(fs.readFileSync(baselinePath, 'utf-8'));
  }
} catch {}
const history = historyData?.[clientId] || [];
const newPages = newPagesData?.[clientId];

const uptime = uptimeData?.[clientId];
const crawl = crawlData;
const ga4 = ga4Data?.[clientId];
const gsc = gscData?.[clientId];
const citations = citationData?.[clientId];
const bing = bingData?.[clientId];
const audit = auditData?.[clientId];
const citByType = citationByType?.[clientId];
const pagespeed = pagespeedData?.[clientId];
const crawlActivity = crawlActivityData?.[clientId];
const kg = kgData?.[clientId];
const nlp = nlpData?.[clientId];
const serp = serpData?.[clientId];
const competitors = competitorData?.[clientId];
const recs = recsData?.[clientId];

// Build provider summary for citations
const citationProviders = citations?.providers || {};
const providerSummary = Object.entries(citationProviders)
  .filter(([_, s]: [string, any]) => (s as any).tested > 0)
  .map(([name, s]: [string, any]) => `${name}: ${(s as any).rate}%`)
  .join(' · ') || 'Not tested';

// Bing stats
const bingQueries = bing?.top_queries?.length || 0;
const bingImpressions = bing?.top_queries?.reduce((sum: number, q: any) => sum + (q.Impressions || 0), 0) || 0;

// Build section status from live data
const sectionStatus: Record<string, any> = {
  'overview': {
    status: 'healthy',
    statusText: 'All data sources active',
    metric: audit ? `${audit.overall_score}/100` : '--',
    metricLabel: audit ? `AI Readiness: ${audit.readiness}` : 'Active monitoring',
    lastUpdated: audit ? new Date(audit.audited_at).toLocaleDateString('en-GB') : undefined,
  },
  'ai-readiness': audit ? {
    status: audit.overall_score >= 70 ? 'healthy' : audit.overall_score >= 40 ? 'warning' : 'error',
    statusText: `${audit.readiness} — ${audit.pages_audited} pages scored${kg ? (kg.is_known_entity ? ' · Known Entity' : ' · Not in Knowledge Graph') : ''}`,
    metric: `${audit.overall_score}/100`,
    metricLabel: `Schema: ${audit.scores.schema}/100 · E-E-A-T: ${audit.scores.eeat}/100 · Citation: ${audit.scores.citation_potential}/100${nlp?.top_entities?.length ? ` · Top entity: ${nlp.top_entities[0].name}` : ''}`,
    lastUpdated: new Date(audit.audited_at).toLocaleDateString('en-GB'),
  } : {
    status: 'not-connected',
    statusText: 'Run run_ai_audit.py',
    metric: '--',
    metricLabel: 'AI readiness score',
  },
  'ai-citations': citByType ? {
    status: citByType.overall_rate >= 50 ? 'healthy' : citByType.overall_rate >= 10 ? 'warning' : 'error',
    statusText: `${citByType.total_cited}/${citByType.total_queries} queries · Brand: ${citByType.by_type?.brand?.rate || 0}% · Industry: ${citByType.by_type?.best_of?.rate || 0}%`,
    metric: `${citByType.overall_rate}%`,
    metricLabel: citByType.top_competitors?.length ? `Top competitor: ${citByType.top_competitors[0].name} (${citByType.top_competitors[0].mentions} mentions)` : 'No competitors detected',
    lastUpdated: new Date(citByType.tested_at).toLocaleDateString('en-GB'),
  } : citations ? {
    status: citations.citation_rate >= 50 ? 'healthy' : citations.citation_rate >= 20 ? 'warning' : 'error',
    statusText: `${citations.cited_count}/${citations.total_queries} queries cited`,
    metric: `${citations.citation_rate}%`,
    metricLabel: providerSummary,
    lastUpdated: citations.tested_at ? new Date(citations.tested_at).toLocaleDateString('en-GB') : undefined,
  } : {
    status: 'not-connected',
    statusText: 'Run citation tests',
    metric: '--',
    metricLabel: 'Citation rate',
  },
  'seo-health': crawl ? {
    status: crawl.total_issues > 10 ? 'warning' : crawl.total_issues > 0 ? 'warning' : 'healthy',
    statusText: `${crawl.total_issues} issues found`,
    metric: `${crawl.pages_crawled} pages`,
    metricLabel: `${crawl.total_issues} issues · ${crawl.pages_with_schema} with schema`,
    lastUpdated: new Date(crawl.crawled_at).toLocaleDateString('en-GB'),
  } : {
    status: 'not-connected',
    statusText: 'Run crawl_sites.py',
    metric: '--',
    metricLabel: 'Awaiting first crawl',
  },
  'traffic': ga4 ? {
    status: 'healthy',
    statusText: `${ga4.overview.sessions} sessions (30d)`,
    metric: `${ga4.overview.active_users.toLocaleString()}`,
    metricLabel: `Users (30d) · ${ga4.overview.pageviews.toLocaleString()} pageviews · ${ga4.overview.bounce_rate}% bounce`,
    lastUpdated: new Date(ga4.fetched_at).toLocaleDateString('en-GB'),
  } : {
    status: 'not-connected',
    statusText: 'Connect GA4',
    metric: '--',
    metricLabel: 'Monthly visitors',
  },
  'search-performance': gsc || bing || serp ? {
    status: (gsc?.totals?.impressions || 0) + bingImpressions > 0 ? 'healthy' : 'warning',
    statusText: `Google: ${gsc?.totals?.clicks || 0} clicks · Bing: ${bingImpressions} imp · Organic: ${serp?.organic_rate || 0}% ranked`,
    metric: `${(gsc?.totals?.impressions || 0) + bingImpressions}`,
    metricLabel: serp ? `AI Overviews: ${serp.queries_with_ai_overview}/${serp.total_queries} queries · In AIO: ${serp.brand_in_ai_overview}` : `Total impressions (Google + Bing)`,
    lastUpdated: serp ? new Date(serp.checked_at).toLocaleDateString('en-GB') : gsc ? new Date(gsc.fetched_at).toLocaleDateString('en-GB') : undefined,
  } : {
    status: 'not-connected',
    statusText: 'Connect GSC + Bing',
    metric: '--',
    metricLabel: 'Search impressions',
  },
  'competitors': competitors ? {
    status: competitors.client_visibility_pct > 50 ? 'healthy' : competitors.client_visibility_pct > 0 ? 'warning' : 'error',
    statusText: `Visible in ${competitors.client_visibility_pct}% of queries${competitors.client_avg_position ? ` · avg #${competitors.client_avg_position}` : ''}`,
    metric: `${competitors.client_visibility_pct}%`,
    metricLabel: competitors.competitors?.length ? `Top competitor: ${competitors.competitors[0].domain} (${competitors.competitors[0].visibility_pct}% visible)` : 'No competitor data',
    lastUpdated: new Date(competitors.checked_at).toLocaleDateString('en-GB'),
  } : {
    status: 'not-connected',
    statusText: 'Run competitor analysis',
    metric: '--',
    metricLabel: 'Competitor comparison',
  },
  'content-gaps': gsc ? {
    status: (gsc.content_gaps?.length || 0) > 0 ? 'warning' : 'healthy',
    statusText: (gsc.content_gaps?.length || 0) > 0 ? `${gsc.content_gaps.length} gaps found` : 'No gaps detected',
    metric: `${gsc.content_gaps?.length || 0}`,
    metricLabel: (gsc.totals?.impressions || 0) > 0 ? `From ${gsc.totals.impressions.toLocaleString()} impressions` : 'Monitoring for opportunities',
    lastUpdated: new Date(gsc.fetched_at).toLocaleDateString('en-GB'),
  } : {
    status: 'not-connected',
    statusText: 'Connect GSC',
    metric: '--',
    metricLabel: 'Opportunities found',
  },
  'site-tree': crawl ? {
    status: 'healthy',
    statusText: `${crawl.pages_crawled} pages mapped`,
    metric: `${crawl.pages_crawled}`,
    metricLabel: `Avg depth: ${crawl.avg_depth}`,
    lastUpdated: new Date(crawl.crawled_at).toLocaleDateString('en-GB'),
  } : {
    status: 'not-connected',
    statusText: 'Run crawl_sites.py',
    metric: '--',
    metricLabel: 'Pages discovered',
  },
  'internal-links': crawl ? {
    status: crawl.orphan_pages > 0 ? 'warning' : 'healthy',
    statusText: crawl.orphan_pages > 0 ? `${crawl.orphan_pages} orphan pages` : 'All pages linked',
    metric: `${crawl.links?.length || 0}`,
    metricLabel: `links mapped · ${crawl.orphan_pages} orphans`,
    lastUpdated: new Date(crawl.crawled_at).toLocaleDateString('en-GB'),
  } : {
    status: 'not-connected',
    statusText: 'Run crawl_sites.py',
    metric: '--',
    metricLabel: 'Internal links mapped',
  },
  'site-speed': pagespeed ? {
    status: (pagespeed.avg_scores?.performance || 0) >= 80 ? 'healthy' : (pagespeed.avg_scores?.performance || 0) >= 50 ? 'warning' : 'error',
    statusText: `Performance: ${pagespeed.avg_scores?.performance || 0} · SEO: ${pagespeed.avg_scores?.seo || 0}`,
    metric: `${pagespeed.avg_scores?.performance || 0}/100`,
    metricLabel: `Perf ${pagespeed.avg_scores?.performance || 0} · A11y ${pagespeed.avg_scores?.accessibility || 0} · SEO ${pagespeed.avg_scores?.seo || 0} · ${pagespeed.pages_tested} pages tested`,
    lastUpdated: new Date(pagespeed.fetched_at).toLocaleDateString('en-GB'),
  } : {
    status: 'not-connected',
    statusText: 'Run fetch_pagespeed.py',
    metric: '--',
    metricLabel: 'Lighthouse scores',
  },
  'uptime': uptime ? {
    status: uptime.is_up ? 'healthy' : 'error',
    statusText: uptime.is_up ? `${uptime.response_time_ms}ms response` : 'SITE DOWN',
    metric: `${uptime.uptime_pct}%`,
    metricLabel: `Uptime (${uptime.checks_total} checks) · avg ${uptime.avg_response_ms || uptime.response_time_ms}ms`,
    lastUpdated: new Date(uptime.checked_at).toLocaleDateString('en-GB'),
  } : {
    status: 'not-connected',
    statusText: 'Run check_uptime.py',
    metric: '--',
    metricLabel: 'Uptime percentage',
  },
  'crawl-activity': crawlActivity ? {
    status: crawlActivity.ai_bots_blocked > 0 ? 'warning' : 'healthy',
    statusText: `${crawlActivity.bing_total_crawled} Bing crawls · ${crawlActivity.ai_bots_allowed} AI bots allowed`,
    metric: `${crawlActivity.bing_indexed}`,
    metricLabel: `Pages indexed in Bing · ${crawlActivity.ai_bots_blocked > 0 ? crawlActivity.ai_bots_blocked + ' AI bots BLOCKED' : 'All AI bots allowed'}`,
    lastUpdated: new Date(crawlActivity.fetched_at).toLocaleDateString('en-GB'),
  } : {
    status: 'not-connected',
    statusText: 'Run fetch_crawl_activity.py',
    metric: '--',
    metricLabel: 'Bot crawl data',
  },
  'new-pages': newPages ? {
    status: newPages.new_pages_count > 0 ? 'healthy' : 'pending',
    statusText: newPages.new_pages_count > 0 ? `${newPages.new_pages_count} new pages since baseline` : `${newPages.current_pages} pages tracked`,
    metric: `${newPages.new_pages_count}`,
    metricLabel: newPages.new_pages_count > 0 ? Object.entries(newPages.by_category || {}).map(([cat, d]: [string, any]) => `${d.count} ${cat}`).join(' · ') : `Baseline: ${newPages.baseline_pages} pages · tracking changes`,
    lastUpdated: new Date(newPages.checked_at).toLocaleDateString('en-GB'),
  } : {
    status: 'not-connected',
    statusText: 'Run track_new_pages.py',
    metric: '--',
    metricLabel: 'New pages added',
  },
  'crawl-status': crawl ? {
    status: 'healthy',
    statusText: 'Last crawl complete',
    metric: new Date(crawl.crawled_at).toLocaleDateString('en-GB'),
    metricLabel: `${crawl.pages_crawled} pages · ${crawl.total_issues} issues`,
    lastUpdated: new Date(crawl.crawled_at).toLocaleDateString('en-GB'),
  } : {
    status: 'not-connected',
    statusText: 'No crawls yet',
    metric: '--',
    metricLabel: 'Last crawl',
  },
  'recommendations': recs ? {
    status: recs.critical > 0 ? 'error' : recs.high > 0 ? 'warning' : 'healthy',
    statusText: `${recs.critical} critical · ${recs.high} high · ${recs.medium} medium`,
    metric: `${recs.total}`,
    metricLabel: `Prioritised actions to improve AI visibility`,
    lastUpdated: new Date(recs.generated_at).toLocaleDateString('en-GB'),
  } : {
    status: 'not-connected',
    statusText: 'Run generate_recommendations.py',
    metric: '--',
    metricLabel: 'Recommendations',
  },
  'positive-signals': crawl ? {
    status: 'healthy',
    statusText: `${crawl.positive_signals?.length || 0} signals detected`,
    metric: `${crawl.positive_signals?.length || 0}`,
    metricLabel: `${crawl.pages_with_schema} pages with schema · avg ${crawl.avg_word_count} words`,
    lastUpdated: new Date(crawl.crawled_at).toLocaleDateString('en-GB'),
  } : {
    status: 'not-connected',
    statusText: 'Run data collection scripts',
    metric: '--',
    metricLabel: 'Positive signals detected',
  },
};

// Chart data for inline expansion
const chartDataMap: Record<string, string> = {};
if (ga4?.daily) {
  chartDataMap['traffic'] = JSON.stringify(ga4.daily.map((d: any) => ({ date: d.date, value: d.users })));
}
if (crawlActivity?.bing_crawl_daily?.length) {
  chartDataMap['crawl-activity'] = JSON.stringify(crawlActivity.bing_crawl_daily.map((d: any) => ({ date: d.date, value: d.crawled_pages })));
  chartDataMap['crawl-status'] = JSON.stringify(crawlActivity.bing_crawl_daily.map((d: any) => ({ date: d.date, value: d.in_index })));
}
// Search performance — GSC impressions over time (use daily from GA4 as proxy for now)
if (ga4?.daily) {
  chartDataMap['search-performance'] = JSON.stringify(ga4.daily.map((d: any) => ({ date: d.date, value: d.sessions })));
}
// AI readiness — just show the score breakdown as a bar
if (audit) {
  chartDataMap['ai-readiness'] = JSON.stringify([
    { date: 'Schema', value: audit.scores.schema },
    { date: 'Structure', value: audit.scores.content_structure },
    { date: 'E-E-A-T', value: audit.scores.eeat },
    { date: 'Citation', value: audit.scores.citation_potential },
  ]);
}
// Uptime — show response time if we have history
const uptimeHistoryData = loadJson('uptime_history.json');
const uptimeHist = uptimeHistoryData?.[clientId];
if (uptimeHist?.length) {
  chartDataMap['uptime'] = JSON.stringify(uptimeHist.map((d: any) => ({ date: d.time, value: d.ms })));
}
// Site speed — show scores as bar
if (pagespeed?.avg_scores) {
  chartDataMap['site-speed'] = JSON.stringify([
    { date: 'Performance', value: pagespeed.avg_scores.performance || 0 },
    { date: 'SEO', value: pagespeed.avg_scores.seo || 0 },
    { date: 'Accessibility', value: pagespeed.avg_scores.accessibility || 0 },
    { date: 'Best Practices', value: pagespeed.avg_scores['best-practices'] || 0 },
  ]);
}

// Count issues per section from recommendations
const recsForSection: Record<string, number> = {};
if (recs?.recommendations) {
  for (const r of recs.recommendations) {
    const cat = r.category.toLowerCase();
    if (cat.includes('schema')) recsForSection['seo-health'] = (recsForSection['seo-health'] || 0) + 1;
    else if (cat.includes('seo')) recsForSection['seo-health'] = (recsForSection['seo-health'] || 0) + 1;
    else if (cat.includes('citation')) recsForSection['ai-citations'] = (recsForSection['ai-citations'] || 0) + 1;
    else if (cat.includes('ai readiness') || cat.includes('ai visibility')) recsForSection['ai-readiness'] = (recsForSection['ai-readiness'] || 0) + 1;
    else if (cat.includes('performance')) recsForSection['site-speed'] = (recsForSection['site-speed'] || 0) + 1;
    else if (cat.includes('internal')) recsForSection['internal-links'] = (recsForSection['internal-links'] || 0) + 1;
    else if (cat.includes('content')) recsForSection['content-gaps'] = (recsForSection['content-gaps'] || 0) + 1;
    else if (cat.includes('search')) recsForSection['search-performance'] = (recsForSection['search-performance'] || 0) + 1;
    else if (cat.includes('index')) recsForSection['crawl-activity'] = (recsForSection['crawl-activity'] || 0) + 1;
    else if (cat.includes('e-e-a-t')) recsForSection['ai-readiness'] = (recsForSection['ai-readiness'] || 0) + 1;
    else if (cat.includes('access')) recsForSection['accessibility'] = (recsForSection['accessibility'] || 0) + 1;
  }
}

// Calculate changes from baseline
const changes: Record<string, { value: number; label: string }> = {};
if (baseline) {
  if (audit && baseline.ai_readiness) {
    const diff = audit.overall_score - (baseline.ai_readiness.overall_score || 0);
    if (diff !== 0) changes['ai-readiness'] = { value: diff, label: 'pts' };
  }
  if (citations && baseline.ai_citations) {
    const diff = Math.round((citations.overall_rate || 0) - (baseline.ai_citations.citation_rate || 0));
    if (diff !== 0) changes['ai-citations'] = { value: diff, label: '%' };
  }
  if (crawl && baseline.crawl) {
    const diff = (crawl.total_issues || 0) - (baseline.crawl.total_issues || 0);
    if (diff !== 0) changes['seo-health'] = { value: -diff, label: 'issues' }; // negative = improvement
  }
  if (ga4?.overview && baseline.traffic) {
    const diff = (ga4.overview.active_users || 0) - (baseline.traffic.active_users || 0);
    if (diff !== 0) changes['traffic'] = { value: diff, label: 'users' };
  }
}

// Token expiry calc
function daysUntil(dateStr: string): number {
  if (dateStr === 'never' || dateStr === 'auto') return 999;
  const d = new Date(dateStr);
  const now = new Date();
  return Math.ceil((d.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
}
---

<DashboardLayout title={client.name} currentClient={clientId} view="agency">
  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white">{client.name}</h1>
        <p class="text-sm text-gray-400 mt-1">{client.domain}</p>
      </div>
      <div class="flex gap-2">
        <a
          href={`/agency/${clientId}/settings`}
          class="px-3 py-1.5 rounded bg-gray-800 text-gray-300 hover:bg-gray-700 text-xs transition"
        >
          Client View Settings
        </a>
        <a
          href={`/client/${clientId}`}
          class="px-3 py-1.5 rounded bg-blue-600 text-white hover:bg-blue-500 text-xs transition"
        >
          Preview Client View
        </a>
      </div>
    </div>
  </div>

  <!-- Fixes summary bar -->
  {recs && recs.total > 0 && (
    <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 mb-4 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-2">
          <span class="text-sm font-semibold text-white">{recs.total} fixes needed</span>
        </div>
        {recs.critical > 0 && (
          <span class="px-2 py-1 rounded bg-red-900/50 text-red-300 text-xs font-medium">{recs.critical} critical</span>
        )}
        {recs.high > 0 && (
          <span class="px-2 py-1 rounded bg-yellow-900/50 text-yellow-300 text-xs font-medium">{recs.high} high</span>
        )}
        {recs.medium > 0 && (
          <span class="px-2 py-1 rounded bg-blue-900/50 text-blue-300 text-xs font-medium">{recs.medium} medium</span>
        )}
        {recs.low > 0 && (
          <span class="px-2 py-1 rounded bg-gray-800 text-gray-400 text-xs">{recs.low} low</span>
        )}
      </div>
      <a href={`/agency/${clientId}/recommendations`} class="text-xs text-blue-400 hover:text-blue-300 transition">
        View all fixes →
      </a>
    </div>
  )}

  <!-- Stats bar -->
  {auto.stats.length > 0 && (
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3 mb-6">
      {auto.stats.map((stat: any) => (
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{stat.value}</div>
          <div class="text-xs text-gray-500 mt-1">{stat.label}</div>
        </div>
      ))}
    </div>
  )}

  <!-- Status bar -->
  <div class="flex flex-wrap gap-3 mb-6 text-xs">
    <div class="px-3 py-1.5 rounded-full bg-gray-800 text-gray-400">
      {client.allSections.length} data sections
    </div>
    <div class="px-3 py-1.5 rounded-full bg-blue-900/50 text-blue-300">
      {client.clientViewSections.length} visible to client
    </div>
    {hasAutomations && (
      <div class="px-3 py-1.5 rounded-full bg-green-900/50 text-green-300">
        {auto.automated.length} automations live
      </div>
    )}
    {auto.actions.filter((a: any) => a.priority === 'high').length > 0 && (
      <div class="px-3 py-1.5 rounded-full bg-red-900/50 text-red-300">
        {auto.actions.filter((a: any) => a.priority === 'high').length} urgent actions
      </div>
    )}
  </div>

  <!-- AI SEARCH section -->
  {(() => {
    const aiSections = ['overview', 'ai-readiness', 'ai-citations', 'recommendations', 'competitors'];
    const seoSections = ['seo-health', 'traffic', 'search-performance', 'content-gaps', 'new-pages', 'site-tree', 'internal-links'];
    const monitorSections = ['site-speed', 'crawl-activity', 'uptime', 'crawl-status', 'positive-signals'];

    function renderGroup(title: string, ids: string[]) {
      const filtered = sections.filter((s: any) => ids.includes(s.id));
      if (filtered.length === 0) return null;
      return `group:${title}`;
    }

    return null;
  })()}

  <!-- Recommendations first -->
  <div class="grid grid-cols-1 gap-4 mb-6">
    {sections.filter((s: any) => s.id === 'recommendations').map((section: any) => {
      const data = sectionStatus[section.id] || {};
      return (
        <SectionCard
          id={section.id} label={section.label} description={section.description}
          status={data.status} statusText={data.statusText} metric={data.metric}
          metricLabel={data.metricLabel} lastUpdated={data.lastUpdated}
          clientId={clientId}
          issueCount={recs?.total}
        />
      );
    })}
  </div>

