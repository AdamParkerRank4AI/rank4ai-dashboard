              <span>Platform</span><span>Expires</span><span>Days Left</span><span>Type</span>
            </div>
            {auto.tokens.map((token: any) => {
              const days = daysUntil(token.expires);
              const color = days > 30 ? 'text-green-400' : days > 14 ? 'text-yellow-400' : days < 999 ? 'text-red-400' : 'text-green-400';
              const daysText = days >= 999 ? 'N/A' : `${days} days`;
              return (
                <div class="grid grid-cols-4 gap-0 px-4 py-2 border-b border-gray-800 last:border-0 text-sm">
                  <span class="text-white">{token.name}</span>
                  <span class="text-gray-400">{token.expires === 'never' ? 'Never' : token.expires === 'auto' ? 'Auto-refresh' : token.expires}</span>
                  <span class={color}>{daysText}</span>
                  <span class="text-gray-500 text-xs">{token.type}</span>
                </div>
              );
            })}
          </div>
        </div>
      )}
    </>
  )}
</DashboardLayout>

<script define:vars={{ chartDataMap }}>
  // Render inline charts when panels are expanded
  document.querySelectorAll('[data-chart-panel]').forEach(panel => {
    panel.addEventListener('render-chart', async (e) => {
      const id = e.detail.id;
      const dataStr = JSON.stringify(chartDataMap[id] || '[]');
      const data = JSON.parse(JSON.parse(dataStr));

      if (!data || data.length === 0) return;

      const canvas = panel.querySelector(`[data-chart-canvas="${id}"]`);
      if (!canvas) return;

      const { Chart } = await import('https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.js');

      const labels = data.map(d => {
        if (!d.date) return '';
        if (d.date.length === 8 && /^\d{8}$/.test(d.date)) {
          const date = `${d.date.slice(0,4)}-${d.date.slice(4,6)}-${d.date.slice(6,8)}`;
          return new Date(date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
        }
        // Check if it's a date string
        const parsed = new Date(d.date);
        if (!isNaN(parsed.getTime()) && d.date.includes('-')) {
          return parsed.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
        }
        // Not a date — use as-is (e.g. "Schema", "Performance")
        return d.date;
      });

      const colors = {
        'traffic': { border: '#3b82f6', bg: 'rgba(59, 130, 246, 0.1)' },
        'crawl-activity': { border: '#8b5cf6', bg: 'rgba(139, 92, 246, 0.1)' },
        'crawl-status': { border: '#10b981', bg: 'rgba(16, 185, 129, 0.1)' },
      };
      const color = colors[id] || { border: '#3b82f6', bg: 'rgba(59, 130, 246, 0.1)' };

      new Chart(canvas, {
        type: ['crawl-activity', 'ai-readiness', 'site-speed'].includes(id) ? 'bar' : 'line',
        data: {
          labels,
          datasets: [{
            label: id.replace(/-/g, ' '),
            data: data.map(d => d.value),
            borderColor: color.border,
            backgroundColor: color.bg,
            fill: true,
            tension: 0.3,
            pointRadius: 2,
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { display: false } },
          scales: {
            x: { ticks: { color: '#6b7280', font: { size: 9 }, maxTicksLimit: 10 }, grid: { color: '#1f2937' } },
            y: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: '#1f2937' } },
          }
        }
      });
    });
  });
</script>
