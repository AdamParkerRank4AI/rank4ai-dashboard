---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ToggleSwitch from '../../../components/ToggleSwitch.astro';
import clients from '../../../data/clients.json';
import sections from '../../../data/sections.json';

export function getStaticPaths() {
  return clients.map((c) => ({ params: { client: c.id } }));
}

const { client: clientId } = Astro.params;
const client = clients.find((c) => c.id === clientId);

if (!client) {
  return Astro.redirect('/');
}

// Filter out 'overview' — that's agency-only
const toggleableSections = sections.filter((s) => s.id !== 'overview');
---

<DashboardLayout title={`${client.name} — Settings`} currentClient={clientId} view="agency">
  <div class="max-w-2xl">
    <div class="mb-6">
      <a href={`/agency/${clientId}`} class="text-sm text-gray-400 hover:text-gray-300 transition">
        &larr; Back to {client.name}
      </a>
    </div>

    <h1 class="text-2xl font-bold text-white mb-2">Client View Settings</h1>
    <p class="text-gray-400 mb-2">{client.name} — {client.domain}</p>
    <p class="text-sm text-gray-500 mb-8">
      Toggle which sections are visible in the client's dashboard view.
      Changes update the client view at <code class="text-blue-400">/client/{clientId}</code>
    </p>

    <div class="space-y-3">
      {toggleableSections.map((section) => (
        <ToggleSwitch
          id={section.id}
          label={section.label}
          description={section.description}
          checked={client.clientViewSections.includes(section.id)}
          clientId={clientId}
        />
      ))}
    </div>

    <div class="mt-8 p-4 rounded-lg bg-gray-800 border border-gray-700">
      <p class="text-sm text-gray-300 mb-2">How to update client visibility:</p>
      <p class="text-xs text-gray-500">
        Edit <code class="text-blue-400">src/data/clients.json</code> and add/remove section IDs
        from the <code class="text-blue-400">clientViewSections</code> array. Redeploy to apply changes.
        Dynamic toggling will be added when the dashboard gets a backend.
      </p>
    </div>

    <div class="mt-4">
      <a
        href={`/client/${clientId}`}
        class="inline-block px-4 py-2 rounded bg-blue-600 text-white hover:bg-blue-500 text-sm transition"
      >
        Preview Client View
      </a>
    </div>
  </div>
</DashboardLayout>
