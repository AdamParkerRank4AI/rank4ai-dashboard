---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import ToggleSwitch from '../../../components/ToggleSwitch.astro';
import clients from '../../../data/clients.json';
import sections from '../../../data/sections.json';

export function getStaticPaths() {
  return clients.map((c) => ({ params: { client: c.id } }));
}

const { client: clientId } = Astro.params;
const client = clients.find((c) => c.id === clientId);

if (!client) {
  return Astro.redirect('/');
}

// Filter out 'overview' — that's agency-only
const toggleableSections = sections.filter((s) => s.id !== 'overview');
---

<DashboardLayout title={`${client.name} — Settings`} currentClient={clientId} view="agency">
  <div class="max-w-2xl">
    <div class="mb-6">
      <a href={`/agency/${clientId}`} class="text-sm text-gray-400 hover:text-gray-300 transition">
        &larr; Back to {client.name}
      </a>
    </div>

    <h1 class="text-2xl font-bold text-white mb-2">Client View Settings</h1>
    <p class="text-gray-400 mb-2">{client.name} — {client.domain}</p>
    <p class="text-sm text-gray-500 mb-8">
      Toggle which sections are visible in the client's dashboard view.
      Changes update the client view at <code class="text-blue-400">/client/{clientId}</code>
    </p>

    <div class="space-y-3">
      {toggleableSections.map((section) => (
        <ToggleSwitch
          id={section.id}
          label={section.label}
          description={section.description}
          checked={client.clientViewSections.includes(section.id)}
          clientId={clientId}
        />
      ))}
    </div>

    <p id="settings-status" class="text-xs mt-4"></p>

    <div class="mt-8 p-4 rounded-lg bg-gray-800 border border-gray-700">
      <p class="text-sm text-gray-300 mb-2">How it works</p>
      <p class="text-xs text-gray-500">
        Toggling a section here saves to <code class="text-blue-400">src/data/clients.json</code> in the dashboard repo, then fires a Cloudflare deploy hook. The client view refreshes within 1 to 2 minutes. Bearer token (EDIT_SECRET) required on first toggle.
      </p>
    </div>

    <div class="mt-4 flex gap-2">
      <a
        href={`/client/${clientId}`}
        class="inline-block px-4 py-2 rounded bg-blue-600 text-white hover:bg-blue-500 text-sm transition"
      >
        Preview Client View
      </a>
      <a
        href={`/agency/${clientId}`}
        class="inline-block px-4 py-2 rounded bg-gray-700 text-gray-300 hover:bg-gray-600 text-sm transition"
      >
        Back to Agency View
      </a>
    </div>
  </div>

  <script is:inline define:vars={{ clientId }}>
    (function() {
      var TOKEN_KEY = 'r4ai_edit_token';
      function getToken() {
        try { return sessionStorage.getItem(TOKEN_KEY) || ''; } catch { return ''; }
      }
      function setToken(t) { try { if (t) sessionStorage.setItem(TOKEN_KEY, t); else sessionStorage.removeItem(TOKEN_KEY); } catch {} }
      var status = document.getElementById('settings-status');

      document.querySelectorAll('[data-section-id]').forEach(function(input) {
        input.addEventListener('change', async function(e) {
          var sectionId = input.dataset.sectionId;
          var enabled = input.checked;
          var token = getToken();
          if (!token) {
            var t = prompt('Paste EDIT_SECRET (saved in this tab only).');
            if (!t) { input.checked = !enabled; return; }
            setToken(t.trim());
            token = getToken();
          }
          status.textContent = 'Saving ' + sectionId + '…';
          status.style.color = '#facc15';
          try {
            var r = await fetch('/api/update-client-sections', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
              body: JSON.stringify({ clientId: clientId, sectionId: sectionId, enabled: enabled }),
            });
            var data = await r.json();
            if (!r.ok || !data.ok) {
              status.textContent = '✗ ' + (data.error || 'HTTP ' + r.status);
              status.style.color = '#f87171';
              if (r.status === 401) setToken('');
              input.checked = !enabled;  // revert toggle
              return;
            }
            status.innerHTML = '✓ ' + sectionId + ' ' + (enabled ? 'enabled' : 'disabled') + ' · <a target="_blank" class="underline text-emerald-400" href="' + (data.commitUrl || '#') + '">' + (data.commit || '').slice(0, 7) + '</a> · deploy will reflect in 1-2 min';
            status.style.color = '#34d399';
          } catch (err) {
            status.textContent = '✗ ' + (err.message || 'Network error');
            status.style.color = '#f87171';
            input.checked = !enabled;
          }
        });
      });
    })();
  </script>
</DashboardLayout>
