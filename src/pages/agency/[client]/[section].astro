  <!-- NEW PAGES -->
  {sectionId === 'new-pages' && newPagesDetail && (
    <div>
      <div class="grid grid-cols-3 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{newPagesDetail.baseline_pages}</div>
          <div class="text-xs text-gray-500">Baseline Pages</div>
