---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import SiteTree from '../../../components/SiteTree.jsx';
import LinkGraph from '../../../components/LinkGraph.jsx';
import clients from '../../../data/clients.json';
import sections from '../../../data/sections.json';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const paths: any[] = [];
  for (const c of clients) {
    for (const s of sections) {
      paths.push({ params: { client: c.id, section: s.id } });
    }
  }
  return paths;
}

const { client: clientId, section: sectionId } = Astro.params;
const client = clients.find((c) => c.id === clientId);
const section = sections.find((s) => s.id === sectionId);

if (!client || !section) {
  return Astro.redirect('/');
}

function loadJson(filename: string) {
  try {
    const filePath = path.join(process.cwd(), 'src', 'data', 'live', filename);
    if (fs.existsSync(filePath)) {
      return JSON.parse(fs.readFileSync(filePath, 'utf-8'));
    }
  } catch {}
  return null;
}

const ga4All = loadJson('ga4.json');
const gscAll = loadJson('gsc.json');
const bingAll = loadJson('bing.json');
const serpAll = loadJson('serp_data.json');
const competitorAll = loadJson('competitor_serp.json');
const recsAll = loadJson('recommendations.json');
const newPagesAll = loadJson('new_pages.json');
const citationPrompts = loadJson('citation_prompts.json');
const dailyHistory = loadJson('daily_history.json');
const crawlData = loadJson(`crawl_${clientId}.json`);
const uptimeAll = loadJson('uptime.json');
const uptimeHistory = loadJson('uptime_history.json');
const citationsAll = loadJson('citations_by_type.json');
const citByTypeAll = loadJson('citations_by_type.json');
const auditAll = loadJson('ai_audit.json');
const pagespeedAll = loadJson('pagespeed.json');
const crawlActivityAll = loadJson('crawl_activity.json');
const kgAll = loadJson('knowledge_graph.json');
const nlpAll = loadJson('nlp_entities.json');

const ga4 = ga4All?.[clientId];
const gsc = gscAll?.[clientId];
const bing = bingAll?.[clientId];
const serp = serpAll?.[clientId];
const competitors = competitorAll?.[clientId];
const recs = recsAll?.[clientId];
const newPagesDetail = newPagesAll?.[clientId];
const prompts = citationPrompts?.[clientId];
const history = dailyHistory?.[clientId] || [];
const uptime = uptimeAll?.[clientId];
const citations = citationsAll?.[clientId];
const citByType = citByTypeAll?.[clientId];
const audit = auditAll?.[clientId];
const pagespeed = pagespeedAll?.[clientId];
const crawlActivityDetail = crawlActivityAll?.[clientId];
const kg = kgAll?.[clientId];
const nlp = nlpAll?.[clientId];

// Prepare chart data as JSON strings for client-side JS
const dailyTraffic = JSON.stringify(ga4?.daily || []);
const topPages = JSON.stringify(ga4?.top_pages || []);
const sources = JSON.stringify(ga4?.sources || []);
const countries = JSON.stringify(ga4?.countries || []);
const topQueries = JSON.stringify(gsc?.top_queries || []);
const gscPages = JSON.stringify(gsc?.top_pages || []);
const contentGaps = JSON.stringify(gsc?.content_gaps || []);
const crawlPages = JSON.stringify(crawlData?.pages || []);
const crawlIssues = JSON.stringify(crawlData?.issues || []);
const crawlLinks = JSON.stringify(crawlData?.links?.slice(0, 200) || []);
const positiveSignals = JSON.stringify(crawlData?.positive_signals || []);
const citationResults = JSON.stringify(citations?.results || []);
const uptimeChecks = JSON.stringify(uptimeHistory?.[clientId] || []);
const crawlDaily = JSON.stringify(crawlActivityDetail?.bing_crawl_daily || []);
---

<DashboardLayout title={`${section.label} — ${client.name}`} currentClient={clientId} view="agency">
  <div class="mb-6">
    <a href={`/agency/${clientId}`} class="text-sm text-gray-400 hover:text-gray-300 transition">
      &larr; Back to {client.name}
    </a>
  </div>

  <h1 class="text-2xl font-bold text-white mb-1">{section.label}</h1>
  <p class="text-sm text-gray-400 mb-6">{client.name} — {client.domain}</p>

  <!-- TRAFFIC -->
  {sectionId === 'traffic' && ga4 && (
    <div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{ga4.overview.active_users.toLocaleString()}</div>
          <div class="text-xs text-gray-500">Active Users</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{ga4.overview.sessions.toLocaleString()}</div>
          <div class="text-xs text-gray-500">Sessions</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{ga4.overview.pageviews.toLocaleString()}</div>
          <div class="text-xs text-gray-500">Pageviews</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{ga4.overview.bounce_rate}%</div>
          <div class="text-xs text-gray-500">Bounce Rate</div>
        </div>
      </div>

      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6 mb-6">
        <h3 class="text-sm font-semibold text-gray-400 mb-4">Daily Users (Last 30 Days)</h3>
        <canvas id="trafficChart" height="250"></canvas>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
          <h3 class="text-sm font-semibold text-gray-400 mb-4">Top Pages</h3>
          <div class="space-y-2">
            {ga4.top_pages.slice(0, 10).map((p: any) => (
              <div class="flex justify-between text-xs border-b border-gray-800 pb-2">
                <span class="text-gray-300 truncate max-w-[250px]">{p.path}</span>
                <span class="text-white font-medium">{p.pageviews} views</span>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
          <h3 class="text-sm font-semibold text-gray-400 mb-4">Traffic Sources</h3>
          <div class="space-y-2">
            {ga4.sources.map((s: any) => (
              <div class="flex justify-between text-xs border-b border-gray-800 pb-2">
                <span class="text-gray-300">{s.channel}</span>
                <span class="text-white font-medium">{s.sessions} sessions</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6 mt-6">
        <h3 class="text-sm font-semibold text-gray-400 mb-4">Top Countries</h3>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
          {ga4.countries.slice(0, 10).map((c: any) => (
            <div class="text-center p-3 bg-gray-800 rounded-lg">
              <div class="text-white font-medium text-sm">{c.users}</div>
              <div class="text-xs text-gray-500">{c.country}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- CONTENT GAPS -->
  {sectionId === 'content-gaps' && gsc && (
    <div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{gsc.totals?.clicks || 0}</div>
          <div class="text-xs text-gray-500">Total Clicks</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{gsc.totals?.impressions?.toLocaleString() || 0}</div>
          <div class="text-xs text-gray-500">Impressions</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{gsc.totals?.ctr || 0}%</div>
          <div class="text-xs text-gray-500">CTR</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{gsc.totals?.position || 0}</div>
          <div class="text-xs text-gray-500">Avg Position</div>
        </div>
      </div>

      {gsc.content_gaps?.length > 0 && (
        <div class="bg-gray-900 border border-yellow-800/50 rounded-lg p-6 mb-6">
          <h3 class="text-sm font-semibold text-yellow-400 mb-4">Content Gaps — High Impressions, Low Clicks</h3>
          <div class="overflow-x-auto">
            <table class="w-full text-xs">
              <thead>
                <tr class="text-gray-500 border-b border-gray-800">
                  <th class="text-left py-2 px-3">Query</th>
                  <th class="text-right py-2 px-3">Impressions</th>
                  <th class="text-right py-2 px-3">Clicks</th>
                  <th class="text-right py-2 px-3">CTR</th>
                  <th class="text-right py-2 px-3">Position</th>
                </tr>
              </thead>
              <tbody>
                {gsc.content_gaps.map((g: any) => (
                  <tr class="border-b border-gray-800/50">
                    <td class="py-2 px-3 text-gray-300">{g.query}</td>
                    <td class="py-2 px-3 text-right text-white">{g.impressions}</td>
                    <td class="py-2 px-3 text-right text-white">{g.clicks}</td>
                    <td class="py-2 px-3 text-right text-yellow-400">{g.ctr}%</td>
                    <td class="py-2 px-3 text-right text-gray-400">{g.position}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
        <h3 class="text-sm font-semibold text-gray-400 mb-4">Top Queries</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-xs">
            <thead>
              <tr class="text-gray-500 border-b border-gray-800">
                <th class="text-left py-2 px-3">Query</th>
                <th class="text-right py-2 px-3">Clicks</th>
                <th class="text-right py-2 px-3">Impressions</th>
                <th class="text-right py-2 px-3">CTR</th>
                <th class="text-right py-2 px-3">Position</th>
              </tr>
            </thead>
            <tbody>
              {gsc.top_queries.map((q: any) => (
                <tr class="border-b border-gray-800/50">
                  <td class="py-2 px-3 text-gray-300">{q.query}</td>
                  <td class="py-2 px-3 text-right text-white">{q.clicks}</td>
                  <td class="py-2 px-3 text-right text-white">{q.impressions}</td>
                  <td class="py-2 px-3 text-right text-blue-400">{q.ctr}%</td>
                  <td class="py-2 px-3 text-right text-gray-400">{q.position}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  )}

  <!-- SEO HEALTH -->
  {sectionId === 'seo-health' && crawlData && (
    <div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{crawlData.pages_crawled}</div>
          <div class="text-xs text-gray-500">Pages Crawled</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-yellow-400">{crawlData.total_issues}</div>
          <div class="text-xs text-gray-500">Issues Found</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-green-400">{crawlData.pages_with_schema}</div>
          <div class="text-xs text-gray-500">With Schema</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{crawlData.avg_word_count}</div>
          <div class="text-xs text-gray-500">Avg Word Count</div>
        </div>
      </div>

      {crawlData.issues.length > 0 && (
        <div class="bg-gray-900 border border-yellow-800/50 rounded-lg p-6 mb-6">
          <h3 class="text-sm font-semibold text-yellow-400 mb-4">Issues</h3>
          <div class="overflow-x-auto max-h-96 overflow-y-auto">
            <table class="w-full text-xs">
              <thead class="sticky top-0 bg-gray-900">
                <tr class="text-gray-500 border-b border-gray-800">
                  <th class="text-left py-2 px-3">Type</th>
                  <th class="text-left py-2 px-3">URL</th>
                  <th class="text-left py-2 px-3">Detail</th>
                </tr>
              </thead>
              <tbody>
                {crawlData.issues.map((issue: any) => (
                  <tr class="border-b border-gray-800/50">
                    <td class="py-2 px-3 text-yellow-400 whitespace-nowrap">{issue.type.replace(/_/g, ' ')}</td>
                    <td class="py-2 px-3 text-gray-300 truncate max-w-[300px]">{new URL(issue.url).pathname}</td>
                    <td class="py-2 px-3 text-gray-500">{issue.detail}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
        <h3 class="text-sm font-semibold text-gray-400 mb-4">All Pages</h3>
        <div class="overflow-x-auto max-h-[500px] overflow-y-auto">
          <table class="w-full text-xs">
            <thead class="sticky top-0 bg-gray-900">
              <tr class="text-gray-500 border-b border-gray-800">
                <th class="text-left py-2 px-3">Path</th>
                <th class="text-left py-2 px-3">H1</th>
                <th class="text-right py-2 px-3">Words</th>
                <th class="text-right py-2 px-3">Links In</th>
                <th class="text-right py-2 px-3">Depth</th>
                <th class="text-left py-2 px-3">Schema</th>
              </tr>
            </thead>
            <tbody>
              {crawlData.pages.slice(0, 100).map((p: any) => (
                <tr class="border-b border-gray-800/50">
                  <td class="py-2 px-3 text-gray-300 truncate max-w-[200px]">{p.path}</td>
                  <td class="py-2 px-3 text-gray-400 truncate max-w-[200px]">{p.h1 || '—'}</td>
                  <td class="py-2 px-3 text-right text-white">{p.word_count}</td>
                  <td class="py-2 px-3 text-right text-white">{p.internal_links_in}</td>
                  <td class="py-2 px-3 text-right text-gray-400">{p.depth}</td>
                  <td class="py-2 px-3 text-green-400 text-[10px]">{p.schemas?.join(', ') || '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  )}

  <!-- AI CITATIONS -->
  {sectionId === 'ai-citations' && (citByType || citations) && (
    <div>
      {citByType ? (
        <>
          <!-- Bing Copilot citation banner -->
          {bing?.top_queries?.length > 0 && (
            <div class="bg-blue-950/30 border border-blue-800/50 rounded-lg p-4 mb-6 flex items-center justify-between">
              <div>
                <span class="text-sm text-blue-300 font-medium">Bing Copilot Citations</span>
                <span class="text-xs text-gray-500 ml-2">From Bing AI Performance (live data)</span>
              </div>
              <div class="flex items-center gap-4">
                <div class="text-right">
                  <div class="text-xl font-bold text-blue-400">{bing.top_queries.reduce((sum: number, q: any) => sum + (q.Impressions || 0), 0)}</div>
                  <div class="text-[10px] text-gray-500">Total Impressions</div>
                </div>
                <div class="text-right">
                  <div class="text-lg font-bold text-white">{bing.top_queries.length}</div>
                  <div class="text-[10px] text-gray-500">Queries</div>
                </div>
              </div>
            </div>
          )}

          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
            <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
              <div class={`text-2xl font-bold ${citByType.overall_rate >= 50 ? 'text-green-400' : citByType.overall_rate >= 10 ? 'text-yellow-400' : 'text-red-400'}`}>{citByType.overall_rate}%</div>
              <div class="text-xs text-gray-500">Claude Citation Rate</div>
            </div>
            <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
              <div class="text-2xl font-bold text-white">{citByType.total_cited}/{citByType.total_queries}</div>
              <div class="text-xs text-gray-500">Queries Cited</div>
            </div>
            <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
              <div class={`text-2xl font-bold ${(citByType.by_type?.brand?.rate || 0) >= 50 ? 'text-green-400' : 'text-red-400'}`}>{citByType.by_type?.brand?.rate || 0}%</div>
              <div class="text-xs text-gray-500">Brand Queries</div>
            </div>
            <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
              <div class="text-2xl font-bold text-white">Claude</div>
              <div class="text-xs text-gray-500">Model Tested</div>
            </div>
          </div>

          <!-- Citation rate by query type -->
          <div class="bg-gray-900 border border-gray-800 rounded-lg p-6 mb-6">
            <h3 class="text-sm font-semibold text-gray-400 mb-4">Citation Rate by Query Type</h3>
            <div class="space-y-3">
              {Object.entries(citByType.by_type || {}).map(([type, data]: [string, any]) => (
                <div class="flex items-center gap-4">
                  <span class="text-xs text-gray-400 w-24 capitalize">{type.replace(/_/g, ' ')}</span>
                  <div class="flex-1 bg-gray-800 rounded-full h-6 overflow-hidden">
                    <div
                      class={`h-full rounded-full flex items-center px-2 text-[10px] font-medium text-white ${data.rate >= 50 ? 'bg-green-600' : data.rate > 0 ? 'bg-yellow-600' : 'bg-red-900'}`}
                      style={`width: ${Math.max(data.rate, 8)}%`}
                    >
                      {data.rate}%
                    </div>
                  </div>
                  <span class="text-xs text-gray-500 w-16 text-right">{data.cited}/{data.queries}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Competitor mentions -->
          {citByType.top_competitors?.length > 0 && (
            <div class="bg-gray-900 border border-red-800/30 rounded-lg p-6 mb-6">
              <h3 class="text-sm font-semibold text-red-400 mb-4">Who Gets Mentioned Instead</h3>
              <div class="space-y-2">
                {citByType.top_competitors.map((c: any) => (
                  <div class="flex items-center gap-4">
                    <span class="text-sm text-white w-40">{c.name}</span>
                    <div class="flex-1 bg-gray-800 rounded-full h-5 overflow-hidden">
                      <div class="h-full bg-red-600/60 rounded-full flex items-center px-2 text-[10px] text-white" style={`width: ${Math.max((c.mentions / citByType.total_queries) * 100, 5)}%`}>
                        {c.mentions}x
                      </div>
                    </div>
                    <span class="text-xs text-gray-500 w-20 text-right">in {c.mentions}/{citByType.total_queries} queries</span>
                  </div>
                ))}
              </div>
            </div>
          )}

        </>
      ) : null}
    </div>

    <!-- Prompt Testing Section -->
    {prompts && (
      <div class="mt-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider">Citation Prompt Testing</h2>
          <div class="flex gap-2">
            <button id="run-everything" class="px-3 py-1.5 rounded text-xs bg-green-600 text-white hover:bg-green-500 transition font-medium">
              Run Everything
            </button>
            <button id="stop-running" class="hidden px-3 py-1.5 rounded text-xs bg-red-600 text-white hover:bg-red-500 transition font-medium">
              Stop
            </button>
            <button id="run-all-high" class="px-3 py-1.5 rounded text-xs bg-red-600 text-white hover:bg-red-500 transition">
              High Intent
            </button>
            <button id="run-all-discovery" class="px-3 py-1.5 rounded text-xs bg-blue-600 text-white hover:bg-blue-500 transition">
              Discovery
            </button>
          </div>
        </div>

        <!-- Add prompt form -->
        <div class="bg-gray-900 border border-dashed border-gray-700 rounded-lg p-4 mb-6">
          <div class="flex items-center gap-3">
            <input id="new-prompt-query" type="text" placeholder="Enter a new query to test..." class="flex-1 bg-gray-800 border border-gray-700 rounded px-3 py-2 text-xs text-white placeholder-gray-500 focus:border-blue-500 focus:outline-none" />
            <select id="new-prompt-type" class="bg-gray-800 border border-gray-700 rounded px-2 py-2 text-xs text-gray-300">
              <option value="recommendation">Recommendation</option>
              <option value="industry">Industry</option>
              <option value="problem">Problem</option>
              <option value="question">Question</option>
              <option value="how_to">How-to</option>
              <option value="comparison">Comparison</option>
              <option value="brand">Brand</option>
              <option value="cost">Cost</option>
              <option value="local">Local</option>
              <option value="review">Review</option>
            </select>
            <select id="new-prompt-group" class="bg-gray-800 border border-gray-700 rounded px-2 py-2 text-xs text-gray-300">
              <option value="high_intent">High Intent</option>
              <option value="discovery">Discovery</option>
            </select>
            <button id="add-prompt-btn" class="px-3 py-2 rounded text-xs bg-green-600 text-white hover:bg-green-500 transition">
              + Add
            </button>
          </div>
        </div>

        {prompts.high_intent?.length > 0 && (
          <div class="mb-6">
            <h3 class="text-xs text-red-400 font-semibold mb-3 uppercase tracking-wider">
              High Intent ({prompts.high_intent.length} prompts)
              <span class="text-gray-500 normal-case font-normal ml-2">Recommendation, industry, problem queries — where citations drive business</span>
            </h3>
            <div class="space-y-2" id="high-intent-prompts">
              {prompts.high_intent.map((p: any) => (
                <div class="prompt-row flex items-center gap-3 p-3 rounded-lg bg-gray-900 border border-gray-800" data-prompt-id={p.id} data-query={p.query} data-group="high_intent">
                  <span class={`text-[10px] px-1.5 py-0.5 rounded ${p.type === 'recommendation' ? 'bg-red-900/50 text-red-300' : p.type === 'problem' ? 'bg-yellow-900/50 text-yellow-300' : p.type === 'industry' ? 'bg-blue-900/50 text-blue-300' : 'bg-gray-800 text-gray-400'}`}>{p.type}</span>
                  <span class="text-xs text-gray-300 flex-1">{p.query}</span>
                  <span class="text-[10px] text-gray-600">{p.source}</span>
                  <span class="result-indicator text-xs" data-result-for={p.id}></span>
                  <button class="run-single-btn px-2 py-1 rounded text-[10px] bg-gray-700 text-gray-300 hover:bg-gray-600 hover:text-white transition" data-prompt-id={p.id} data-query={p.query}>
                    Run
                  </button>
                  <button class="remove-prompt-btn px-1.5 py-0.5 rounded text-[10px] bg-gray-800 text-gray-500 hover:bg-red-900 hover:text-red-300 transition" data-prompt-id={p.id} title="Remove prompt">x</button>
                </div>
              ))}
            </div>
          </div>
        )}

        {prompts.discovery?.length > 0 && (
          <div>
            <h3 class="text-xs text-blue-400 font-semibold mb-3 uppercase tracking-wider">
              Discovery ({prompts.discovery.length} prompts)
              <span class="text-gray-500 normal-case font-normal ml-2">Brand, question, how-to, comparison — builds authority</span>
            </h3>
            <div class="space-y-2" id="discovery-prompts">
              {prompts.discovery.map((p: any) => (
                <div class="prompt-row flex items-center gap-3 p-3 rounded-lg bg-gray-900 border border-gray-800" data-prompt-id={p.id} data-query={p.query} data-group="discovery">
                  <span class={`text-[10px] px-1.5 py-0.5 rounded ${p.type === 'brand' ? 'bg-green-900/50 text-green-300' : p.type === 'question' ? 'bg-purple-900/50 text-purple-300' : p.type === 'how_to' ? 'bg-cyan-900/50 text-cyan-300' : p.type === 'comparison' ? 'bg-orange-900/50 text-orange-300' : 'bg-gray-800 text-gray-400'}`}>{p.type}</span>
                  <span class="text-xs text-gray-300 flex-1">{p.query}</span>
                  <span class="text-[10px] text-gray-600">{p.source}</span>
                  <span class="result-indicator text-xs" data-result-for={p.id}></span>
                  <button class="run-single-btn px-2 py-1 rounded text-[10px] bg-gray-700 text-gray-300 hover:bg-gray-600 hover:text-white transition" data-prompt-id={p.id} data-query={p.query}>
                    Run
                  </button>
                  <button class="remove-prompt-btn px-1.5 py-0.5 rounded text-[10px] bg-gray-800 text-gray-500 hover:bg-red-900 hover:text-red-300 transition" data-prompt-id={p.id} title="Remove prompt">x</button>
                </div>
              ))}
            </div>
          </div>
        )}

        {prompts.faq?.length > 0 && (
          <div class="mt-6">
            <h3 class="text-xs text-green-400 font-semibold mb-3 uppercase tracking-wider">Genuine Questions ({prompts.faq.length} FAQs) <span class="text-gray-500 normal-case font-normal ml-2">Real questions — not keyword variations</span></h3>
            <div class="space-y-2" id="faq-prompts">
              {prompts.faq.map((p: any) => (
                <div class="prompt-row flex items-center gap-3 p-3 rounded-lg bg-gray-900 border border-gray-800" data-prompt-id={p.id} data-query={p.query} data-group="faq">
                  <span class={`text-[10px] px-1.5 py-0.5 rounded ${p.type === 'question' ? 'bg-purple-900/50 text-purple-300' : p.type === 'how_to' ? 'bg-cyan-900/50 text-cyan-300' : 'bg-gray-800 text-gray-400'}`}>{p.type}</span>
                  <span class="text-xs text-gray-300 flex-1">{p.query}</span>
                  <span class="text-[10px] text-gray-600">{p.source}</span>
                  {p.page_url && <span class="text-[10px] text-blue-400/60">→ {p.page_url}</span>}
                  <span class="result-indicator text-xs" data-result-for={p.id}></span>
                  <button class="run-single-btn px-2 py-1 rounded text-[10px] bg-gray-700 text-gray-300 hover:bg-gray-600 hover:text-white transition" data-prompt-id={p.id} data-query={p.query}>Run</button>
                  <button class="remove-prompt-btn px-1.5 py-0.5 rounded text-[10px] bg-gray-800 text-gray-500 hover:bg-red-900 hover:text-red-300 transition" data-prompt-id={p.id}>x</button>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    )}

    <script define:vars={{ clientBrand: citByType?.brand || client?.name, clientDomain: client?.domain, workerUrl: 'https://rank4ai-tracker.dawn-field-3d16.workers.dev' }}>
      // Load previous results on page load
      async function loadPreviousResults() {
        const rows = document.querySelectorAll('.prompt-row[data-prompt-id]');
        for (const row of rows) {
          const promptId = row.getAttribute('data-prompt-id');
          if (!promptId) continue;
          try {
            const resp = await fetch(`${workerUrl}/api/citation-history?id=${encodeURIComponent(promptId)}&days=7`);
            if (!resp.ok) continue;
            const data = await resp.json();
            if (data.history && data.history.length > 0) {
              const latest = data.history[data.history.length - 1];
              const indicator = document.querySelector(`[data-result-for="${promptId}"]`);
              if (indicator && latest.results) {
                let html = '';
                const c = latest.results.claude;
                const g = latest.results.chatgpt;
                const gm = latest.results.gemini;
                if (c) html += `<span class="${c.cited ? 'text-green-400' : 'text-red-400'}">C:${c.cited ? 'Y' : 'N'}</span>`;
                if (g) html += ` <span class="${g.cited ? 'text-green-400' : 'text-red-400'}">G:${g.cited ? 'Y' : 'N'}</span>`;
                if (gm) html += ` <span class="${gm.cited ? 'text-green-400' : 'text-red-400'}">Gm:${gm.cited ? 'Y' : 'N'}</span>`;
                if (html) {
                  const date = new Date(latest.tested_at).toLocaleDateString('en-GB', {day:'numeric',month:'short'});
                  indicator.innerHTML = html + ` <span class="text-gray-600 text-[9px]">(${date})</span>`;
                }
              }
            }
          } catch {}
        }
      }

      // Load results for first 20 prompts (don't hammer the API)
      (async () => {
        const rows = Array.from(document.querySelectorAll('.prompt-row[data-prompt-id]')).slice(0, 20);
        for (const row of rows) {
          const promptId = row.getAttribute('data-prompt-id');
          try {
            const resp = await fetch(`${workerUrl}/api/citation-history?id=${encodeURIComponent(promptId)}&days=7`);
            if (!resp.ok) continue;
            const data = await resp.json();
            if (data.history?.length > 0) {
              const latest = data.history[data.history.length - 1];
              const indicator = document.querySelector(`[data-result-for="${promptId}"]`);
              if (indicator && latest.results) {
                let html = '';
                const c = latest.results.claude;
                const g = latest.results.chatgpt;
                const gm = latest.results.gemini;
                if (c) html += `<span class="${c.cited ? 'text-green-400' : 'text-red-400'}">C:${c.cited ? 'Y' : 'N'}</span>`;
                if (g) html += ` <span class="${g.cited ? 'text-green-400' : 'text-red-400'}">G:${g.cited ? 'Y' : 'N'}</span>`;
                if (gm) html += ` <span class="${gm.cited ? 'text-green-400' : 'text-red-400'}">Gm:${gm.cited ? 'Y' : 'N'}</span>`;
                if (html) {
                  const date = new Date(latest.tested_at).toLocaleDateString('en-GB', {day:'numeric',month:'short'});
                  indicator.innerHTML = html + ` <span class="text-gray-600 text-[9px]">(${date})</span>`;
                }
              }
            }
          } catch {}
        }
      })();

      async function runCitation(promptId, query, btn) {
        btn.textContent = 'Testing...';
        btn.disabled = true;
        btn.style.background = '#374151';

        try {
          const resp = await fetch(`${workerUrl}/test-citation`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              query, brand: clientBrand, domain: clientDomain, id: promptId,
            }),
          });

          if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
          const data = await resp.json();

          // Update result indicator
          const indicator = document.querySelector(`[data-result-for="${promptId}"]`);
          if (indicator) {
            const claudeCited = data.results?.claude?.cited;
            const gptCited = data.results?.chatgpt?.cited;
            let html = '';
            const gemCited = data.results?.gemini?.cited;
            if (claudeCited !== undefined) html += `<span class="${claudeCited ? 'text-green-400' : 'text-red-400'}">C:${claudeCited ? 'Y' : 'N'}</span>`;
            if (gptCited !== undefined) html += ` <span class="${gptCited ? 'text-green-400' : 'text-red-400'}">G:${gptCited ? 'Y' : 'N'}</span>`;
            if (gemCited !== undefined) html += ` <span class="${gemCited ? 'text-green-400' : 'text-red-400'}">Gm:${gemCited ? 'Y' : 'N'}</span>`;
            indicator.innerHTML = html;
          }

          // Update row styling
          const row = btn.closest('.prompt-row');
          if (row) {
            const anyCited = data.results?.claude?.cited || data.results?.chatgpt?.cited || data.results?.gemini?.cited;
            row.style.borderColor = anyCited ? '#166534' : '#7f1d1d';
            row.style.background = anyCited ? 'rgba(22, 101, 52, 0.1)' : '';
          }

          btn.textContent = 'Done';
          btn.style.background = '#22c55e';
          setTimeout(() => { btn.textContent = 'Run'; btn.style.background = ''; btn.disabled = false; }, 3000);

        } catch (e) {
          btn.textContent = 'Error';
          btn.style.background = '#ef4444';
          setTimeout(() => { btn.textContent = 'Run'; btn.style.background = ''; btn.disabled = false; }, 3000);
        }
      }

      // Single run buttons
      document.querySelectorAll('.run-single-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const promptId = btn.getAttribute('data-prompt-id');
          const query = btn.getAttribute('data-query');
          runCitation(promptId, query, btn);
        });
      });

      // Run all high intent
      document.getElementById('run-all-high')?.addEventListener('click', async function() {
        this.textContent = 'Running...';
        this.disabled = true;
        const btns = document.querySelectorAll('#high-intent-prompts .run-single-btn');
        for (const btn of btns) {
          const promptId = btn.getAttribute('data-prompt-id');
          const query = btn.getAttribute('data-query');
          await runCitation(promptId, query, btn);
          await new Promise(r => setTimeout(r, 500)); // Small delay between calls
        }
        this.textContent = 'Run All High Intent';
        this.disabled = false;
      });

      // Run all discovery
      document.getElementById('run-all-discovery')?.addEventListener('click', async function() {
        this.textContent = 'Running...';
        this.disabled = true;
        const btns = document.querySelectorAll('#discovery-prompts .run-single-btn');
        for (const btn of btns) {
          const promptId = btn.getAttribute('data-prompt-id');
          const query = btn.getAttribute('data-query');
          await runCitation(promptId, query, btn);
          await new Promise(r => setTimeout(r, 500));
        }
        this.textContent = 'Run All Discovery';
        this.disabled = false;
      });

      // Run Everything with Stop support
      let stopRequested = false;
      const stopBtn = document.getElementById('stop-running');

      stopBtn?.addEventListener('click', () => {
        stopRequested = true;
        stopBtn.textContent = 'Stopping...';
      });

      document.getElementById('run-everything')?.addEventListener('click', async function() {
        stopRequested = false;
        this.textContent = 'Running...';
        this.disabled = true;
        stopBtn.classList.remove('hidden');

        const allBtns = document.querySelectorAll('.run-single-btn');
        const total = allBtns.length;
        let done = 0;
        let cited = 0;

        for (const btn of allBtns) {
          if (stopRequested) break;
          const row = btn.closest('.prompt-row');
          if (row && (row.dataset.parked === 'true' || row.dataset.done === 'true' || row.dataset.removed === 'true')) continue;
          const promptId = btn.getAttribute('data-prompt-id');
          const query = btn.getAttribute('data-query');
          await runCitation(promptId, query, btn);
          done++;
          // Count cited
          const indicator = document.querySelector(`[data-result-for="${promptId}"]`);
          if (indicator && indicator.innerHTML.includes('text-green-400')) cited++;
          this.textContent = `Running... ${done}/${total} (${cited} cited)`;
          await new Promise(r => setTimeout(r, 500));
        }

        stopBtn.classList.add('hidden');
        const status = stopRequested ? `Stopped (${done} tested, ${cited} cited)` : `Done (${done} tested, ${cited} cited)`;
        this.textContent = status;
        setTimeout(() => { this.textContent = 'Run Everything'; this.disabled = false; }, 5000);
      });

      // Remove prompt
      document.querySelectorAll('.remove-prompt-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const row = btn.closest('.prompt-row');
          if (row && confirm('Remove this prompt?')) {
            row.style.opacity = '0.3';
            row.style.pointerEvents = 'none';
            row.dataset.removed = 'true';
          }
        });
      });

      // Add new prompt
      document.getElementById('add-prompt-btn')?.addEventListener('click', () => {
        const queryInput = document.getElementById('new-prompt-query');
        const typeSelect = document.getElementById('new-prompt-type');
        const groupSelect = document.getElementById('new-prompt-group');

        const query = queryInput.value.trim();
        if (!query) { queryInput.focus(); return; }

        const type = typeSelect.value;
        const group = groupSelect.value;
        const id = 'custom-' + Date.now();

        const typeColors = {
          recommendation: 'bg-red-900/50 text-red-300',
          industry: 'bg-blue-900/50 text-blue-300',
          problem: 'bg-yellow-900/50 text-yellow-300',
          brand: 'bg-green-900/50 text-green-300',
          question: 'bg-purple-900/50 text-purple-300',
          how_to: 'bg-cyan-900/50 text-cyan-300',
          comparison: 'bg-orange-900/50 text-orange-300',
          cost: 'bg-gray-800 text-gray-400',
          local: 'bg-gray-800 text-gray-400',
          review: 'bg-gray-800 text-gray-400',
        };

        const row = document.createElement('div');
        row.className = 'prompt-row flex items-center gap-3 p-3 rounded-lg bg-gray-900 border border-green-800/50';
        row.dataset.promptId = id;
        row.dataset.query = query;
        row.dataset.group = group;
        row.innerHTML = `
          <span class="text-[10px] px-1.5 py-0.5 rounded ${typeColors[type] || 'bg-gray-800 text-gray-400'}">${type}</span>
          <span class="text-xs text-gray-300 flex-1">${query}</span>
          <span class="text-[10px] text-green-400">new</span>
          <span class="result-indicator text-xs" data-result-for="${id}"></span>
          <button class="run-single-btn px-2 py-1 rounded text-[10px] bg-gray-700 text-gray-300 hover:bg-gray-600 hover:text-white transition" data-prompt-id="${id}" data-query="${query}">Run</button>
          <button class="remove-prompt-btn px-1.5 py-0.5 rounded text-[10px] bg-gray-800 text-gray-500 hover:bg-red-900 hover:text-red-300 transition" data-prompt-id="${id}" title="Remove">x</button>
        `;

        // Add Run handler
        row.querySelector('.run-single-btn').addEventListener('click', (e) => {
          e.stopPropagation();
          runCitation(id, query, row.querySelector('.run-single-btn'));
        });

        // Add Remove handler
        row.querySelector('.remove-prompt-btn').addEventListener('click', (e) => {
          e.stopPropagation();
          if (confirm('Remove this prompt?')) {
            row.style.opacity = '0.3';
            row.style.pointerEvents = 'none';
          }
        });

        const container = document.getElementById(group === 'high_intent' ? 'high-intent-prompts' : 'discovery-prompts');
        if (container) container.appendChild(row);

        queryInput.value = '';
        queryInput.focus();
      });
    </script>
  )}

  <!-- UPTIME -->
  {sectionId === 'uptime' && uptime && (
    <div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class={`text-2xl font-bold ${uptime.is_up ? 'text-green-400' : 'text-red-400'}`}>{uptime.is_up ? 'UP' : 'DOWN'}</div>
          <div class="text-xs text-gray-500">Current Status</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{uptime.uptime_pct}%</div>
          <div class="text-xs text-gray-500">Uptime</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{uptime.response_time_ms}ms</div>
          <div class="text-xs text-gray-500">Response Time</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{uptime.checks_total}</div>
          <div class="text-xs text-gray-500">Total Checks</div>
        </div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
        <h3 class="text-sm font-semibold text-gray-400 mb-4">Response Time History</h3>
        <canvas id="uptimeChart" height="200"></canvas>
      </div>
    </div>
  )}

  <!-- POSITIVE SIGNALS -->
  {sectionId === 'positive-signals' && crawlData?.positive_signals && (
    <div>
      <div class="bg-gray-900 border border-green-800/50 rounded-lg p-6">
        <h3 class="text-sm font-semibold text-green-400 mb-4">What's Working ({crawlData.positive_signals.length} signals)</h3>
        <div class="space-y-2 max-h-[600px] overflow-y-auto">
          {crawlData.positive_signals.map((s: any) => (
            <div class="flex items-center gap-3 text-xs border-b border-gray-800/50 pb-2">
              <span class={`px-2 py-0.5 rounded text-[10px] ${s.type === 'schema' ? 'bg-blue-900/50 text-blue-300' : s.type === 'good_content' ? 'bg-green-900/50 text-green-300' : 'bg-purple-900/50 text-purple-300'}`}>
                {s.type.replace(/_/g, ' ')}
              </span>
              <span class="text-gray-300 truncate">{new URL(s.url).pathname}</span>
              <span class="text-gray-500 ml-auto">{s.detail}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- AI READINESS -->
  {sectionId === 'ai-readiness' && audit && (
    <div>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class={`text-2xl font-bold ${audit.overall_score >= 70 ? 'text-green-400' : audit.overall_score >= 40 ? 'text-yellow-400' : 'text-red-400'}`}>{audit.overall_score}/100</div>
          <div class="text-xs text-gray-500">Overall Score</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{audit.scores.schema}/100</div>
          <div class="text-xs text-gray-500">Schema</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{audit.scores.content_structure}/100</div>
          <div class="text-xs text-gray-500">Content Structure</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{audit.scores.eeat}/100</div>
          <div class="text-xs text-gray-500">E-E-A-T</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{audit.scores.citation_potential}/100</div>
          <div class="text-xs text-gray-500">Citation Potential</div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
          <h3 class="text-sm font-semibold text-gray-400 mb-4">llms.txt</h3>
          <div class={`text-lg font-bold ${audit.llms_txt?.exists ? 'text-green-400' : 'text-red-400'}`}>
            {audit.llms_txt?.exists ? 'Found' : 'Not Found'}
          </div>
          {audit.llms_txt?.exists && (
            <p class="text-xs text-gray-500 mt-2">{audit.llms_txt.content_length} characters</p>
          )}
          {!audit.llms_txt?.exists && (
            <p class="text-xs text-gray-500 mt-2">Add /llms.txt to tell AI crawlers about your site</p>
          )}
        </div>

        <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
          <h3 class="text-sm font-semibold text-gray-400 mb-4">AI Crawler Access (robots.txt)</h3>
          {audit.robots_txt?.exists ? (
            <div class="space-y-1.5">
              {Object.entries(audit.robots_txt.ai_crawlers || {}).map(([crawler, status]: [string, any]) => (
                <div class="flex justify-between text-xs">
                  <span class="text-gray-300">{crawler}</span>
                  <span class={status === 'blocked' ? 'text-red-400' : status === 'allowed' ? 'text-green-400' : 'text-gray-600'}>{status}</span>
                </div>
              ))}
            </div>
          ) : (
            <p class="text-xs text-gray-500">No robots.txt found</p>
          )}
        </div>
      </div>

      <!-- Knowledge Graph Status -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div class={`bg-gray-900 border rounded-lg p-6 ${kg?.is_known_entity ? 'border-green-800/50' : 'border-red-800/50'}`}>
          <h3 class="text-sm font-semibold text-gray-400 mb-3">Google Knowledge Graph</h3>
          <div class={`text-lg font-bold mb-2 ${kg?.is_known_entity ? 'text-green-400' : 'text-red-400'}`}>
            {kg?.is_known_entity ? 'Known Entity' : 'Not Found'}
          </div>
          <p class="text-xs text-gray-500">
            {kg?.is_known_entity
              ? `Google recognises this brand as an entity. This improves AI visibility.`
              : `Google does not have a Knowledge Panel for this brand. Getting into the Knowledge Graph is critical for AI citation.`}
          </p>
          {kg?.best_match && (
            <div class="mt-3 text-xs">
              <span class="text-gray-400">Best match: </span>
              <span class="text-white">{kg.best_match.name} — {kg.best_match.description}</span>
            </div>
          )}
        </div>

        {nlp && (
          <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
            <h3 class="text-sm font-semibold text-gray-400 mb-3">What This Site Is About</h3>

            {nlp.top_topics?.length > 0 && (
              <div class="mb-4">
                <p class="text-xs text-gray-500 mb-2">Top Topics (from titles & H1s):</p>
                <div class="flex flex-wrap gap-2">
                  {nlp.top_topics.slice(0, 15).map((t: any) => (
                    <span class="text-xs px-2 py-1 rounded bg-blue-900/40 text-blue-300">{t.word} ({t.count})</span>
                  ))}
                </div>
              </div>
            )}

            {nlp.top_phrases?.length > 0 && (
              <div class="mb-4">
                <p class="text-xs text-gray-500 mb-2">Key Phrases:</p>
                <div class="flex flex-wrap gap-2">
                  {nlp.top_phrases.slice(0, 10).map((t: any) => (
                    <span class="text-xs px-2 py-1 rounded bg-green-900/40 text-green-300">{t.phrase} ({t.count})</span>
                  ))}
                </div>
              </div>
            )}

            {nlp.schema_types?.length > 0 && (
              <div class="mb-4">
                <p class="text-xs text-gray-500 mb-2">Schema Types Used:</p>
                <div class="flex flex-wrap gap-2">
