                  <td class={`py-2 px-3 text-right font-medium ${(p.scores?.performance || 0) >= 80 ? 'text-green-400' : (p.scores?.performance || 0) >= 50 ? 'text-yellow-400' : 'text-red-400'}`}>{p.scores?.performance || '--'}</td>
                  <td class="py-2 px-3 text-right text-gray-400">{p.scores?.accessibility || '--'}</td>
