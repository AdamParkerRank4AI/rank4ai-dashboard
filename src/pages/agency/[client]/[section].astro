                <div class="flex gap-2">
                  <a href={`https://github.com/${siteRepo}/actions`} target="_blank" rel="noopener" class="px-3 py-2 bg-blue-600 hover:bg-blue-500 text-white text-xs font-medium rounded-lg transition">View Actions</a>
                  <a href={`https://github.com/${siteRepo}/commits/main`} target="_blank" rel="noopener" class="px-3 py-2 bg-gray-800 hover:bg-gray-700 text-gray-200 text-xs font-medium rounded-lg transition">Recent Commits</a>
                  <a href={`https://dash.cloudflare.com`} target="_blank" rel="noopener" class="px-3 py-2 bg-gray-800 hover:bg-gray-700 text-gray-200 text-xs font-medium rounded-lg transition">Cloudflare</a>
                </div>
              </div>
            </div>
          )}

          {dailyAuditHistory.length > 0 && (
            <div class="bg-gray-900 border border-gray-800 rounded-lg p-6 mb-6">
              <h3 class="text-sm font-semibold text-gray-400 mb-4">Issue trend (last {dailyAuditHistory.length} days)</h3>
              <div class="space-y-1">
                {dailyAuditHistory.slice().reverse().map((h: any) => (
                  <div class="flex items-center justify-between text-xs border-b border-gray-800 py-1">
                    <span class="text-gray-400 font-mono">{h.date}</span>
                    <span class="text-gray-500">{h.pages_checked} pages</span>
                    <span class={`font-medium ${h.issues_total > 0 ? 'text-red-400' : 'text-green-400'}`}>{h.issues_total} issues</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <div class="bg-gray-900 border border-gray-800 rounded-lg p-6 mb-6">
            <h3 class="text-sm font-semibold text-gray-400 mb-4">Pages flagged today</h3>
            {dailyAuditPerSite.flagged_pages?.length === 0 && (
              <p class="text-sm text-gray-500">No pages flagged. All clean.</p>
            )}
            {dailyAuditPerSite.flagged_pages?.length > 0 && (
              <div class="space-y-3">
                {dailyAuditPerSite.flagged_pages.map((p: any, idx: number) => {
                  const issuesList = (p.issues || []).map((i: string) => `  - ${i}`).join('\n');
                  const repoLocal = clientId === 'rank4ai' ? '~/rank4ai-site' : clientId === 'market-invoice' ? '~/compare-invoice-finance' : '~/compareaiseo';
                  const promptText = [
                    `Site: ${dailyAuditPerSite.site_name} (${repoLocal})`,
                    `URL: ${p.url}`,
                    `Found: daily audit ${dailyAuditPerSite.audit_date}`,
                    `Issues:`,
                    issuesList,
                    ``,
                    `Please:`,
                    `1. Open the page source, identify root cause`,
                    `2. Fix in the repo`,
                    `3. Build, then push to main (Cloudflare auto-deploys)`,
                    `4. Append a one-line entry to iCloud/claude/astro/plan/CHANGELOG_${clientId === 'rank4ai' ? '' : (clientId === 'market-invoice' ? 'MARKET_INVOICE' : 'COMPAREAISEO')}.md`,
                    `5. Mark resolved in iCloud/claude/astro/FLEET/INBOX.md`,
                  ].join('\n');
                  return (
                    <div class="border-l-2 border-red-700 pl-3">
                      <div class="flex items-start justify-between gap-3">
                        <a href={p.url} target="_blank" rel="noopener" class="text-xs text-blue-400 hover:text-blue-300 break-all">{p.url}</a>
                        <button
                          class="copy-prompt-btn shrink-0 px-2 py-1 bg-purple-900/40 hover:bg-purple-800/60 border border-purple-700 text-purple-200 text-xs rounded transition"
                          data-prompt={promptText}
                          data-idx={idx}
                          title="Copy a Claude-ready fix prompt for this page"
                        >Copy fix prompt</button>
                      </div>
                      <ul class="mt-1 space-y-0.5">
                        {p.issues?.map((iss: string) => (
                          <li class="text-xs text-gray-400">• {iss}</li>
                        ))}
                      </ul>
                    </div>
                  );
                })}
              </div>
            )}
          </div>

          <script is:inline>
            (function() {
              document.querySelectorAll('.copy-prompt-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                  const text = btn.getAttribute('data-prompt');
                  navigator.clipboard.writeText(text).then(function() {
                    const original = btn.textContent;
                    btn.textContent = '✓ Copied';
                    btn.classList.add('bg-green-900/60', 'border-green-700', 'text-green-200');
                    setTimeout(function() {
                      btn.textContent = original;
                      btn.classList.remove('bg-green-900/60', 'border-green-700', 'text-green-200');
                    }, 1800);
                  });
                });
              });
            })();
          </script>

          <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
            <h3 class="text-sm font-semibold text-gray-400 mb-4">All pages checked ({dailyAuditPerSite.all_pages?.length})</h3>
            <div class="space-y-1 max-h-96 overflow-y-auto">
              {dailyAuditPerSite.all_pages?.map((p: any) => (
                <div class="flex items-center justify-between text-xs border-b border-gray-800 py-1">
                  <a href={p.url} target="_blank" rel="noopener" class="text-gray-300 hover:text-white truncate max-w-[300px]">{p.url.replace(dailyAuditPerSite.url, '') || '/'}</a>
                  <span class="text-gray-500">{p.word_count} words</span>
                  <span class={`font-medium ${p.status === 200 ? 'text-green-400' : 'text-red-400'}`}>{p.status}</span>
                  <span class={`font-medium ${(p.issues?.length || 0) > 0 ? 'text-red-400' : 'text-gray-600'}`}>{p.issues?.length || 0} issues</span>
                </div>
              ))}
            </div>
          </div>
        </>
      )}
    </div>
  )}

  {!['traffic', 'content-gaps', 'seo-health', 'ai-citations', 'uptime', 'positive-signals', 'ai-readiness', 'search-performance', 'overview', 'site-speed', 'crawl-activity', 'competitors', 'recommendations', 'new-pages', 'site-tree', 'internal-links', 'site-manager', 'content-plan', 'daily-audit'].includes(sectionId) && (
    <div class="bg-gray-900 border border-gray-800 rounded-lg p-8 text-center">
      <p class="text-gray-500">Detailed view for {section.label} coming soon.</p>
      <a href={`/agency/${clientId}`} class="text-sm text-blue-400 hover:text-blue-300 mt-2 inline-block">Back to dashboard</a>
    </div>
  )}
</DashboardLayout>

<!-- Chart scripts -->
<script define:vars={{ dailyTraffic, uptimeChecks, crawlDaily, historyData: JSON.stringify(history) }}>
  const daily = JSON.parse(dailyTraffic);
  const checks = JSON.parse(uptimeChecks);

  async function renderCharts() {
    const { Chart, registerables } = await import('https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.js');

    // Traffic chart
    const trafficEl = document.getElementById('trafficChart');
    if (trafficEl && daily.length > 0) {
      const labels = daily.map(d => {
        const date = `${d.date.slice(0,4)}-${d.date.slice(4,6)}-${d.date.slice(6,8)}`;
        return new Date(date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
      });
      new Chart(trafficEl, {
        type: 'line',
        data: {
          labels,
          datasets: [{
            label: 'Users',
            data: daily.map(d => d.users),
            borderColor: '#3b82f6',
            backgroundColor: 'rgba(59, 130, 246, 0.1)',
            fill: true,
            tension: 0.3,
            pointRadius: 2,
          }, {
            label: 'Sessions',
            data: daily.map(d => d.sessions),
            borderColor: '#8b5cf6',
            borderDash: [5, 5],
            tension: 0.3,
            pointRadius: 0,
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { labels: { color: '#9ca3af', font: { size: 11 } } } },
          scales: {
            x: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: '#1f2937' } },
            y: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: '#1f2937' } },
          }
        }
      });
    }

    // Uptime chart
    const uptimeEl = document.getElementById('uptimeChart');
    if (uptimeEl && checks.length > 0) {
      const labels = checks.map(c => new Date(c.time).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }));
      new Chart(uptimeEl, {
        type: 'line',
        data: {
          labels,
          datasets: [{
            label: 'Response Time (ms)',
            data: checks.map(c => c.ms),
            borderColor: c => c.raw > 2000 ? '#ef4444' : '#10b981',
            backgroundColor: 'rgba(16, 185, 129, 0.1)',
            fill: true,
            tension: 0.3,
            pointRadius: 3,
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { labels: { color: '#9ca3af', font: { size: 11 } } } },
          scales: {
            x: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: '#1f2937' } },
            y: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: '#1f2937' } },
          }
        }
      });
    }

    // Crawl activity chart
    const crawlData = JSON.parse(crawlDaily);
    const crawlEl = document.getElementById('crawlChart');
    if (crawlEl && crawlData.length > 0) {
      const labels = crawlData.map(d => {
        const date = new Date(d.date);
        return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
      });
      new Chart(crawlEl, {
        type: 'bar',
        data: {
          labels,
          datasets: [{
            label: 'Pages Crawled',
            data: crawlData.map(d => d.crawled_pages),
            backgroundColor: 'rgba(59, 130, 246, 0.6)',
            borderColor: '#3b82f6',
            borderWidth: 1,
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { labels: { color: '#9ca3af', font: { size: 11 } } } },
          scales: {
            x: { ticks: { color: '#6b7280', font: { size: 9 }, maxRotation: 45 }, grid: { color: '#1f2937' } },
            y: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: '#1f2937' } },
          }
        }
      });
    }

    // Index growth chart
    const indexEl = document.getElementById('indexChart');
    if (indexEl && crawlData.length > 0) {
      const labels = crawlData.map(d => {
        const date = new Date(d.date);
        return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
      });
      new Chart(indexEl, {
        type: 'line',
        data: {
          labels,
          datasets: [{
            label: 'Pages Indexed',
            data: crawlData.map(d => d.in_index),
            borderColor: '#10b981',
            backgroundColor: 'rgba(16, 185, 129, 0.1)',
            fill: true,
            tension: 0.3,
            pointRadius: 2,
          }, {
            label: 'Inbound Links',
            data: crawlData.map(d => d.in_links),
            borderColor: '#8b5cf6',
            borderDash: [5, 5],
            tension: 0.3,
            pointRadius: 0,
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { labels: { color: '#9ca3af', font: { size: 11 } } } },
          scales: {
            x: { ticks: { color: '#6b7280', font: { size: 9 }, maxRotation: 45 }, grid: { color: '#1f2937' } },
            y: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: '#1f2937' } },
          }
        }
      });
    }
  }

    // Trend charts from daily history
    const hist = JSON.parse(historyData);
    if (hist.length > 1) {
      const trendLabels = hist.map(h => {
        const d = new Date(h.date);
        return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
      });

      const trendCharts = [
        { id: 'trend-ai-score', data: hist.map(h => h.ai_score), color: '#8b5cf6', label: 'AI Score' },
        { id: 'trend-citation', data: hist.map(h => h.citation_rate), color: '#ef4444', label: 'Citation %' },
        { id: 'trend-users', data: hist.map(h => h.users), color: '#3b82f6', label: 'Users' },
        { id: 'trend-indexed', data: hist.map(h => h.bing_indexed), color: '#10b981', label: 'Indexed' },
      ];

      for (const tc of trendCharts) {
        const el = document.getElementById(tc.id);
        if (el) {
          new Chart(el, {
            type: 'line',
            data: {
              labels: trendLabels,
              datasets: [{
                label: tc.label,
                data: tc.data,
                borderColor: tc.color,
                backgroundColor: tc.color + '20',
                fill: true,
                tension: 0.3,
                pointRadius: 3,
              }]
            },
            options: {
              responsive: true,
              plugins: { legend: { display: false } },
              scales: {
                x: { ticks: { color: '#6b7280', font: { size: 9 } }, grid: { color: '#1f2937' } },
                y: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: '#1f2937' } },
              }
            }
          });
        }
      }
    }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderCharts);
  } else {
    renderCharts();
  }
</script>
