        function copyText(text, btn) {
          navigator.clipboard.writeText(text).then(() => {
            const orig = btn.textContent;
            btn.textContent = 'Copied!';
            btn.style.background = '#22c55e';
            setTimeout(() => { btn.textContent = orig; btn.style.background = ''; }, 2000);
          });
        }

        // Filter buttons
        document.querySelectorAll('.rec-filter').forEach(btn => {
          btn.addEventListener('click', () => {
            const filter = btn.getAttribute('data-filter');
            document.querySelectorAll('.rec-item').forEach(item => {
              if (filter === 'all' || item.getAttribute('data-rec-priority') === filter) {
                item.style.display = '';
              } else {
                item.style.display = 'none';
              }
            });
            // Update active state
            document.querySelectorAll('.rec-filter').forEach(b => b.style.outline = '');
            btn.style.outline = '2px solid white';

            // Select all visible checkboxes
            document.querySelectorAll('.rec-checkbox').forEach(cb => {
              const item = cb.closest('.rec-item');
              cb.checked = item.style.display !== 'none';
            });
          });
        });

        // Copy single
        document.querySelectorAll('.copy-single-rec').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const idx = parseInt(btn.getAttribute('data-index'));
            copyText(buildPrompt([allRecs[idx]]), btn);
          });
        });

        // Copy selected
        document.getElementById('copy-selected-recs')?.addEventListener('click', function() {
          const checked = document.querySelectorAll('.rec-checkbox:checked');
          if (checked.length === 0) {
            // If none selected, copy all visible
            const visible = [];
            document.querySelectorAll('.rec-item').forEach((item, i) => {
              if (item.style.display !== 'none') {
                visible.push(allRecs[parseInt(item.getAttribute('data-rec-index'))]);
              }
            });
            if (visible.length > 0) copyText(buildPrompt(visible), this);
          } else {
            const selected = [];
            checked.forEach(cb => {
              const idx = parseInt(cb.getAttribute('data-index'));
              selected.push(allRecs[idx]);
            });
            copyText(buildPrompt(selected), this);
          }
        });

        // Persistent state via localStorage
        var storageKey = 'rec-state-' + window.location.pathname;
        var recState = {};
        try { recState = JSON.parse(localStorage.getItem(storageKey) || '{}'); } catch(e) {}

        function saveRecState() {
          localStorage.setItem(storageKey, JSON.stringify(recState));
        }

        function applyState(item, index) {
          var state = recState[index];
          if (!state) return;
          if (state === 'done') {
            item.style.opacity = '0.4';
            item.style.borderColor = '#166534';
            item.querySelector('.done-rec-btn').textContent = '✓';
            item.querySelector('.done-rec-btn').style.background = '#166534';
            item.dataset.done = 'true';
          } else if (state === 'parked') {
            item.style.opacity = '0.3';
            item.style.borderColor = '#854d0e';
            item.querySelector('.park-rec-btn').textContent = 'Unpark';
            item.querySelector('.park-rec-btn').style.background = '#854d0e';
            item.dataset.parked = 'true';
          } else if (state === 'na') {
            item.style.opacity = '0.2';
            item.style.borderColor = '#374151';
            item.querySelector('.na-rec-btn').textContent = 'N/A';
            item.querySelector('.na-rec-btn').style.background = '#374151';
            item.dataset.na = 'true';
          }
        }

        // Apply saved state on load
        document.querySelectorAll('.rec-item').forEach(function(item) {
          var index = item.getAttribute('data-rec-index');
          applyState(item, index);
        });

        // Done button
        document.querySelectorAll('.done-rec-btn').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var item = btn.closest('.rec-item');
            var index = item.getAttribute('data-rec-index');
            if (recState[index] === 'done') {
              delete recState[index];
              item.style.opacity = '1';
              item.style.borderColor = '';
              btn.textContent = 'Done';
              btn.style.background = '';
              item.dataset.done = 'false';
            } else {
              recState[index] = 'done';
              item.style.opacity = '0.4';
              item.style.borderColor = '#166534';
              btn.textContent = '✓';
              btn.style.background = '#166534';
              item.dataset.done = 'true';
            }
            saveRecState();
          });
        });

        // Park button
        document.querySelectorAll('.park-rec-btn').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var item = btn.closest('.rec-item');
            var index = item.getAttribute('data-rec-index');
            if (recState[index] === 'parked') {
              delete recState[index];
              item.style.opacity = '1';
              item.style.borderColor = '';
              btn.textContent = 'Park';
              btn.style.background = '';
              item.dataset.parked = 'false';
            } else {
              recState[index] = 'parked';
              item.style.opacity = '0.3';
              item.style.borderColor = '#854d0e';
              btn.textContent = 'Unpark';
              btn.style.background = '#854d0e';
              item.dataset.parked = 'true';
            }
            saveRecState();
          });
        });

        // N/A (Not Applicable) button
        document.querySelectorAll('.na-rec-btn').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var item = btn.closest('.rec-item');
            var index = item.getAttribute('data-rec-index');
            if (recState[index] === 'na') {
              delete recState[index];
              item.style.opacity = '1';
              item.style.borderColor = '';
              btn.textContent = 'N/A';
              btn.style.background = '';
              item.dataset.na = 'false';
            } else {
              recState[index] = 'na';
              item.style.opacity = '0.2';
              item.style.borderColor = '#374151';
              btn.textContent = 'N/A';
              btn.style.background = '#374151';
              item.dataset.na = 'true';
            }
            saveRecState();
          });
        });

        // Click row to toggle checkbox
        document.querySelectorAll('.rec-item').forEach(function(item) {
          item.addEventListener('click', function(e) {
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'BUTTON') return;
            var cb = item.querySelector('.rec-checkbox');
            cb.checked = !cb.checked;
          });
        });
      </script>
    </div>
  )}

  <!-- SITE TREE -->
  {sectionId === 'site-tree' && crawlData?.tree && (
    <div>
      <div class="grid grid-cols-3 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{crawlData.pages_crawled}</div>
          <div class="text-xs text-gray-500">Total Pages</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{crawlData.avg_depth}</div>
          <div class="text-xs text-gray-500">Avg Depth</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{crawlData.tree?.children?.length || 0}</div>
          <div class="text-xs text-gray-500">Top-Level Sections</div>
        </div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
        <h3 class="text-sm font-semibold text-gray-400 mb-4">Site Structure</h3>
        <SiteTree tree={crawlData.tree} client:load />
      </div>
    </div>
  )}

  <!-- INTERNAL LINKS -->
  {sectionId === 'internal-links' && crawlData && (
    <div>
      <div class="grid grid-cols-3 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{crawlData.links?.filter((l: any) => l.type === 'internal').length || 0}</div>
          <div class="text-xs text-gray-500">Internal Links</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class={`text-2xl font-bold ${crawlData.orphan_pages > 0 ? 'text-red-400' : 'text-green-400'}`}>{crawlData.orphan_pages}</div>
          <div class="text-xs text-gray-500">Orphan Pages</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{crawlData.avg_depth}</div>
          <div class="text-xs text-gray-500">Avg Link Depth</div>
        </div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
        <h3 class="text-sm font-semibold text-gray-400 mb-4">Internal Link Map</h3>
        <LinkGraph pages={crawlData.pages} links={crawlData.links?.slice(0, 500)} client:load />
      </div>
    </div>
  )}

  <!-- Fallback for sections without detail pages -->
  {!['traffic', 'content-gaps', 'seo-health', 'ai-citations', 'uptime', 'positive-signals', 'ai-readiness', 'search-performance', 'overview', 'site-speed', 'crawl-activity', 'competitors', 'recommendations', 'new-pages', 'site-tree', 'internal-links', 'site-manager'].includes(sectionId) && (
    <div class="bg-gray-900 border border-gray-800 rounded-lg p-8 text-center">
      <p class="text-gray-500">Detailed view for {section.label} coming soon.</p>
      <a href={`/agency/${clientId}`} class="text-sm text-blue-400 hover:text-blue-300 mt-2 inline-block">Back to dashboard</a>
    </div>
  )}
</DashboardLayout>

<!-- Chart scripts -->
<script define:vars={{ dailyTraffic, uptimeChecks, crawlDaily, historyData: JSON.stringify(history) }}>
  const daily = JSON.parse(dailyTraffic);
  const checks = JSON.parse(uptimeChecks);

  async function renderCharts() {
    const { Chart, registerables } = await import('https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.js');

    // Traffic chart
    const trafficEl = document.getElementById('trafficChart');
    if (trafficEl && daily.length > 0) {
      const labels = daily.map(d => {
        const date = `${d.date.slice(0,4)}-${d.date.slice(4,6)}-${d.date.slice(6,8)}`;
        return new Date(date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
      });
      new Chart(trafficEl, {
        type: 'line',
        data: {
          labels,
          datasets: [{
            label: 'Users',
            data: daily.map(d => d.users),
            borderColor: '#3b82f6',
            backgroundColor: 'rgba(59, 130, 246, 0.1)',
            fill: true,
            tension: 0.3,
            pointRadius: 2,
          }, {
            label: 'Sessions',
            data: daily.map(d => d.sessions),
            borderColor: '#8b5cf6',
            borderDash: [5, 5],
            tension: 0.3,
            pointRadius: 0,
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { labels: { color: '#9ca3af', font: { size: 11 } } } },
          scales: {
            x: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: '#1f2937' } },
            y: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: '#1f2937' } },
          }
        }
      });
    }

    // Uptime chart
    const uptimeEl = document.getElementById('uptimeChart');
    if (uptimeEl && checks.length > 0) {
      const labels = checks.map(c => new Date(c.time).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }));
      new Chart(uptimeEl, {
        type: 'line',
        data: {
          labels,
          datasets: [{
            label: 'Response Time (ms)',
            data: checks.map(c => c.ms),
            borderColor: c => c.raw > 2000 ? '#ef4444' : '#10b981',
            backgroundColor: 'rgba(16, 185, 129, 0.1)',
            fill: true,
            tension: 0.3,
            pointRadius: 3,
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { labels: { color: '#9ca3af', font: { size: 11 } } } },
          scales: {
            x: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: '#1f2937' } },
            y: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: '#1f2937' } },
          }
        }
      });
    }

    // Crawl activity chart
    const crawlData = JSON.parse(crawlDaily);
    const crawlEl = document.getElementById('crawlChart');
    if (crawlEl && crawlData.length > 0) {
      const labels = crawlData.map(d => {
        const date = new Date(d.date);
        return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
      });
      new Chart(crawlEl, {
        type: 'bar',
        data: {
          labels,
          datasets: [{
            label: 'Pages Crawled',
            data: crawlData.map(d => d.crawled_pages),
            backgroundColor: 'rgba(59, 130, 246, 0.6)',
            borderColor: '#3b82f6',
            borderWidth: 1,
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { labels: { color: '#9ca3af', font: { size: 11 } } } },
          scales: {
            x: { ticks: { color: '#6b7280', font: { size: 9 }, maxRotation: 45 }, grid: { color: '#1f2937' } },
            y: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: '#1f2937' } },
          }
        }
      });
    }

    // Index growth chart
    const indexEl = document.getElementById('indexChart');
    if (indexEl && crawlData.length > 0) {
      const labels = crawlData.map(d => {
        const date = new Date(d.date);
        return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
      });
      new Chart(indexEl, {
        type: 'line',
        data: {
          labels,
          datasets: [{
            label: 'Pages Indexed',
            data: crawlData.map(d => d.in_index),
            borderColor: '#10b981',
            backgroundColor: 'rgba(16, 185, 129, 0.1)',
            fill: true,
            tension: 0.3,
            pointRadius: 2,
          }, {
            label: 'Inbound Links',
            data: crawlData.map(d => d.in_links),
            borderColor: '#8b5cf6',
            borderDash: [5, 5],
            tension: 0.3,
            pointRadius: 0,
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { labels: { color: '#9ca3af', font: { size: 11 } } } },
          scales: {
            x: { ticks: { color: '#6b7280', font: { size: 9 }, maxRotation: 45 }, grid: { color: '#1f2937' } },
            y: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: '#1f2937' } },
          }
        }
      });
    }
  }

    // Trend charts from daily history
    const hist = JSON.parse(historyData);
    if (hist.length > 1) {
      const trendLabels = hist.map(h => {
        const d = new Date(h.date);
        return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
      });

      const trendCharts = [
        { id: 'trend-ai-score', data: hist.map(h => h.ai_score), color: '#8b5cf6', label: 'AI Score' },
        { id: 'trend-citation', data: hist.map(h => h.citation_rate), color: '#ef4444', label: 'Citation %' },
        { id: 'trend-users', data: hist.map(h => h.users), color: '#3b82f6', label: 'Users' },
        { id: 'trend-indexed', data: hist.map(h => h.bing_indexed), color: '#10b981', label: 'Indexed' },
      ];

      for (const tc of trendCharts) {
        const el = document.getElementById(tc.id);
        if (el) {
          new Chart(el, {
            type: 'line',
            data: {
              labels: trendLabels,
              datasets: [{
                label: tc.label,
                data: tc.data,
                borderColor: tc.color,
                backgroundColor: tc.color + '20',
                fill: true,
                tension: 0.3,
                pointRadius: 3,
              }]
            },
            options: {
              responsive: true,
              plugins: { legend: { display: false } },
              scales: {
                x: { ticks: { color: '#6b7280', font: { size: 9 } }, grid: { color: '#1f2937' } },
                y: { ticks: { color: '#6b7280', font: { size: 10 } }, grid: { color: '#1f2937' } },
              }
            }
          });
        }
      }
    }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderCharts);
  } else {
    renderCharts();
  }
</script>
