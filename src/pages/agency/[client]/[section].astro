                <th class="text-center py-2 px-1" title="Meta Description">Meta</th>
                <th class="text-center py-2 px-1" title="Schema Markup">Schema</th>
                <th class="text-center py-2 px-1" title="Answer Capsule (40-60w direct answer)">Capsule</th>
                <th class="text-center py-2 px-1" title="FAQ Section">FAQ</th>
                <th class="text-center py-2 px-1" title="Images">Imgs</th>
                <th class="text-center py-2 px-1" title="Image Alt Text">Alt</th>
                <th class="text-center py-2 px-1" title="Video">Vid</th>
                <th class="text-center py-2 px-1" title="Comparison Table">Table</th>
                <th class="text-center py-2 px-1" title="Open Graph Tags">OG</th>
                <th class="text-center py-2 px-1" title="Breadcrumbs">Bread</th>
                <th class="text-center py-2 px-1" title="Definition Statement">Def</th>
                <th class="text-center py-2 px-1" title="Author Attribution">Auth</th>
                <th class="text-center py-2 px-1" title="Call to Action">CTA</th>
                <th class="text-center py-2 px-1" title="Internal Links In (3+)">Links</th>
                <th class="text-center py-2 px-1" title="Content Depth (500+ words)">Words</th>
                <th class="text-center py-2 px-1" title="Last Modified Date">Date</th>
              </tr>
            </thead>
            <tbody>
              {crawlData.pages?.filter((p: any) => p.word_count > 20).sort((a: any, b: any) => a.path.localeCompare(b.path)).map((p: any) => {
                const tick = '<span class="text-green-400">✓</span>';
                const cross = '<span class="text-red-400">✗</span>';
                const dash = '<span class="text-gray-700">-</span>';
                const isQA = p.path?.includes('/questions/') || p.path?.includes('/ai-search-questions/');
                return (
                  <tr class="border-b border-gray-800/30 hover:bg-gray-800/20">
                    <td class="py-1.5 px-2 text-blue-400 truncate max-w-[150px]">{p.path}</td>
                    <td class="text-center py-1.5 px-1" set:html={p.h1 ? tick : cross} />
                    <td class="text-center py-1.5 px-1" set:html={p.meta_desc ? tick : cross} />
                    <td class="text-center py-1.5 px-1" set:html={p.schemas?.length > 0 ? tick : cross} />
                    <td class="text-center py-1.5 px-1" set:html={p.has_answer_capsule ? tick : (isQA ? dash : cross)} />
                    <td class="text-center py-1.5 px-1" set:html={p.schemas?.includes('FAQPage') || p.question_h2s >= 2 ? tick : dash} />
                    <td class="text-center py-1.5 px-1" set:html={p.image_count > 0 ? tick : (isQA ? dash : cross)} />
                    <td class="text-center py-1.5 px-1" set:html={p.image_count === 0 || p.images_with_alt === p.image_count ? tick : cross} />
                    <td class="text-center py-1.5 px-1" set:html={p.video_count > 0 ? tick : dash} />
                    <td class="text-center py-1.5 px-1" set:html={p.has_comparison_table ? tick : dash} />
                    <td class="text-center py-1.5 px-1" set:html={p.has_og_tags ? tick : cross} />
                    <td class="text-center py-1.5 px-1" set:html={p.has_breadcrumbs ? tick : cross} />
                    <td class="text-center py-1.5 px-1" set:html={p.has_definition ? tick : dash} />
                    <td class="text-center py-1.5 px-1" set:html={p.has_author ? tick : dash} />
                    <td class="text-center py-1.5 px-1" set:html={p.has_cta ? tick : dash} />
                    <td class="text-center py-1.5 px-1" set:html={(p.internal_links_in || 0) >= 3 ? tick : cross} />
                    <td class="text-center py-1.5 px-1" set:html={isQA ? (p.word_count >= 100 ? tick : cross) : (p.word_count >= 500 ? tick : cross)} />
                    <td class="text-center py-1.5 px-1" set:html={p.last_modified ? tick : dash} />
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        <div class="mt-3 flex gap-4 text-[10px] text-gray-500">
          <span><span class="text-green-400">✓</span> = present</span>
          <span><span class="text-red-400">✗</span> = missing (should have)</span>
          <span><span class="text-gray-700">-</span> = optional / not applicable</span>
        </div>

        <script>
          function collectMissing(criticalOnly) {
            var headers = ['H1', 'Meta', 'Schema', 'Capsule', 'FAQ', 'Images', 'Alt', 'Video', 'Table', 'OG', 'Bread', 'Def', 'Auth', 'CTA', 'Links', 'Words', 'Date'];
            var criticalHeaders = ['H1', 'Meta', 'Schema', 'Capsule', 'OG', 'Bread', 'Images', 'Links', 'Words'];
            var rows = document.querySelectorAll('table tbody tr');
            var lines = [];

            rows.forEach(function(row) {
              var cells = row.querySelectorAll('td');
              if (cells.length < 18) return;
              var path = cells[0]?.textContent?.trim() || '';
              var missing = [];

              for (var i = 1; i < cells.length && i <= headers.length; i++) {
                var text = cells[i]?.textContent?.trim() || '';
                if (text === '✗') {
                  var header = headers[i - 1];
                  if (!criticalOnly || criticalHeaders.includes(header)) {
                    missing.push(header);
                  }
                }
              }

              if (missing.length > 0) {
                lines.push(path + ': missing ' + missing.join(', '));
              }
            });

            return lines;
          }

          document.getElementById('copy-missing-all')?.addEventListener('click', function() {
            var lines = collectMissing(false);
            var text = 'Pages with missing elements (' + lines.length + ' pages):\n\n' + lines.join('\n');
            navigator.clipboard.writeText(text).then(function() {
              var btn = document.getElementById('copy-missing-all');
              btn.textContent = 'Copied! (' + lines.length + ' pages)';
              btn.style.background = '#22c55e';
              setTimeout(function() { btn.textContent = 'Copy All Missing'; btn.style.background = ''; }, 3000);
            });
          });

          document.getElementById('copy-missing-critical')?.addEventListener('click', function() {
            var lines = collectMissing(true);
            var text = 'Pages with critical missing elements (' + lines.length + ' pages):\n\n' + lines.join('\n');
            navigator.clipboard.writeText(text).then(function() {
              var btn = document.getElementById('copy-missing-critical');
              btn.textContent = 'Copied! (' + lines.length + ' pages)';
              btn.style.background = '#22c55e';
              setTimeout(function() { btn.textContent = 'Copy Critical Only'; btn.style.background = ''; }, 3000);
            });
          });
        </script>
      </div>

      <!-- Page inventory with search -->
      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold text-gray-400">All Pages ({crawlData.pages_crawled})</h3>
          <div class="flex items-center gap-2">
            <input
              type="text"
              placeholder="Search pages..."
              class="bg-gray-800 border border-gray-700 rounded px-3 py-1.5 text-xs text-white placeholder-gray-500 focus:border-blue-500 focus:outline-none w-48"
              id="page-search"
            />
            <button id="export-csv" class="px-3 py-1.5 rounded text-xs bg-gray-700 text-gray-300 hover:bg-gray-600 transition" title="Export all page meta to CSV">
              Export CSV
            </button>
          </div>
        </div>
        <div class="overflow-x-auto max-h-[600px] overflow-y-auto" id="page-list">
          <table class="w-full text-xs">
            <thead class="sticky top-0 bg-gray-900">
              <tr class="text-gray-500 border-b border-gray-800">
                <th class="text-left py-2 px-3 cursor-pointer hover:text-white" data-sort="path">Path</th>
                <th class="text-left py-2 px-3 cursor-pointer hover:text-white" data-sort="h1">H1</th>
                <th class="text-left py-2 px-3 cursor-pointer hover:text-white" data-sort="title">Title</th>
                <th class="text-right py-2 px-3 cursor-pointer hover:text-white" data-sort="words">Words</th>
                <th class="text-center py-2 px-3">Schema</th>
                <th class="text-right py-2 px-3 cursor-pointer hover:text-white" data-sort="links">Links In</th>
                <th class="text-right py-2 px-3">Depth</th>
              </tr>
            </thead>
            <tbody>
              {crawlData.pages?.sort((a: any, b: any) => a.path.localeCompare(b.path)).map((p: any) => (
                <tr class="border-b border-gray-800/50 hover:bg-gray-800/30 page-row" data-path={p.path}>
                  <td class="py-2 px-3 text-blue-400 truncate max-w-[180px]">
                    <a href={p.url} target="_blank" class="hover:underline">{p.path}</a>
                  </td>
                  <td class={`py-2 px-3 truncate max-w-[200px] ${p.h1 ? 'text-gray-300' : 'text-red-400'}`}>{p.h1 || 'MISSING'}</td>
                  <td class="py-2 px-3 text-gray-500 truncate max-w-[200px]">{p.title?.slice(0, 50)}</td>
                  <td class={`py-2 px-3 text-right ${p.word_count < 100 ? 'text-red-400' : p.word_count >= 2000 ? 'text-green-400' : 'text-white'}`}>{p.word_count}</td>
                  <td class="py-2 px-3 text-center">{p.schemas?.length > 0 ? <span class="text-green-400 text-[10px]">{p.schemas.join(', ')}</span> : <span class="text-red-400">None</span>}</td>
                  <td class="py-2 px-3 text-right text-white">{p.internal_links_in || 0}</td>
                  <td class="py-2 px-3 text-right text-gray-400">{p.depth || 0}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Search filter script -->
      <script>
        document.getElementById('page-search')?.addEventListener('input', (e) => {
          const query = e.target.value.toLowerCase();
          document.querySelectorAll('.page-row').forEach(row => {
            const path = row.getAttribute('data-path')?.toLowerCase() || '';
            const h1 = row.querySelector('td:nth-child(2)')?.textContent?.toLowerCase() || '';
            row.style.display = (path.includes(query) || h1.includes(query)) ? '' : 'none';
          });
        });

        // Content type filter
        document.querySelectorAll('[data-filter-type]').forEach(card => {
          card.addEventListener('click', () => {
            const type = card.getAttribute('data-filter-type');
            document.querySelectorAll('.page-row').forEach(row => {
              const path = row.getAttribute('data-path') || '';
              row.style.display = path.startsWith('/' + type) ? '' : 'none';
            });
            // Clear search
            const search = document.getElementById('page-search');
            if (search) search.value = type;
          });
        });

        const workerUrl = 'https://rank4ai-tracker.dawn-field-3d16.workers.dev';
        const siteRepo = document.querySelector('[data-site-repo]')?.getAttribute('data-site-repo') || '';

        // Export CSV
        document.getElementById('export-csv')?.addEventListener('click', function() {
          var rows = [['Path', 'H1', 'Title', 'Meta Description', 'Words', 'Schema', 'Links In', 'Depth']];
          document.querySelectorAll('.page-row').forEach(function(row) {
            var cells = row.querySelectorAll('td');
            if (cells.length >= 7) {
              rows.push([
                row.getAttribute('data-path') || '',
                (cells[1]?.textContent || '').trim(),
                (cells[2]?.textContent || '').trim(),
                '', // Meta desc not in table — would need to fetch
                (cells[3]?.textContent || '').trim(),
                (cells[4]?.textContent || '').trim(),
                (cells[5]?.textContent || '').trim(),
                (cells[6]?.textContent || '').trim(),
              ]);
            }
          });
          var csv = rows.map(function(r) { return r.map(function(c) { return '"' + (c || '').replace(/"/g, '""') + '"'; }).join(','); }).join('\n');
          var blob = new Blob([csv], { type: 'text/csv' });
          var url = URL.createObjectURL(blob);
          var a = document.createElement('a');
          a.href = url;
          a.download = 'pages-export.csv';
          a.click();
        });

        // Create new page handler
        document.getElementById('create-page-btn')?.addEventListener('click', async function() {
          var pageType = document.getElementById('new-page-type').value;
          var slug = document.getElementById('new-page-slug').value.trim();
          var title = document.getElementById('new-page-title').value.trim();
          var desc = document.getElementById('new-page-desc').value.trim();
          var content = document.getElementById('new-page-content').value;
          var status = document.getElementById('create-status');

          if (!slug || !title) {
            status.textContent = 'Slug and title required';
            status.style.color = '#ef4444';
            return;
          }

          // Clean slug
          slug = slug.toLowerCase().replace(/[^a-z0-9-]/g, '-').replace(/-+/g, '-');

          this.textContent = 'Creating...';
          this.disabled = true;

          // Build the page content from template
          var today = new Date().toISOString().slice(0, 10);
          var pageContent = '---\n';
          pageContent += "import BaseLayout from '../../layouts/BaseLayout.astro';\n";
          pageContent += "import Breadcrumbs from '../../components/Breadcrumbs.astro';\n";
          pageContent += "import LeadForm from '../../components/LeadForm.astro';\n\n";
          pageContent += 'const title = "' + title.replace(/"/g, '\\"') + '";\n';
          pageContent += 'const description = "' + desc.replace(/"/g, '\\"') + '";\n';
          pageContent += '\nconst schema = {\n';
          pageContent += '  "@context": "https://schema.org",\n';
          pageContent += '  "@type": "Article",\n';
          pageContent += '  "headline": "' + title.replace(/"/g, '\\"') + '",\n';
          pageContent += '  "description": description,\n';
          pageContent += '  "datePublished": "' + today + '",\n';
          pageContent += '  "dateModified": "' + today + '",\n';
          pageContent += '  "author": { "@type": "Organization", "name": "Market Invoice" },\n';
          pageContent += '  "publisher": { "@type": "Organization", "name": "Market Invoice", "url": "https://marketinvoice.co.uk" }\n';
          pageContent += '};\n';
          pageContent += '---\n\n';
          pageContent += '<BaseLayout title={title} description={description} schema={schema}>\n';
          pageContent += '  <article class="max-w-3xl mx-auto px-4 py-12 md:py-16">\n';
          pageContent += '    <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "' + pageType + '", href: "/' + pageType + '/" }, { label: title.slice(0,30) }]} />\n\n';
          pageContent += '    <h1 class="text-3xl md:text-4xl font-bold mb-6">' + title + '</h1>\n\n';
          if (content) {
            pageContent += '    ' + content + '\n\n';
          } else {
            pageContent += '    <p class="text-lg text-gray-700 leading-relaxed mb-6">Content coming soon.</p>\n\n';
          }
          pageContent += '    <LeadForm />\n';
          pageContent += '  </article>\n';
          pageContent += '</BaseLayout>\n';

          // Determine file path
          var filePath = 'src/pages/' + pageType + '/' + slug + '.astro';

          try {
            var resp = await fetch(workerUrl + '/api/file', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                repo: siteRepo,
                path: filePath,
                content: pageContent,
                message: 'Create ' + pageType + ': ' + title + ' via dashboard',
              }),
            });

            if (resp.ok) {
              status.textContent = 'Created! Auto-deploying...';
              status.style.color = '#22c55e';
              this.textContent = 'Created!';
              this.style.background = '#22c55e';
              // Clear form
              document.getElementById('new-page-slug').value = '';
              document.getElementById('new-page-title').value = '';
              document.getElementById('new-page-desc').value = '';
              document.getElementById('new-page-content').value = '';
            } else {
              var err = await resp.json();
              status.textContent = 'Error: ' + (err.error || 'Failed');
              status.style.color = '#ef4444';
              this.textContent = 'Error';
              this.style.background = '#ef4444';
            }
          } catch (err) {
            status.textContent = 'Error: ' + err.message;
            status.style.color = '#ef4444';
          }

          var btn = this;
          setTimeout(function() { btn.textContent = 'Create Page (auto-deploy)'; btn.style.background = ''; btn.disabled = false; }, 3000);
        });

        // Copy Claude prompt for new page creation
        document.getElementById('copy-create-prompt-btn')?.addEventListener('click', function() {
          var pageType = document.getElementById('new-page-type')?.value || 'page';
          var slug = (document.getElementById('new-page-slug')?.value || '').trim().toLowerCase().replace(/[^a-z0-9-]/g, '-').replace(/-+/g, '-');
          var newTitle = (document.getElementById('new-page-title')?.value || '').trim();
          var newDesc = (document.getElementById('new-page-desc')?.value || '').trim();
          var newContent = (document.getElementById('new-page-content')?.value || '').trim();
          var status = document.getElementById('create-status');
          if (!slug || !newTitle) {
            if (status) { status.textContent = 'Slug and title required'; status.style.color = '#ef4444'; }
            return;
          }
          var repoLocal = siteRepo.includes('market-invoice') ? '~/compare-invoice-finance' : siteRepo.includes('seocompare') ? '~/compareaiseo' : '~/rank4ai-site';
          var prompt = [
            'Site: ' + siteRepo + ' (' + repoLocal + ')',
            'Create new ' + pageType + ' page',
            '',
            'Slug: ' + slug,
            'Title: ' + newTitle,
            'Meta description: ' + newDesc,
            '',
            'Content:',
            newContent || '(no content provided — please draft based on title)',
            '',
            '1. Create ' + repoLocal + '/src/pages/' + pageType + '/' + slug + '.astro',
            '2. Use BaseLayout/Layout pattern from sister pages in the same section',
            '3. Include Breadcrumbs + AuthorBox + Article schema + SpeakableSchema',
            '4. Build to verify',
            '5. Commit + push to main (Cloudflare auto-deploys)',
            '6. Append entry to CHANGELOG_*.md',
            '7. Mark in FLEET INBOX if part of a tracked initiative',
          ].join('\n');
          navigator.clipboard.writeText(prompt).then(function() {
            var btn = document.getElementById('copy-create-prompt-btn');
            var orig = btn.textContent;
            btn.textContent = '✓ Copied';
            btn.style.background = 'rgba(34, 197, 94, 0.2)';
            setTimeout(function() { btn.textContent = orig; btn.style.background = ''; }, 1800);
          });
        });

        // Click page row to open editor
        document.querySelectorAll('.page-row').forEach(function(row) {
          row.addEventListener('click', async function(e) {
            if (e.target.tagName === 'A') return;
            var pagePath = row.getAttribute('data-path');
            var editorPanel = document.getElementById('page-editor');
            if (!editorPanel) return;

            editorPanel.classList.remove('hidden');
            editorPanel.textContent = 'Loading...';

            var filePath = 'src/pages' + pagePath.replace(/\/$/, '') + (pagePath.endsWith('/') ? '/index.astro' : '.astro');

            try {
              var resp = await fetch(workerUrl + '/api/file?repo=' + encodeURIComponent(siteRepo) + '&path=' + encodeURIComponent(filePath));
              if (!resp.ok) throw new Error('HTTP ' + resp.status);
              var data = await resp.json();
              var content = data.content;

              // Parse title, description, and H1 from content
              var titleMatch = content.match(/(?:const\s+)?title\s*=\s*["'](.*?)["']/);
              var descMatch = content.match(/(?:const\s+)?description\s*=\s*["'](.*?)["']/);
              var h1Match = content.match(/<h1[^>]*>(.*?)<\/h1>/);
              var title = titleMatch ? titleMatch[1] : '';
              var desc = descMatch ? descMatch[1] : '';
              var h1 = h1Match ? h1Match[1].replace(/<[^>]+>/g, '') : '';

              // Build editor UI
              editorPanel.innerHTML = '';

              var header = document.createElement('div');
              header.className = 'flex items-center justify-between mb-4';
              header.innerHTML = '<h3 class="text-sm font-semibold text-white">' + pagePath + '</h3><button id="close-editor" class="text-gray-500 hover:text-white text-xs">Close</button>';
              editorPanel.appendChild(header);

              // Title field
              var titleDiv = document.createElement('div');
              titleDiv.className = 'mb-3';
              titleDiv.innerHTML = '<label class="text-[10px] text-gray-500 uppercase block mb-1">Title Tag (' + title.length + ' chars)</label>';
              var titleInput = document.createElement('input');
              titleInput.type = 'text';
              titleInput.value = title;
              titleInput.className = 'w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-xs text-white';
              titleInput.id = 'edit-title';
              titleDiv.appendChild(titleInput);
              editorPanel.appendChild(titleDiv);

              // H1 display (read-only — H1 is in the template HTML)
              if (h1) {
                var h1Div = document.createElement('div');
                h1Div.className = 'mb-3';
                h1Div.innerHTML = '<label class="text-[10px] text-gray-500 uppercase block mb-1">H1 Tag</label><div class="px-3 py-2 bg-gray-800/50 border border-gray-700 rounded text-xs text-gray-300">' + h1 + '</div>';
                editorPanel.appendChild(h1Div);
              }

              // Description field
              var descDiv = document.createElement('div');
              descDiv.className = 'mb-3';
              descDiv.innerHTML = '<label class="text-[10px] text-gray-500 uppercase block mb-1">Meta Description (' + desc.length + ' chars)</label>';
              var descArea = document.createElement('textarea');
              descArea.rows = 3;
              descArea.value = desc;
              descArea.className = 'w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-xs text-white';
              descArea.id = 'edit-desc';
              descDiv.appendChild(descArea);
              editorPanel.appendChild(descDiv);

              // Buttons
              var btnDiv = document.createElement('div');
              btnDiv.className = 'flex gap-2';
              var saveBtn = document.createElement('button');
              saveBtn.textContent = 'Save to GitHub';
              saveBtn.className = 'px-4 py-2 rounded text-xs bg-blue-600 text-white hover:bg-blue-500 transition';
              var ghLink = document.createElement('a');
              ghLink.href = 'https://github.com/' + siteRepo + '/blob/main/' + filePath;
              ghLink.target = '_blank';
              ghLink.textContent = 'View on GitHub';
              ghLink.className = 'px-4 py-2 rounded text-xs bg-gray-700 text-gray-300 hover:bg-gray-600 transition';
              var deleteBtn = document.createElement('button');
              deleteBtn.textContent = 'Delete Page';
              deleteBtn.className = 'px-4 py-2 rounded text-xs bg-red-900 text-red-300 hover:bg-red-800 transition';

              // Copy Claude prompt button (Claude-in-the-loop alternative)
              var copyPromptBtn = document.createElement('button');
              copyPromptBtn.textContent = 'Copy Claude prompt';
              copyPromptBtn.className = 'px-4 py-2 rounded text-xs bg-purple-900/40 hover:bg-purple-800/60 border border-purple-700 text-purple-200 transition';
              copyPromptBtn.title = 'Copy a Claude-ready edit brief to clipboard (paste into a Claude Code session)';
              copyPromptBtn.addEventListener('click', function() {
                var newTitle = document.getElementById('edit-title')?.value || title;
                var newDesc = document.getElementById('edit-desc')?.value || desc;
                var repoLocal = siteRepo.includes('market-invoice') ? '~/compare-invoice-finance' : siteRepo.includes('seocompare') ? '~/compareaiseo' : '~/rank4ai-site';
                var prompt = [
                  'Site: ' + siteRepo + ' (' + repoLocal + ')',
                  'File: ' + filePath,
                  'URL: ' + previewLink.href,
                  '',
                  'Current title: ' + title,
                  'Current meta_desc: ' + desc,
                  '',
                  'Please update to:',
                  '  Title: ' + newTitle,
                  '  Meta_desc: ' + newDesc,
                  '',
                  '1. Edit ' + filePath + ' in the repo',
                  '2. Build to verify',
                  '3. Commit + push to main (Cloudflare auto-deploys)',
                  '4. Append a one-line entry to the relevant CHANGELOG_*.md',
                ].join('\n');
                navigator.clipboard.writeText(prompt).then(function() {
                  var orig = copyPromptBtn.textContent;
                  copyPromptBtn.textContent = '✓ Copied';
                  copyPromptBtn.style.background = 'rgba(34, 197, 94, 0.2)';
                  setTimeout(function() {
                    copyPromptBtn.textContent = orig;
                    copyPromptBtn.style.background = '';
                  }, 1800);
                });
              });

              btnDiv.appendChild(saveBtn);
              btnDiv.appendChild(copyPromptBtn);
              btnDiv.appendChild(ghLink);
              btnDiv.appendChild(deleteBtn);
              editorPanel.appendChild(btnDiv);

              // Preview link
              var previewDiv = document.createElement('div');
              previewDiv.className = 'mt-3 pt-3 border-t border-gray-800';
              var previewLink = document.createElement('a');
              previewLink.href = 'https://' + (siteRepo.includes('market-invoice') ? 'www.marketinvoice.co.uk' : siteRepo.includes('seocompare') ? 'www.seocompare.co.uk' : 'adamparkerrank4ai.github.io/rank4ai-preview') + pagePath;
              previewLink.target = '_blank';
              previewLink.textContent = 'Preview live page →';
              previewLink.className = 'text-xs text-blue-400 hover:text-blue-300';
              previewDiv.appendChild(previewLink);
              editorPanel.appendChild(previewDiv);

              // Close
              document.getElementById('close-editor').addEventListener('click', function() {
                editorPanel.classList.add('hidden');
              });

              // Delete handler
              deleteBtn.addEventListener('click', async function() {
                if (!confirm('DELETE ' + pagePath + '?\n\nThis will remove the page from the site. It cannot be undone (without git revert).')) return;
                if (!confirm('Are you REALLY sure? Type the page path in the next prompt if you want to proceed.')) return;
                deleteBtn.textContent = 'Deleting...';
                deleteBtn.disabled = true;
                try {
                  var delResp = await fetch(workerUrl + '/api/file', {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                      repo: siteRepo, path: filePath, sha: data.sha,
                      message: 'Delete ' + pagePath + ' via dashboard',
                    }),
                  });
                  if (delResp.ok) {
                    deleteBtn.textContent = 'Deleted';
                    deleteBtn.style.background = '#166534';
                    editorPanel.style.borderColor = '#166534';
                  } else {
                    deleteBtn.textContent = 'Error';
                    deleteBtn.style.background = '#ef4444';
                  }
                } catch(e) {
                  deleteBtn.textContent = 'Error';
                  deleteBtn.style.background = '#ef4444';
                }
              });

              // Save
              saveBtn.addEventListener('click', async function() {
                var newTitle = document.getElementById('edit-title').value;
                var newDesc = document.getElementById('edit-desc').value;
                var newContent = content;
                if (title) newContent = newContent.replace(title, newTitle);
                if (desc) newContent = newContent.replace(desc, newDesc);

                saveBtn.textContent = 'Saving...';
                saveBtn.disabled = true;

                try {
                  var saveResp = await fetch(workerUrl + '/api/file', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                      repo: siteRepo, path: filePath, content: newContent,
                      sha: data.sha, message: 'Update meta: ' + pagePath + ' via dashboard',
                    }),
                  });
                  if (saveResp.ok) {
                    saveBtn.textContent = 'Saved!';
                    saveBtn.style.background = '#22c55e';
                  } else {
                    saveBtn.textContent = 'Error';
                    saveBtn.style.background = '#ef4444';
                  }
                } catch (err) {
                  saveBtn.textContent = 'Error';
                  saveBtn.style.background = '#ef4444';
                }
                setTimeout(function() { saveBtn.textContent = 'Save to GitHub'; saveBtn.style.background = ''; saveBtn.disabled = false; }, 3000);
              });

            } catch (err) {
              editorPanel.innerHTML = '<div class="text-red-400 text-xs py-4">Failed to load: ' + err.message + '</div>';
            }
          });
        });
      </script>

      <!-- Page editor panel (hidden by default) -->
