          <div class={`text-2xl font-bold ${(pagespeed.avg_scores?.performance || 0) >= 80 ? 'text-green-400' : (pagespeed.avg_scores?.performance || 0) >= 50 ? 'text-yellow-400' : 'text-red-400'}`}>{pagespeed.avg_scores?.performance || 0}</div>
          <div class="text-xs text-gray-500">Performance</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class={`text-2xl font-bold ${(pagespeed.avg_scores?.accessibility || 0) >= 80 ? 'text-green-400' : 'text-yellow-400'}`}>{pagespeed.avg_scores?.accessibility || 0}</div>
          <div class="text-xs text-gray-500">Accessibility</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class={`text-2xl font-bold ${(pagespeed.avg_scores?.seo || 0) >= 80 ? 'text-green-400' : 'text-yellow-400'}`}>{pagespeed.avg_scores?.seo || 0}</div>
          <div class="text-xs text-gray-500">SEO Score</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{pagespeed.avg_scores?.['best-practices'] || 0}</div>
