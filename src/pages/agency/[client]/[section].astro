          <!-- Detailed list -->
          {Object.entries(newPagesDetail.by_category || {}).map(([cat, data]: [string, any]) => (
            <div class="bg-gray-900 border border-gray-800 rounded-lg p-6 mb-4">
              <h3 class="text-sm font-semibold text-gray-400 mb-3">{cat} ({data.count} new)</h3>
              <div class="overflow-x-auto">
                <table class="w-full text-xs">
                  <thead>
                    <tr class="text-gray-500 border-b border-gray-800">
                      <th class="text-left py-2 px-3">Page</th>
                      <th class="text-left py-2 px-3">H1</th>
                      <th class="text-right py-2 px-3">Words</th>
                      <th class="text-center py-2 px-3">Schema</th>
                    </tr>
                  </thead>
                  <tbody>
                    {data.pages?.map((p: any) => (
                      <tr class="border-b border-gray-800/50">
                        <td class="py-2 px-3 text-gray-300 truncate max-w-[200px]">{p.path}</td>
                        <td class="py-2 px-3 text-gray-400 truncate max-w-[200px]">{p.h1 || '--'}</td>
                        <td class="py-2 px-3 text-right text-white">{p.word_count}</td>
                        <td class="py-2 px-3 text-center">{p.has_schema ? <span class="text-green-400">Yes</span> : <span class="text-red-400">No</span>}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-8 text-center">
          <p class="text-gray-500 text-sm">No new pages detected since the baseline was set ({newPagesDetail.baseline_pages} pages).</p>
          <p class="text-gray-600 text-xs mt-2">New pages will appear here when the daily crawl detects additions to the site.</p>
          <p class="text-gray-600 text-xs mt-1">Baseline set: {new Date(newPagesDetail.checked_at).toLocaleDateString('en-GB')}</p>
        </div>
      )}
    </div>
  )}

  <!-- RECOMMENDATIONS -->
  {sectionId === 'recommendations' && recs && (
    <div>
      <div class="grid grid-cols-4 gap-4 mb-6" id="rec-stats">
        <div class="bg-red-950/30 border border-red-800/50 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-red-400" id="rec-stat-critical">{recs.critical}</div>
          <div class="text-xs text-gray-500">Critical</div>
        </div>
        <div class="bg-yellow-950/30 border border-yellow-800/50 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-yellow-400" id="rec-stat-high">{recs.high}</div>
          <div class="text-xs text-gray-500">High</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-blue-400" id="rec-stat-medium">{recs.medium}</div>
          <div class="text-xs text-gray-500">Medium</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-gray-400" id="rec-stat-low">{recs.low}</div>
          <div class="text-xs text-gray-500">Low</div>
        </div>
      </div>

      <!-- Filter + Copy controls -->
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class="text-xs text-gray-500">Filter:</span>
        <button class="rec-filter px-3 py-1.5 rounded text-xs bg-gray-800 text-white border border-gray-700 hover:bg-gray-700 transition" data-filter="all">All ({recs.total})</button>
        <button class="rec-filter px-3 py-1.5 rounded text-xs bg-red-900/50 text-red-300 border border-red-800/50 hover:bg-red-900 transition" data-filter="critical">Critical ({recs.critical})</button>
        <button class="rec-filter px-3 py-1.5 rounded text-xs bg-yellow-900/50 text-yellow-300 border border-yellow-800/50 hover:bg-yellow-900 transition" data-filter="high">High ({recs.high})</button>
        <button class="rec-filter px-3 py-1.5 rounded text-xs bg-blue-900/50 text-blue-300 border border-blue-800/50 hover:bg-blue-900 transition" data-filter="medium">Medium ({recs.medium})</button>
        <button class="rec-filter px-3 py-1.5 rounded text-xs bg-gray-800 text-gray-400 border border-gray-700 hover:bg-gray-700 transition" data-filter="low">Low ({recs.low})</button>
        <span class="text-gray-700 mx-1">|</span>
        <button id="copy-selected-recs" class="px-3 py-1.5 rounded text-xs bg-blue-600 text-white hover:bg-blue-500 transition">
          Copy Selected to Clipboard
        </button>
      </div>

      <div class="space-y-4" id="recs-list">
        {recs.recommendations?.map((r: any, i: number) => (
          <div
            class={`rec-item rounded-lg border p-5 cursor-pointer transition ${r.priority === 'critical' ? 'border-red-800/50 bg-red-950/20' : r.priority === 'high' ? 'border-yellow-800/50 bg-yellow-950/10' : r.priority === 'medium' ? 'border-blue-800/50 bg-blue-950/10' : 'border-gray-800 bg-gray-900'}`}
            data-rec-priority={r.priority}
            data-rec-index={i}
          >
            <div class="flex items-start justify-between mb-2">
              <div class="flex items-center gap-3">
                <input type="checkbox" class="rec-checkbox w-4 h-4 rounded" data-index={i} />
                <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${r.priority === 'critical' ? 'bg-red-600 text-white' : r.priority === 'high' ? 'bg-yellow-600 text-white' : r.priority === 'medium' ? 'bg-blue-600 text-white' : 'bg-gray-600 text-white'}`}>
                  {r.priority.toUpperCase()}
                </span>
                <span class="text-[10px] text-gray-500 px-2 py-0.5 rounded bg-gray-800">{r.category}</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-[10px] text-gray-600">Impact: {r.impact}</span>
                <button
                  class="copy-single-rec text-[10px] px-2 py-1 rounded bg-gray-800 text-gray-400 hover:bg-gray-700 hover:text-white transition"
                  data-index={i}
                >
                  Copy
                </button>
                <button class="done-rec-btn text-[10px] px-2 py-1 rounded bg-gray-800 text-gray-400 hover:bg-green-900 hover:text-green-300 transition" data-index={i}>Done</button>
                <button class="park-rec-btn text-[10px] px-2 py-1 rounded bg-gray-800 text-gray-400 hover:bg-yellow-900 hover:text-yellow-300 transition" data-index={i}>Park</button>
                <button class="na-rec-btn text-[10px] px-2 py-1 rounded bg-gray-800 text-gray-400 hover:bg-gray-700 hover:text-gray-300 transition" data-index={i} title="Remove this recommendation">Remove</button>
              </div>
            </div>
            <h3 class="text-white font-medium text-sm mb-2 rec-title">{r.title}</h3>
            <p class="text-xs text-gray-400 leading-relaxed">{r.detail}</p>
          </div>
        ))}
      </div>

      <script define:vars={{ clientDomain: client?.domain, recsJson: JSON.stringify(recs.recommendations || []) }}>
        const allRecs = JSON.parse(recsJson);

        function buildPrompt(items) {
          if (items.length === 1) {
            return `Fix this issue on ${clientDomain}:\n\n[${items[0].priority.toUpperCase()}] ${items[0].title}\n${items[0].detail}`;
          }
          return `Fix these ${items.length} issues on ${clientDomain}:\n\n` +
            items.map((r, i) => `${i+1}. [${r.priority.toUpperCase()}] ${r.title}\n   ${r.detail}`).join('\n\n');
        }

        function copyText(text, btn) {
          navigator.clipboard.writeText(text).then(() => {
            const orig = btn.textContent;
            btn.textContent = 'Copied!';
            btn.style.background = '#22c55e';
            setTimeout(() => { btn.textContent = orig; btn.style.background = ''; }, 2000);
          });
        }

        // Filter buttons
        document.querySelectorAll('.rec-filter').forEach(btn => {
          btn.addEventListener('click', () => {
            const filter = btn.getAttribute('data-filter');
            document.querySelectorAll('.rec-item').forEach(item => {
              if (filter === 'all' || item.getAttribute('data-rec-priority') === filter) {
                item.style.display = '';
              } else {
                item.style.display = 'none';
              }
            });
            // Update active state
            document.querySelectorAll('.rec-filter').forEach(b => b.style.outline = '');
            btn.style.outline = '2px solid white';

            // Select all visible checkboxes
            document.querySelectorAll('.rec-checkbox').forEach(cb => {
              const item = cb.closest('.rec-item');
              cb.checked = item.style.display !== 'none';
            });
          });
        });

        // Copy single
        document.querySelectorAll('.copy-single-rec').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const idx = parseInt(btn.getAttribute('data-index'));
            copyText(buildPrompt([allRecs[idx]]), btn);
          });
        });

        // Copy selected
        document.getElementById('copy-selected-recs')?.addEventListener('click', function() {
          const checked = document.querySelectorAll('.rec-checkbox:checked');
          if (checked.length === 0) {
            // If none selected, copy all visible
            const visible = [];
            document.querySelectorAll('.rec-item').forEach((item, i) => {
              if (item.style.display !== 'none') {
                visible.push(allRecs[parseInt(item.getAttribute('data-rec-index'))]);
              }
            });
            if (visible.length > 0) copyText(buildPrompt(visible), this);
          } else {
            const selected = [];
            checked.forEach(cb => {
              const idx = parseInt(cb.getAttribute('data-index'));
              selected.push(allRecs[idx]);
            });
            copyText(buildPrompt(selected), this);
          }
        });

        // Persistent state via localStorage
        var storageKey = 'rec-state-' + window.location.pathname.replace(/\/$/, '');
        var recState = {};
        try { recState = JSON.parse(localStorage.getItem(storageKey) || '{}'); } catch(e) {}

        function saveRecState() {
          localStorage.setItem(storageKey, JSON.stringify(recState));
          updateRecStats();
        }

        function updateRecStats() {
          var dismissed = Object.keys(recState);
          var counts = { critical: 0, high: 0, medium: 0, low: 0 };
          dismissed.forEach(function(idx) {
            var item = document.querySelector('.rec-item[data-rec-index="' + idx + '"]');
            if (item) {
              var p = item.getAttribute('data-rec-priority');
              if (p) counts[p] = (counts[p] || 0) + 1;
            }
          });
          var origCrit = parseInt(allRecs.filter(function(r) { return r.priority === 'critical'; }).length);
          var origHigh = parseInt(allRecs.filter(function(r) { return r.priority === 'high'; }).length);
          var origMed = parseInt(allRecs.filter(function(r) { return r.priority === 'medium'; }).length);
          var origLow = parseInt(allRecs.filter(function(r) { return r.priority === 'low'; }).length);

          var el;
          el = document.getElementById('rec-stat-critical');
          if (el) el.textContent = origCrit - (counts.critical || 0);
          el = document.getElementById('rec-stat-high');
          if (el) el.textContent = origHigh - (counts.high || 0);
          el = document.getElementById('rec-stat-medium');
          if (el) el.textContent = origMed - (counts.medium || 0);
          el = document.getElementById('rec-stat-low');
          if (el) el.textContent = origLow - (counts.low || 0);

          // Update filter button labels
          document.querySelectorAll('.rec-filter').forEach(function(btn) {
            var f = btn.getAttribute('data-filter');
            if (f === 'all') btn.textContent = 'All (' + (allRecs.length - dismissed.length) + ')';
            if (f === 'critical') btn.textContent = 'Critical (' + (origCrit - (counts.critical || 0)) + ')';
            if (f === 'high') btn.textContent = 'High (' + (origHigh - (counts.high || 0)) + ')';
            if (f === 'medium') btn.textContent = 'Medium (' + (origMed - (counts.medium || 0)) + ')';
            if (f === 'low') btn.textContent = 'Low (' + (origLow - (counts.low || 0)) + ')';
          });
        }

        function applyState(item, index) {
          var state = recState[index];
          if (!state) return;
          if (state === 'done') {
            item.style.opacity = '0.4';
            item.style.borderColor = '#166534';
            item.querySelector('.done-rec-btn').textContent = 'Done';
            item.querySelector('.done-rec-btn').style.background = '#166534';
            item.querySelector('.done-rec-btn').style.color = '#86efac';
            item.dataset.done = 'true';
          } else if (state === 'parked') {
            item.style.opacity = '0.3';
            item.style.borderColor = '#854d0e';
            item.querySelector('.park-rec-btn').textContent = 'Parked';
            item.querySelector('.park-rec-btn').style.background = '#854d0e';
            item.querySelector('.park-rec-btn').style.color = '#fde047';
            item.dataset.parked = 'true';
          } else if (state === 'na') {
            item.style.opacity = '0.2';
            item.style.borderColor = '#374151';
            item.querySelector('.na-rec-btn').textContent = 'Removed';
            item.querySelector('.na-rec-btn').style.background = '#374151';
            item.querySelector('.na-rec-btn').style.color = '#9ca3af';
            item.dataset.na = 'true';
          }
        }

        // Apply saved state on load
        document.querySelectorAll('.rec-item').forEach(function(item) {
          var index = item.getAttribute('data-rec-index');
          applyState(item, index);
        });

        // Update stats to reflect dismissed items
        updateRecStats();

        // Done button
        document.querySelectorAll('.done-rec-btn').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var item = btn.closest('.rec-item');
            var index = item.getAttribute('data-rec-index');
            if (recState[index] === 'done') {
              delete recState[index];
              item.style.opacity = '1';
              item.style.borderColor = '';
              btn.textContent = 'Done';
              btn.style.background = '';
              btn.style.color = '';
              item.dataset.done = 'false';
            } else {
              recState[index] = 'done';
              item.style.opacity = '0.4';
              item.style.borderColor = '#166534';
              btn.textContent = 'Done';
              btn.style.background = '#166534';
              btn.style.color = '#86efac';
              item.dataset.done = 'true';
              // Reset others
              item.querySelector('.park-rec-btn').textContent = 'Park';
              item.querySelector('.park-rec-btn').style.background = '';
              item.querySelector('.park-rec-btn').style.color = '';
              item.querySelector('.na-rec-btn').textContent = 'Remove';
              item.querySelector('.na-rec-btn').style.background = '';
              item.querySelector('.na-rec-btn').style.color = '';
            }
            saveRecState();
          });
        });

        // Park button
        document.querySelectorAll('.park-rec-btn').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var item = btn.closest('.rec-item');
            var index = item.getAttribute('data-rec-index');
            if (recState[index] === 'parked') {
              delete recState[index];
              item.style.opacity = '1';
              item.style.borderColor = '';
              btn.textContent = 'Park';
              btn.style.background = '';
              btn.style.color = '';
              item.dataset.parked = 'false';
            } else {
              recState[index] = 'parked';
              item.style.opacity = '0.3';
              item.style.borderColor = '#854d0e';
              btn.textContent = 'Parked';
              btn.style.background = '#854d0e';
              btn.style.color = '#fde047';
              item.dataset.parked = 'true';
              // Reset others
              item.querySelector('.done-rec-btn').textContent = 'Done';
              item.querySelector('.done-rec-btn').style.background = '';
              item.querySelector('.done-rec-btn').style.color = '';
              item.querySelector('.na-rec-btn').textContent = 'Remove';
              item.querySelector('.na-rec-btn').style.background = '';
              item.querySelector('.na-rec-btn').style.color = '';
            }
            saveRecState();
          });
        });

        // N/A (Not Applicable) button
        document.querySelectorAll('.na-rec-btn').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var item = btn.closest('.rec-item');
            var index = item.getAttribute('data-rec-index');
            if (recState[index] === 'na') {
              delete recState[index];
              item.style.opacity = '1';
              item.style.borderColor = '';
              btn.textContent = 'Remove';
              btn.style.background = '';
              btn.style.color = '';
              item.dataset.na = 'false';
            } else {
              recState[index] = 'na';
              item.style.opacity = '0.2';
              item.style.borderColor = '#374151';
              btn.textContent = 'Removed';
              btn.style.background = '#374151';
              btn.style.color = '#9ca3af';
