---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import SiteTree from '../../../components/SiteTree.jsx';
import LinkGraph from '../../../components/LinkGraph.jsx';
import clients from '../../../data/clients.json';
import sections from '../../../data/sections.json';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const paths: any[] = [];
  for (const c of clients) {
    for (const s of sections) {
      paths.push({ params: { client: c.id, section: s.id } });
    }
  }
  return paths;
}

const { client: clientId, section: sectionId } = Astro.params;
const client = clients.find((c) => c.id === clientId);
const section = sections.find((s) => s.id === sectionId);

if (!client || !section) {
  return Astro.redirect('/');
}

function loadJson(filename: string) {
  try {
    const filePath = path.join(process.cwd(), 'src', 'data', 'live', filename);
    if (fs.existsSync(filePath)) {
      return JSON.parse(fs.readFileSync(filePath, 'utf-8'));
    }
  } catch {}
  return null;
}

const ga4All = loadJson('ga4.json');
const gscAll = loadJson('gsc.json');
const bingAll = loadJson('bing.json');
const serpAll = loadJson('serp_data.json');
const competitorAll = loadJson('competitor_serp.json');
const recsAll = loadJson('recommendations.json');
const newPagesAll = loadJson('new_pages.json');
const citationPrompts = loadJson('citation_prompts.json');
const citationResults = loadJson('citation_results.json');
const siteConfigAll = loadJson('../site-config.json');
const siteConf = siteConfigAll?.[clientId];
const dailyHistory = loadJson('daily_history.json');
const crawlData = loadJson(`crawl_${clientId}.json`);
const uptimeAll = loadJson('uptime.json');
const uptimeHistory = loadJson('uptime_history.json');
const citationsAll = loadJson('citations_by_type.json');
const citByTypeAll = loadJson('citations_by_type.json');
const auditAll = loadJson('ai_audit.json');
const pagespeedAll = loadJson('pagespeed.json');
const crawlActivityAll = loadJson('crawl_activity.json');
const kgAll = loadJson('knowledge_graph.json');
const nlpAll = loadJson('nlp_entities.json');

const ga4 = ga4All?.[clientId];
const gsc = gscAll?.[clientId];
const bing = bingAll?.[clientId];
const serp = serpAll?.[clientId];
const competitors = competitorAll?.[clientId];
const recs = recsAll?.[clientId];
const newPagesDetail = newPagesAll?.[clientId];
const citResults = citationResults?.[clientId];
const prompts = citationPrompts?.[clientId];
const history = dailyHistory?.[clientId] || [];
const uptime = uptimeAll?.[clientId];
const citations = citationsAll?.[clientId];
const citByType = citByTypeAll?.[clientId];
const audit = auditAll?.[clientId];
const pagespeed = pagespeedAll?.[clientId];
const crawlActivityDetail = crawlActivityAll?.[clientId];
const kg = kgAll?.[clientId];
const nlp = nlpAll?.[clientId];

// Prepare chart data as JSON strings for client-side JS
const dailyTraffic = JSON.stringify(ga4?.daily || []);
const topPages = JSON.stringify(ga4?.top_pages || []);
const sources = JSON.stringify(ga4?.sources || []);
const countries = JSON.stringify(ga4?.countries || []);
const topQueries = JSON.stringify(gsc?.top_queries || []);
const gscPages = JSON.stringify(gsc?.top_pages || []);
const contentGaps = JSON.stringify(gsc?.content_gaps || []);
const crawlPages = JSON.stringify(crawlData?.pages || []);
const crawlIssues = JSON.stringify(crawlData?.issues || []);
const crawlLinks = JSON.stringify(crawlData?.links?.slice(0, 200) || []);
const positiveSignals = JSON.stringify(crawlData?.positive_signals || []);
const citationResultsJson = JSON.stringify(citations?.results || []);
const uptimeChecks = JSON.stringify(uptimeHistory?.[clientId] || []);
const crawlDaily = JSON.stringify(crawlActivityDetail?.bing_crawl_daily || []);
---

<DashboardLayout title={`${section.label} — ${client.name}`} currentClient={clientId} view="agency">
  <div class="mb-6">
    <a href={`/agency/${clientId}`} class="text-sm text-gray-400 hover:text-gray-300 transition">
      &larr; Back to {client.name}
    </a>
  </div>

  <h1 class="text-2xl font-bold text-white mb-1">{section.label}</h1>
  <p class="text-sm text-gray-400 mb-6">{client.name} — {client.domain}</p>

  <!-- TRAFFIC -->
  {sectionId === 'traffic' && ga4 && (
    <div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{ga4.overview.active_users.toLocaleString()}</div>
          <div class="text-xs text-gray-500">Active Users</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{ga4.overview.sessions.toLocaleString()}</div>
          <div class="text-xs text-gray-500">Sessions</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{ga4.overview.pageviews.toLocaleString()}</div>
          <div class="text-xs text-gray-500">Pageviews</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{ga4.overview.bounce_rate}%</div>
          <div class="text-xs text-gray-500">Bounce Rate</div>
        </div>
      </div>

      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6 mb-6">
        <h3 class="text-sm font-semibold text-gray-400 mb-4">Daily Users (Last 30 Days)</h3>
        <canvas id="trafficChart" height="250"></canvas>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
          <h3 class="text-sm font-semibold text-gray-400 mb-4">Top Pages</h3>
          <div class="space-y-2">
            {ga4.top_pages.slice(0, 10).map((p: any) => (
              <div class="flex justify-between text-xs border-b border-gray-800 pb-2">
                <span class="text-gray-300 truncate max-w-[250px]">{p.path}</span>
                <span class="text-white font-medium">{p.pageviews} views</span>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
          <h3 class="text-sm font-semibold text-gray-400 mb-4">Traffic Sources</h3>
          <div class="space-y-2">
            {ga4.sources.map((s: any) => (
              <div class="flex justify-between text-xs border-b border-gray-800 pb-2">
                <span class="text-gray-300">{s.channel}</span>
                <span class="text-white font-medium">{s.sessions} sessions</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6 mt-6">
        <h3 class="text-sm font-semibold text-gray-400 mb-4">Top Countries</h3>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
          {ga4.countries.slice(0, 10).map((c: any) => (
            <div class="text-center p-3 bg-gray-800 rounded-lg">
              <div class="text-white font-medium text-sm">{c.users}</div>
              <div class="text-xs text-gray-500">{c.country}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- CONTENT GAPS -->
  {sectionId === 'content-gaps' && gsc && (
    <div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{gsc.totals?.clicks || 0}</div>
          <div class="text-xs text-gray-500">Total Clicks</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{gsc.totals?.impressions?.toLocaleString() || 0}</div>
          <div class="text-xs text-gray-500">Impressions</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{gsc.totals?.ctr || 0}%</div>
          <div class="text-xs text-gray-500">CTR</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{gsc.totals?.position || 0}</div>
          <div class="text-xs text-gray-500">Avg Position</div>
        </div>
      </div>

      {gsc.content_gaps?.length > 0 && (
        <div class="bg-gray-900 border border-yellow-800/50 rounded-lg p-6 mb-6">
          <h3 class="text-sm font-semibold text-yellow-400 mb-4">Content Gaps — High Impressions, Low Clicks</h3>
          <div class="overflow-x-auto">
            <table class="w-full text-xs">
              <thead>
                <tr class="text-gray-500 border-b border-gray-800">
                  <th class="text-left py-2 px-3">Query</th>
                  <th class="text-right py-2 px-3">Impressions</th>
                  <th class="text-right py-2 px-3">Clicks</th>
                  <th class="text-right py-2 px-3">CTR</th>
                  <th class="text-right py-2 px-3">Position</th>
                </tr>
              </thead>
              <tbody>
                {gsc.content_gaps.map((g: any) => (
                  <tr class="border-b border-gray-800/50">
                    <td class="py-2 px-3 text-gray-300">{g.query}</td>
                    <td class="py-2 px-3 text-right text-white">{g.impressions}</td>
                    <td class="py-2 px-3 text-right text-white">{g.clicks}</td>
                    <td class="py-2 px-3 text-right text-yellow-400">{g.ctr}%</td>
                    <td class="py-2 px-3 text-right text-gray-400">{g.position}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
        <h3 class="text-sm font-semibold text-gray-400 mb-4">Top Queries</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-xs">
            <thead>
              <tr class="text-gray-500 border-b border-gray-800">
                <th class="text-left py-2 px-3">Query</th>
                <th class="text-right py-2 px-3">Clicks</th>
                <th class="text-right py-2 px-3">Impressions</th>
                <th class="text-right py-2 px-3">CTR</th>
                <th class="text-right py-2 px-3">Position</th>
              </tr>
            </thead>
            <tbody>
              {gsc.top_queries.map((q: any) => (
                <tr class="border-b border-gray-800/50">
                  <td class="py-2 px-3 text-gray-300">{q.query}</td>
                  <td class="py-2 px-3 text-right text-white">{q.clicks}</td>
                  <td class="py-2 px-3 text-right text-white">{q.impressions}</td>
                  <td class="py-2 px-3 text-right text-blue-400">{q.ctr}%</td>
                  <td class="py-2 px-3 text-right text-gray-400">{q.position}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  )}

  <!-- SEO HEALTH -->
  {sectionId === 'seo-health' && crawlData && (
    <div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{crawlData.pages_crawled}</div>
          <div class="text-xs text-gray-500">Pages Crawled</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-yellow-400">{crawlData.total_issues}</div>
          <div class="text-xs text-gray-500">Issues Found</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-green-400">{crawlData.pages_with_schema}</div>
          <div class="text-xs text-gray-500">With Schema</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{crawlData.avg_word_count}</div>
          <div class="text-xs text-gray-500">Avg Word Count</div>
        </div>
      </div>

      {crawlData.issues.length > 0 && (
        <div class="bg-gray-900 border border-yellow-800/50 rounded-lg p-6 mb-6">
          <h3 class="text-sm font-semibold text-yellow-400 mb-4">Issues</h3>
          <div class="overflow-x-auto max-h-96 overflow-y-auto">
            <table class="w-full text-xs">
              <thead class="sticky top-0 bg-gray-900">
                <tr class="text-gray-500 border-b border-gray-800">
                  <th class="text-left py-2 px-3">Type</th>
                  <th class="text-left py-2 px-3">URL</th>
                  <th class="text-left py-2 px-3">Detail</th>
                </tr>
              </thead>
              <tbody>
                {crawlData.issues.map((issue: any) => (
                  <tr class="border-b border-gray-800/50">
                    <td class="py-2 px-3 text-yellow-400 whitespace-nowrap">{issue.type.replace(/_/g, ' ')}</td>
                    <td class="py-2 px-3 text-gray-300 truncate max-w-[300px]">{new URL(issue.url).pathname}</td>
                    <td class="py-2 px-3 text-gray-500">{issue.detail}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
        <h3 class="text-sm font-semibold text-gray-400 mb-4">All Pages</h3>
        <div class="overflow-x-auto max-h-[500px] overflow-y-auto">
          <table class="w-full text-xs">
            <thead class="sticky top-0 bg-gray-900">
              <tr class="text-gray-500 border-b border-gray-800">
                <th class="text-left py-2 px-3">Path</th>
                <th class="text-left py-2 px-3">H1</th>
                <th class="text-right py-2 px-3">Words</th>
                <th class="text-right py-2 px-3">Links In</th>
                <th class="text-right py-2 px-3">Depth</th>
                <th class="text-left py-2 px-3">Schema</th>
              </tr>
            </thead>
            <tbody>
              {crawlData.pages.slice(0, 100).map((p: any) => (
                <tr class="border-b border-gray-800/50">
                  <td class="py-2 px-3 text-gray-300 truncate max-w-[200px]">{p.path}</td>
                  <td class="py-2 px-3 text-gray-400 truncate max-w-[200px]">{p.h1 || '—'}</td>
                  <td class="py-2 px-3 text-right text-white">{p.word_count}</td>
                  <td class="py-2 px-3 text-right text-white">{p.internal_links_in}</td>
                  <td class="py-2 px-3 text-right text-gray-400">{p.depth}</td>
                  <td class="py-2 px-3 text-green-400 text-[10px]">{p.schemas?.join(', ') || '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  )}

  <!-- AI CITATIONS — Clean rebuild -->
  {sectionId === 'ai-citations' && (
    <div>
      <!-- Bing Copilot banner -->
      {bing?.top_queries?.length > 0 && (
        <div class="bg-blue-950/30 border border-blue-800/50 rounded-lg p-4 mb-6 flex items-center justify-between">
          <div>
            <span class="text-sm text-blue-300 font-medium">Bing Copilot</span>
            <span class="text-xs text-gray-500 ml-2">Live AI citations from Microsoft</span>
          </div>
          <div class="flex items-center gap-4">
            <div class="text-right">
              <div class="text-xl font-bold text-blue-400">{bing.top_queries.reduce((sum: number, q: any) => sum + (q.Impressions || 0), 0)}</div>
              <div class="text-[10px] text-gray-500">Impressions</div>
            </div>
          </div>
        </div>
      )}

      <!-- Summary stats from baseline results -->
      {citResults?.summary ? (
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
          <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
            <div class={`text-2xl font-bold ${citResults.summary.claude.rate > 20 ? 'text-green-400' : citResults.summary.claude.rate > 0 ? 'text-yellow-400' : 'text-red-400'}`}>{citResults.summary.claude.rate}%</div>
            <div class="text-xs text-gray-500">Claude</div>
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
            <div class={`text-2xl font-bold ${citResults.summary.chatgpt.rate > 20 ? 'text-green-400' : citResults.summary.chatgpt.rate > 0 ? 'text-yellow-400' : 'text-red-400'}`}>{citResults.summary.chatgpt.rate}%</div>
            <div class="text-xs text-gray-500">ChatGPT</div>
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
            <div class={`text-2xl font-bold ${citResults.summary.gemini.rate > 20 ? 'text-green-400' : citResults.summary.gemini.rate > 0 ? 'text-yellow-400' : 'text-red-400'}`}>{citResults.summary.gemini.rate}%</div>
            <div class="text-xs text-gray-500">Gemini</div>
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
            <div class="text-2xl font-bold text-white">{citResults.total_prompts}</div>
            <div class="text-xs text-gray-500">Prompts Tested</div>
          </div>
        </div>
      ) : citByType ? (
        <div class="grid grid-cols-2 gap-4 mb-6">
          <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
            <div class={`text-2xl font-bold ${citByType.overall_rate >= 10 ? 'text-yellow-400' : 'text-red-400'}`}>{citByType.overall_rate}%</div>
            <div class="text-xs text-gray-500">Claude (old test)</div>
          </div>
        </div>
      ) : null}

      <!-- Results by category (from baseline results) -->
      {citResults?.by_category && (
        <div class="mb-6">
          <h3 class="text-sm font-semibold text-gray-400 mb-4">Results by Category</h3>
          <div class="space-y-3">
            {Object.entries(citResults.by_category).map(([cat, data]: [string, any]) => (
              <div class="flex items-center gap-4">
                <span class="text-xs text-gray-400 w-28 capitalize">{cat.replace(/_/g, ' ')}</span>
                <div class="flex-1 grid grid-cols-3 gap-2">
                  <div class="bg-gray-800 rounded h-6 flex items-center px-2">
                    <span class={`text-[10px] ${data.claude_rate > 0 ? 'text-green-400' : 'text-red-400'}`}>C: {data.claude_rate}%</span>
                  </div>
                  <div class="bg-gray-800 rounded h-6 flex items-center px-2">
                    <span class={`text-[10px] ${data.chatgpt_rate > 0 ? 'text-green-400' : 'text-red-400'}`}>G: {data.chatgpt_rate}%</span>
                  </div>
                  <div class="bg-gray-800 rounded h-6 flex items-center px-2">
                    <span class={`text-[10px] ${data.gemini_rate > 0 ? 'text-green-400' : 'text-red-400'}`}>Gm: {data.gemini_rate}%</span>
                  </div>
                </div>
                <span class="text-xs text-gray-500 w-12 text-right">{data.total}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Individual results -->
      {citResults?.results && (
        <div class="mb-6">
          <h3 class="text-sm font-semibold text-gray-400 mb-4">Individual Results ({citResults.results.length} tested)</h3>
          <div class="space-y-2 max-h-[500px] overflow-y-auto">
            {citResults.results.map((r: any) => (
              <div class={`flex items-center gap-3 p-3 rounded-lg border ${(r.claude?.cited || r.chatgpt?.cited || r.gemini?.cited) ? 'border-green-800/50 bg-green-950/10' : 'border-gray-800 bg-gray-900'}`}>
                <span class="text-[10px] px-1.5 py-0.5 rounded bg-gray-800 text-gray-400 flex-shrink-0">{r.type}</span>
                <span class="text-xs text-gray-300 flex-1">{r.query}</span>
                {r.page_url && <span class="text-[10px] text-blue-400/50">→ {r.page_url}</span>}
                <span class={`text-[10px] ${r.claude?.cited ? 'text-green-400' : 'text-red-400'}`}>C:{r.claude?.cited ? 'Y' : 'N'}</span>
                <span class={`text-[10px] ${r.chatgpt?.cited ? 'text-green-400' : 'text-red-400'}`}>G:{r.chatgpt?.cited ? 'Y' : 'N'}</span>
                <span class={`text-[10px] ${r.gemini?.cited ? 'text-green-400' : 'text-red-400'}`}>Gm:{r.gemini?.cited ? 'Y' : 'N'}</span>
              </div>
            ))}
          </div>
          {citResults.tested_at && (
            <p class="text-[10px] text-gray-600 mt-2">Last tested: {new Date(citResults.tested_at).toLocaleDateString('en-GB', {day:'numeric', month:'long', year:'numeric', hour:'2-digit', minute:'2-digit'})}</p>
          )}
        </div>
      )}

      <!-- Competitor mentions (from old data if available) -->
      {citByType?.top_competitors?.length > 0 && (
        <div class="bg-gray-900 border border-red-800/30 rounded-lg p-6 mb-6">
          <h3 class="text-sm font-semibold text-red-400 mb-4">Who Gets Mentioned Instead</h3>
          <div class="space-y-2">
            {citByType.top_competitors.map((c: any) => (
              <div class="flex items-center gap-4">
                <span class="text-sm text-white w-40">{c.name}</span>
                <div class="flex-1 bg-gray-800 rounded-full h-5 overflow-hidden">
                  <div class="h-full bg-red-600/60 rounded-full flex items-center px-2 text-[10px] text-white" style={`width: ${Math.max((c.mentions / (citByType.total_queries || 1)) * 100, 5)}%`}>
                    {c.mentions}x
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  )}


  <!-- SITE MANAGER -->
  {sectionId === 'site-manager' && crawlData && (
    <div data-site-repo={siteConf?.repo || ''}>
      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{crawlData.pages_crawled}</div>
          <div class="text-xs text-gray-500">Total Pages</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{crawlData.topic_cluster_count || 0}</div>
          <div class="text-xs text-gray-500">Sections</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-green-400">{crawlData.pages_with_schema}</div>
          <div class="text-xs text-gray-500">With Schema</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{crawlData.avg_word_count}</div>
          <div class="text-xs text-gray-500">Avg Words</div>
        </div>
      </div>

      <!-- Content types grid -->
      {siteConf?.page_types && (
        <div class="mb-6">
          <h3 class="text-sm font-semibold text-gray-400 mb-3">Content Types</h3>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            {Object.entries(siteConf.page_types).map(([key, type]: [string, any]) => {
              const count = crawlData.pages?.filter((p: any) => p.path?.startsWith(`/${type.path}`)).length || 0;
              return (
                <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-blue-500/50 transition cursor-pointer" data-filter-type={type.path}>
                  <div class="text-lg font-bold text-white">{count}</div>
                  <div class="text-xs text-gray-400">{type.label}</div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      <!-- Create New Page -->
      {siteConf?.repo && (
        <div class="bg-gray-900 border border-dashed border-green-800/50 rounded-lg p-6 mb-6">
          <h3 class="text-sm font-semibold text-green-400 mb-4">Create New Page</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="text-[10px] text-gray-500 uppercase block mb-1">Page Type</label>
              <select id="new-page-type" class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-xs text-white">
                {Object.entries(siteConf.page_types || {}).map(([key, type]: [string, any]) => (
                  <option value={key}>{type.label}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="text-[10px] text-gray-500 uppercase block mb-1">URL Slug</label>
              <input id="new-page-slug" type="text" placeholder="my-new-page" class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-xs text-white placeholder-gray-600" />
            </div>
            <div class="md:col-span-2">
              <label class="text-[10px] text-gray-500 uppercase block mb-1">Page Title (H1)</label>
              <input id="new-page-title" type="text" placeholder="Your Page Title Here" class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-xs text-white placeholder-gray-600" />
            </div>
            <div class="md:col-span-2">
              <label class="text-[10px] text-gray-500 uppercase block mb-1">Meta Description</label>
              <textarea id="new-page-desc" rows="2" placeholder="150-160 character description for search results..." class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-xs text-white placeholder-gray-600"></textarea>
            </div>
            <div class="md:col-span-2">
              <label class="text-[10px] text-gray-500 uppercase block mb-1">Content (HTML)</label>
              <textarea id="new-page-content" rows="8" placeholder="<p>Your content here...</p>" class="w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-xs text-white placeholder-gray-600 font-mono"></textarea>
            </div>
            <div class="md:col-span-2 flex items-center gap-3">
              <button id="create-page-btn" class="px-4 py-2 rounded text-xs bg-green-600 text-white hover:bg-green-500 transition font-medium">
                Create Page
              </button>
              <span id="create-status" class="text-xs text-gray-500"></span>
            </div>
          </div>
        </div>
      )}

      <!-- Site tree -->
      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6 mb-6">
        <h3 class="text-sm font-semibold text-gray-400 mb-4">Site Structure</h3>
        <SiteTree tree={crawlData.tree} client:load />
      </div>

      <!-- Page inventory with search -->
      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold text-gray-400">All Pages ({crawlData.pages_crawled})</h3>
          <input
            type="text"
            placeholder="Search pages..."
            class="bg-gray-800 border border-gray-700 rounded px-3 py-1.5 text-xs text-white placeholder-gray-500 focus:border-blue-500 focus:outline-none w-48"
            id="page-search"
          />
        </div>
        <div class="overflow-x-auto max-h-[600px] overflow-y-auto" id="page-list">
          <table class="w-full text-xs">
            <thead class="sticky top-0 bg-gray-900">
              <tr class="text-gray-500 border-b border-gray-800">
                <th class="text-left py-2 px-3 cursor-pointer hover:text-white" data-sort="path">Path</th>
                <th class="text-left py-2 px-3 cursor-pointer hover:text-white" data-sort="h1">H1</th>
                <th class="text-left py-2 px-3 cursor-pointer hover:text-white" data-sort="title">Title</th>
                <th class="text-right py-2 px-3 cursor-pointer hover:text-white" data-sort="words">Words</th>
                <th class="text-center py-2 px-3">Schema</th>
                <th class="text-right py-2 px-3 cursor-pointer hover:text-white" data-sort="links">Links In</th>
                <th class="text-right py-2 px-3">Depth</th>
              </tr>
            </thead>
            <tbody>
              {crawlData.pages?.sort((a: any, b: any) => a.path.localeCompare(b.path)).map((p: any) => (
                <tr class="border-b border-gray-800/50 hover:bg-gray-800/30 page-row" data-path={p.path}>
                  <td class="py-2 px-3 text-blue-400 truncate max-w-[180px]">
                    <a href={p.url} target="_blank" class="hover:underline">{p.path}</a>
                  </td>
                  <td class={`py-2 px-3 truncate max-w-[200px] ${p.h1 ? 'text-gray-300' : 'text-red-400'}`}>{p.h1 || 'MISSING'}</td>
                  <td class="py-2 px-3 text-gray-500 truncate max-w-[200px]">{p.title?.slice(0, 50)}</td>
                  <td class={`py-2 px-3 text-right ${p.word_count < 100 ? 'text-red-400' : p.word_count >= 2000 ? 'text-green-400' : 'text-white'}`}>{p.word_count}</td>
                  <td class="py-2 px-3 text-center">{p.schemas?.length > 0 ? <span class="text-green-400 text-[10px]">{p.schemas.join(', ')}</span> : <span class="text-red-400">None</span>}</td>
                  <td class="py-2 px-3 text-right text-white">{p.internal_links_in || 0}</td>
                  <td class="py-2 px-3 text-right text-gray-400">{p.depth || 0}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Search filter script -->
      <script>
        document.getElementById('page-search')?.addEventListener('input', (e) => {
          const query = e.target.value.toLowerCase();
          document.querySelectorAll('.page-row').forEach(row => {
            const path = row.getAttribute('data-path')?.toLowerCase() || '';
            const h1 = row.querySelector('td:nth-child(2)')?.textContent?.toLowerCase() || '';
            row.style.display = (path.includes(query) || h1.includes(query)) ? '' : 'none';
          });
        });

        // Content type filter
        document.querySelectorAll('[data-filter-type]').forEach(card => {
          card.addEventListener('click', () => {
            const type = card.getAttribute('data-filter-type');
            document.querySelectorAll('.page-row').forEach(row => {
              const path = row.getAttribute('data-path') || '';
              row.style.display = path.startsWith('/' + type) ? '' : 'none';
            });
            // Clear search
            const search = document.getElementById('page-search');
            if (search) search.value = type;
          });
        });

        const workerUrl = 'https://rank4ai-tracker.dawn-field-3d16.workers.dev';
        const siteRepo = document.querySelector('[data-site-repo]')?.getAttribute('data-site-repo') || '';

        // Create new page handler
        document.getElementById('create-page-btn')?.addEventListener('click', async function() {
          var pageType = document.getElementById('new-page-type').value;
          var slug = document.getElementById('new-page-slug').value.trim();
          var title = document.getElementById('new-page-title').value.trim();
          var desc = document.getElementById('new-page-desc').value.trim();
          var content = document.getElementById('new-page-content').value;
          var status = document.getElementById('create-status');

          if (!slug || !title) {
            status.textContent = 'Slug and title required';
            status.style.color = '#ef4444';
            return;
          }

          // Clean slug
          slug = slug.toLowerCase().replace(/[^a-z0-9-]/g, '-').replace(/-+/g, '-');

          this.textContent = 'Creating...';
          this.disabled = true;

          // Build the page content from template
          var today = new Date().toISOString().slice(0, 10);
          var pageContent = '---\n';
          pageContent += "import BaseLayout from '../../layouts/BaseLayout.astro';\n";
          pageContent += "import Breadcrumbs from '../../components/Breadcrumbs.astro';\n";
          pageContent += "import LeadForm from '../../components/LeadForm.astro';\n\n";
          pageContent += 'const title = "' + title.replace(/"/g, '\\"') + '";\n';
          pageContent += 'const description = "' + desc.replace(/"/g, '\\"') + '";\n';
          pageContent += '\nconst schema = {\n';
          pageContent += '  "@context": "https://schema.org",\n';
          pageContent += '  "@type": "Article",\n';
          pageContent += '  "headline": "' + title.replace(/"/g, '\\"') + '",\n';
          pageContent += '  "description": description,\n';
          pageContent += '  "datePublished": "' + today + '",\n';
          pageContent += '  "dateModified": "' + today + '",\n';
          pageContent += '  "author": { "@type": "Organization", "name": "Market Invoice" },\n';
          pageContent += '  "publisher": { "@type": "Organization", "name": "Market Invoice", "url": "https://marketinvoice.co.uk" }\n';
          pageContent += '};\n';
          pageContent += '---\n\n';
          pageContent += '<BaseLayout title={title} description={description} schema={schema}>\n';
          pageContent += '  <article class="max-w-3xl mx-auto px-4 py-12 md:py-16">\n';
          pageContent += '    <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "' + pageType + '", href: "/' + pageType + '/" }, { label: title.slice(0,30) }]} />\n\n';
          pageContent += '    <h1 class="text-3xl md:text-4xl font-bold mb-6">' + title + '</h1>\n\n';
          if (content) {
            pageContent += '    ' + content + '\n\n';
          } else {
            pageContent += '    <p class="text-lg text-gray-700 leading-relaxed mb-6">Content coming soon.</p>\n\n';
          }
          pageContent += '    <LeadForm />\n';
          pageContent += '  </article>\n';
          pageContent += '</BaseLayout>\n';

          // Determine file path
          var filePath = 'src/pages/' + pageType + '/' + slug + '.astro';

          try {
            var resp = await fetch(workerUrl + '/api/file', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                repo: siteRepo,
                path: filePath,
                content: pageContent,
                message: 'Create ' + pageType + ': ' + title + ' via dashboard',
              }),
            });

            if (resp.ok) {
              status.textContent = 'Created! Auto-deploying...';
              status.style.color = '#22c55e';
              this.textContent = 'Created!';
              this.style.background = '#22c55e';
              // Clear form
              document.getElementById('new-page-slug').value = '';
              document.getElementById('new-page-title').value = '';
              document.getElementById('new-page-desc').value = '';
              document.getElementById('new-page-content').value = '';
            } else {
              var err = await resp.json();
              status.textContent = 'Error: ' + (err.error || 'Failed');
              status.style.color = '#ef4444';
              this.textContent = 'Error';
              this.style.background = '#ef4444';
            }
          } catch (err) {
            status.textContent = 'Error: ' + err.message;
            status.style.color = '#ef4444';
          }

          var btn = this;
          setTimeout(function() { btn.textContent = 'Create Page'; btn.style.background = ''; btn.disabled = false; }, 3000);
        });

        // Click page row to open editor
        document.querySelectorAll('.page-row').forEach(function(row) {
          row.addEventListener('click', async function(e) {
            if (e.target.tagName === 'A') return;
            var pagePath = row.getAttribute('data-path');
            var editorPanel = document.getElementById('page-editor');
            if (!editorPanel) return;

            editorPanel.classList.remove('hidden');
            editorPanel.textContent = 'Loading...';

            var filePath = 'src/pages' + pagePath.replace(/\/$/, '') + (pagePath.endsWith('/') ? '/index.astro' : '.astro');

            try {
              var resp = await fetch(workerUrl + '/api/file?repo=' + encodeURIComponent(siteRepo) + '&path=' + encodeURIComponent(filePath));
              if (!resp.ok) throw new Error('HTTP ' + resp.status);
              var data = await resp.json();
              var content = data.content;

              // Parse title, description, and H1 from content
              var titleMatch = content.match(/(?:const\s+)?title\s*=\s*["'](.*?)["']/);
              var descMatch = content.match(/(?:const\s+)?description\s*=\s*["'](.*?)["']/);
              var h1Match = content.match(/<h1[^>]*>(.*?)<\/h1>/);
              var title = titleMatch ? titleMatch[1] : '';
              var desc = descMatch ? descMatch[1] : '';
              var h1 = h1Match ? h1Match[1].replace(/<[^>]+>/g, '') : '';

              // Build editor UI
              editorPanel.innerHTML = '';

              var header = document.createElement('div');
              header.className = 'flex items-center justify-between mb-4';
              header.innerHTML = '<h3 class="text-sm font-semibold text-white">' + pagePath + '</h3><button id="close-editor" class="text-gray-500 hover:text-white text-xs">Close</button>';
              editorPanel.appendChild(header);

              // Title field
              var titleDiv = document.createElement('div');
              titleDiv.className = 'mb-3';
              titleDiv.innerHTML = '<label class="text-[10px] text-gray-500 uppercase block mb-1">Title Tag (' + title.length + ' chars)</label>';
              var titleInput = document.createElement('input');
              titleInput.type = 'text';
              titleInput.value = title;
              titleInput.className = 'w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-xs text-white';
              titleInput.id = 'edit-title';
              titleDiv.appendChild(titleInput);
              editorPanel.appendChild(titleDiv);

              // H1 display (read-only — H1 is in the template HTML)
              if (h1) {
                var h1Div = document.createElement('div');
                h1Div.className = 'mb-3';
                h1Div.innerHTML = '<label class="text-[10px] text-gray-500 uppercase block mb-1">H1 Tag</label><div class="px-3 py-2 bg-gray-800/50 border border-gray-700 rounded text-xs text-gray-300">' + h1 + '</div>';
                editorPanel.appendChild(h1Div);
              }

              // Description field
              var descDiv = document.createElement('div');
              descDiv.className = 'mb-3';
              descDiv.innerHTML = '<label class="text-[10px] text-gray-500 uppercase block mb-1">Meta Description (' + desc.length + ' chars)</label>';
              var descArea = document.createElement('textarea');
              descArea.rows = 3;
              descArea.value = desc;
              descArea.className = 'w-full bg-gray-800 border border-gray-700 rounded px-3 py-2 text-xs text-white';
              descArea.id = 'edit-desc';
              descDiv.appendChild(descArea);
              editorPanel.appendChild(descDiv);

              // Buttons
              var btnDiv = document.createElement('div');
              btnDiv.className = 'flex gap-2';
              var saveBtn = document.createElement('button');
              saveBtn.textContent = 'Save to GitHub';
              saveBtn.className = 'px-4 py-2 rounded text-xs bg-blue-600 text-white hover:bg-blue-500 transition';
              var ghLink = document.createElement('a');
              ghLink.href = 'https://github.com/' + siteRepo + '/blob/main/' + filePath;
              ghLink.target = '_blank';
              ghLink.textContent = 'View on GitHub';
              ghLink.className = 'px-4 py-2 rounded text-xs bg-gray-700 text-gray-300 hover:bg-gray-600 transition';
              var deleteBtn = document.createElement('button');
              deleteBtn.textContent = 'Delete Page';
              deleteBtn.className = 'px-4 py-2 rounded text-xs bg-red-900 text-red-300 hover:bg-red-800 transition';

              btnDiv.appendChild(saveBtn);
              btnDiv.appendChild(ghLink);
              btnDiv.appendChild(deleteBtn);
              editorPanel.appendChild(btnDiv);

              // Preview link
              var previewDiv = document.createElement('div');
              previewDiv.className = 'mt-3 pt-3 border-t border-gray-800';
              var previewLink = document.createElement('a');
              previewLink.href = 'https://' + (siteRepo.includes('market-invoice') ? 'www.marketinvoice.co.uk' : siteRepo.includes('seocompare') ? 'www.seocompare.co.uk' : 'adamparkerrank4ai.github.io/rank4ai-preview') + pagePath;
              previewLink.target = '_blank';
              previewLink.textContent = 'Preview live page →';
              previewLink.className = 'text-xs text-blue-400 hover:text-blue-300';
              previewDiv.appendChild(previewLink);
              editorPanel.appendChild(previewDiv);

              // Close
              document.getElementById('close-editor').addEventListener('click', function() {
                editorPanel.classList.add('hidden');
              });

              // Delete handler
              deleteBtn.addEventListener('click', async function() {
                if (!confirm('DELETE ' + pagePath + '?\n\nThis will remove the page from the site. It cannot be undone (without git revert).')) return;
                if (!confirm('Are you REALLY sure? Type the page path in the next prompt if you want to proceed.')) return;
                deleteBtn.textContent = 'Deleting...';
                deleteBtn.disabled = true;
                try {
                  var delResp = await fetch(workerUrl + '/api/file', {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                      repo: siteRepo, path: filePath, sha: data.sha,
                      message: 'Delete ' + pagePath + ' via dashboard',
                    }),
                  });
                  if (delResp.ok) {
                    deleteBtn.textContent = 'Deleted';
                    deleteBtn.style.background = '#166534';
                    editorPanel.style.borderColor = '#166534';
                  } else {
                    deleteBtn.textContent = 'Error';
                    deleteBtn.style.background = '#ef4444';
                  }
                } catch(e) {
                  deleteBtn.textContent = 'Error';
                  deleteBtn.style.background = '#ef4444';
                }
              });

              // Save
              saveBtn.addEventListener('click', async function() {
                var newTitle = document.getElementById('edit-title').value;
                var newDesc = document.getElementById('edit-desc').value;
                var newContent = content;
                if (title) newContent = newContent.replace(title, newTitle);
                if (desc) newContent = newContent.replace(desc, newDesc);

                saveBtn.textContent = 'Saving...';
                saveBtn.disabled = true;

                try {
                  var saveResp = await fetch(workerUrl + '/api/file', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                      repo: siteRepo, path: filePath, content: newContent,
                      sha: data.sha, message: 'Update meta: ' + pagePath + ' via dashboard',
                    }),
                  });
                  if (saveResp.ok) {
                    saveBtn.textContent = 'Saved!';
                    saveBtn.style.background = '#22c55e';
                  } else {
                    saveBtn.textContent = 'Error';
                    saveBtn.style.background = '#ef4444';
                  }
                } catch (err) {
                  saveBtn.textContent = 'Error';
                  saveBtn.style.background = '#ef4444';
                }
                setTimeout(function() { saveBtn.textContent = 'Save to GitHub'; saveBtn.style.background = ''; saveBtn.disabled = false; }, 3000);
              });

            } catch (err) {
              editorPanel.innerHTML = '<div class="text-red-400 text-xs py-4">Failed to load: ' + err.message + '</div>';
            }
          });
        });
      </script>

      <!-- Page editor panel (hidden by default) -->
      <div id="page-editor" class="hidden bg-gray-900 border border-blue-800/50 rounded-lg p-6 mt-4"></div>
    </div>
  )}

  <!-- UPTIME -->
  {sectionId === 'uptime' && uptime && (
    <div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class={`text-2xl font-bold ${uptime.is_up ? 'text-green-400' : 'text-red-400'}`}>{uptime.is_up ? 'UP' : 'DOWN'}</div>
          <div class="text-xs text-gray-500">Current Status</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{uptime.uptime_pct}%</div>
          <div class="text-xs text-gray-500">Uptime</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{uptime.response_time_ms}ms</div>
          <div class="text-xs text-gray-500">Response Time</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{uptime.checks_total}</div>
          <div class="text-xs text-gray-500">Total Checks</div>
        </div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
        <h3 class="text-sm font-semibold text-gray-400 mb-4">Response Time History</h3>
        <canvas id="uptimeChart" height="200"></canvas>
      </div>
    </div>
  )}

  <!-- POSITIVE SIGNALS -->
  {sectionId === 'positive-signals' && crawlData?.positive_signals && (
    <div>
      <div class="bg-gray-900 border border-green-800/50 rounded-lg p-6">
        <h3 class="text-sm font-semibold text-green-400 mb-4">What's Working ({crawlData.positive_signals.length} signals)</h3>
        <div class="space-y-2 max-h-[600px] overflow-y-auto">
          {crawlData.positive_signals.map((s: any) => (
            <div class="flex items-center gap-3 text-xs border-b border-gray-800/50 pb-2">
              <span class={`px-2 py-0.5 rounded text-[10px] ${s.type === 'schema' ? 'bg-blue-900/50 text-blue-300' : s.type === 'good_content' ? 'bg-green-900/50 text-green-300' : 'bg-purple-900/50 text-purple-300'}`}>
                {s.type.replace(/_/g, ' ')}
              </span>
              <span class="text-gray-300 truncate">{new URL(s.url).pathname}</span>
              <span class="text-gray-500 ml-auto">{s.detail}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- AI READINESS -->
  {sectionId === 'ai-readiness' && audit && (
    <div>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class={`text-2xl font-bold ${audit.overall_score >= 70 ? 'text-green-400' : audit.overall_score >= 40 ? 'text-yellow-400' : 'text-red-400'}`}>{audit.overall_score}/100</div>
          <div class="text-xs text-gray-500">Overall Score</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{audit.scores.schema}/100</div>
          <div class="text-xs text-gray-500">Schema</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{audit.scores.content_structure}/100</div>
          <div class="text-xs text-gray-500">Content Structure</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{audit.scores.eeat}/100</div>
          <div class="text-xs text-gray-500">E-E-A-T</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{audit.scores.citation_potential}/100</div>
          <div class="text-xs text-gray-500">Citation Potential</div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
          <h3 class="text-sm font-semibold text-gray-400 mb-4">llms.txt</h3>
          <div class={`text-lg font-bold ${audit.llms_txt?.exists ? 'text-green-400' : 'text-red-400'}`}>
