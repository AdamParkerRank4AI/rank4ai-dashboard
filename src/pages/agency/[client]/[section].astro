      {/* Table */}
      <div class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden">
        <div class="overflow-x-auto max-h-[70vh] overflow-y-auto">
          <table class="w-full text-xs" id="pc-table">
            <thead class="sticky top-0 bg-gray-900 border-b border-gray-800 z-10">
              <tr class="text-left text-gray-500">
                <th class="py-2 px-2 w-8"></th>
                <th class="py-2 px-2">URL / H1</th>
                <th class="py-2 px-1 text-center" title="H1 present">H1</th>
                <th class="py-2 px-1 text-center" title="Title present + under 70 chars">Title</th>
                <th class="py-2 px-1 text-center" title="Meta desc present + under 160 chars">Meta</th>
                <th class="py-2 px-1 text-center" title="Canonical URL set">Canon</th>
                <th class="py-2 px-1 text-center" title="OG tags present">OG</th>
                <th class="py-2 px-1 text-center" title="Has schema markup">Schema</th>
                <th class="py-2 px-1 text-center" title="Has Person/author signal">Author</th>
