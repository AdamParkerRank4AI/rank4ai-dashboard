        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-white">{newPagesDetail.current_pages}</div>
          <div class="text-xs text-gray-500">Current Pages</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class={`text-2xl font-bold ${newPagesDetail.new_pages_count > 0 ? 'text-green-400' : 'text-gray-500'}`}>{newPagesDetail.new_pages_count}</div>
          <div class="text-xs text-gray-500">New Pages Added</div>
        </div>
      </div>

      {newPagesDetail.new_pages_count > 0 ? (
        <div>
          <!-- Summary by category -->
          <div class="bg-gray-900 border border-green-800/30 rounded-lg p-6 mb-6">
            <h3 class="text-sm font-semibold text-green-400 mb-4">New Content by Type</h3>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
              {Object.entries(newPagesDetail.by_category || {}).map(([cat, data]: [string, any]) => (
                <div class="bg-gray-800 rounded-lg p-3 text-center">
                  <div class="text-lg font-bold text-green-400">{data.count}</div>
                  <div class="text-xs text-gray-400">{cat}</div>
                </div>
              ))}
