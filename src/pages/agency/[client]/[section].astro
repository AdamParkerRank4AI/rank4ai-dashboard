                meta: !!p.meta_desc && p.meta_desc.length <= 160 && p.meta_desc.length >= 50,
                canon: !!p.canonical,
                og: !!p.has_og_tags,
                schema: (p.schemas || []).length > 0,
                author: !!p.has_author,
                capsule: !!p.has_answer_capsule,
                crumbs: !!p.has_breadcrumbs,
              };
              const tick = (ok: boolean) => ok ? '<span class="text-green-400">✓</span>' : '<span class="text-red-500">✗</span>';
              const failFlags: string[] = [];
              if (!checks.h1) failFlags.push('no-h1');
              if (!checks.title) failFlags.push(p.title?.length > 70 ? 'long-title' : 'no-title');
              if (!checks.meta) failFlags.push(p.meta_desc?.length > 160 ? 'long-meta' : 'no-meta');
              if (!checks.schema) failFlags.push('no-schema');
              if (!checks.og) failFlags.push('no-og');
              if (!checks.author) failFlags.push('no-author');
              if ((p.internal_links_in ?? 0) === 0) failFlags.push('orphan');
              if ((p.word_count ?? 0) < 300) failFlags.push('thin');

              const allPass = Object.values(checks).every(Boolean);
              const rowClass = allPass ? '' : 'bg-gray-900';
              const schemasJson = JSON.stringify(p.schemas || []).replace(/</g, '&lt;');
              const escapedTitle = (p.title || '').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
              const escapedH1 = (p.h1 || '').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
              const escapedMeta = (p.meta_desc || '').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
              return `
                <tr class="pc-row border-b border-gray-800/50 hover:bg-gray-800/40 cursor-pointer" data-flags="${failFlags.join(' ')}" data-search="${(p.url + ' ' + (p.h1 || '') + ' ' + (p.title || '')).toLowerCase().replace(/"/g, '&quot;')}" data-idx="${idx}">
                  <td class="py-1.5 px-2 text-gray-500"><span class="pc-chevron">▸</span></td>
                  <td class="py-1.5 px-2 max-w-[400px]">
                    <div class="text-white font-medium truncate" title="${escapedH1}">${escapedH1 || '<span class="text-red-500">[missing H1]</span>'}</div>
                    <div class="text-gray-500 text-[10px] truncate" title="${p.url}">${p.path || '/'}</div>
                  </td>
                  <td class="py-1.5 px-1 text-center">${tick(checks.h1)}</td>
                  <td class="py-1.5 px-1 text-center">${tick(checks.title)}</td>
                  <td class="py-1.5 px-1 text-center">${tick(checks.meta)}</td>
                  <td class="py-1.5 px-1 text-center">${tick(checks.canon)}</td>
                  <td class="py-1.5 px-1 text-center">${tick(checks.og)}</td>
                  <td class="py-1.5 px-1 text-center">${tick(checks.schema)}</td>
                  <td class="py-1.5 px-1 text-center">${tick(checks.author)}</td>
                  <td class="py-1.5 px-1 text-center">${tick(checks.capsule)}</td>
                  <td class="py-1.5 px-1 text-center">${tick(checks.crumbs)}</td>
                  <td class="py-1.5 px-1 text-right text-gray-400">${p.internal_links_in ?? 0}</td>
                  <td class="py-1.5 px-1 text-right ${(p.word_count ?? 0) < 300 ? 'text-red-400' : 'text-gray-400'}">${p.word_count ?? 0}</td>
                </tr>
                <tr class="pc-detail hidden bg-gray-950 border-b border-gray-800">
                  <td></td>
                  <td colspan="12" class="py-4 px-3">
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 text-xs">
                      <div class="space-y-2">
                        <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">URL</span><div class="text-blue-400 break-all"><a href="${p.url}" target="_blank" rel="noopener" class="hover:underline">${p.url}</a></div></div>
                        <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">H1</span><div class="text-white">${escapedH1 || '<span class="text-red-500">(missing)</span>'}</div></div>
                        <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">Title tag <span class="text-gray-600">(${(p.title || '').length} chars)</span></span><div class="text-white">${escapedTitle || '<span class="text-red-500">(missing)</span>'}</div></div>
                        <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">Meta description <span class="text-gray-600">(${(p.meta_desc || '').length} chars)</span></span><div class="text-white">${escapedMeta || '<span class="text-red-500">(missing)</span>'}</div></div>
                        <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">Canonical</span><div class="text-gray-300 break-all">${p.canonical || '<span class="text-red-500">(missing)</span>'}</div></div>
                        ${p.last_modified ? `<div><span class="text-gray-500 uppercase text-[10px] tracking-wider">Last modified</span><div class="text-gray-300">${p.last_modified}</div></div>` : ''}
                      </div>
                      <div class="space-y-2">
                        <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">Schemas <span class="text-gray-600">(${(p.schemas || []).length})</span></span><div class="flex flex-wrap gap-1 mt-1">${(p.schemas || []).map((s: string) => `<span class="px-1.5 py-0.5 rounded text-[10px] bg-purple-900/40 text-purple-300 border border-purple-800/40">${s}</span>`).join('') || '<span class="text-red-500">(none)</span>'}</div></div>
                        <div class="grid grid-cols-2 gap-2">
                          <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">Inbound</span><div class="text-white">${p.internal_links_in ?? 0}</div></div>
                          <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">Outbound</span><div class="text-white">${p.internal_links_out ?? 0}</div></div>
                          <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">Words</span><div class="text-white">${p.word_count ?? 0}</div></div>
                          <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">Depth</span><div class="text-white">${p.depth === 99 ? 'unreachable' : p.depth}</div></div>
                          <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">H2 count</span><div class="text-white">${p.h2_count ?? 0}</div></div>
                          <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">Question H2s</span><div class="text-white">${p.question_h2s ?? 0}</div></div>
                          <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">Lists</span><div class="text-white">${p.list_count ?? 0}</div></div>
                          <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">Tables</span><div class="text-white">${p.table_count ?? 0}</div></div>
                          <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">Images</span><div class="text-white">${p.image_count ?? 0} <span class="text-gray-500">(${p.images_with_alt ?? 0} w/ alt)</span></div></div>
                          <div><span class="text-gray-500 uppercase text-[10px] tracking-wider">Response</span><div class="text-white">${p.response_time_ms ?? 0}ms</div></div>
                        </div>
                        <div class="flex flex-wrap gap-2 mt-2">
                          <a href="${p.url}" target="_blank" rel="noopener" class="px-2 py-1 rounded text-[11px] bg-blue-900/40 text-blue-300 border border-blue-800/40 hover:bg-blue-900/60">View live →</a>
                          <a href="https://search.google.com/test/rich-results?url=${encodeURIComponent(p.url)}" target="_blank" rel="noopener" class="px-2 py-1 rounded text-[11px] bg-gray-800 text-gray-300 border border-gray-700 hover:bg-gray-700">Test schema</a>
                          <a href="https://pagespeed.web.dev/report?url=${encodeURIComponent(p.url)}" target="_blank" rel="noopener" class="px-2 py-1 rounded text-[11px] bg-gray-800 text-gray-300 border border-gray-700 hover:bg-gray-700">PageSpeed</a>
                          <span class="px-2 py-1 rounded text-[11px] bg-yellow-900/30 text-yellow-400 border border-yellow-800/40">Edit (coming next)</span>
                        </div>
                      </div>
                    </div>
                  </td>
                </tr>
              `;
            }).join('')} />
          </table>
        </div>
      </div>

      <p class="text-[11px] text-gray-500 mt-3">Showing {crawlData.pages?.filter((p: any) => p.status === 200).length || 0} live pages from the last crawl ({crawlData.crawled_at?.slice(0, 10)}). Click any row to expand full details. Edit capability via GitHub API is the next phase.</p>

      <script is:inline define:vars={{ clientId }}>
        (function() {
          const table = document.getElementById('pc-table');
          if (!table) return;
          const search = document.getElementById('pc-search');
          const filter = document.getElementById('pc-filter');
          const count = document.getElementById('pc-count');

          // Expand/collapse rows
          table.addEventListener('click', (e) => {
            const row = e.target.closest('.pc-row');
            if (!row) return;
            const detail = row.nextElementSibling;
            if (!detail || !detail.classList.contains('pc-detail')) return;
            const isOpen = !detail.classList.contains('hidden');
            detail.classList.toggle('hidden');
            const chev = row.querySelector('.pc-chevron');
            if (chev) chev.textContent = isOpen ? '▸' : '▾';
          });

          const applyFilters = () => {
            const q = (search.value || '').toLowerCase().trim();
            const f = filter.value;
            let visible = 0;
            const rows = table.querySelectorAll('.pc-row');
            rows.forEach((r) => {
              const matchSearch = !q || (r.dataset.search || '').indexOf(q) !== -1;
              const flags = (r.dataset.flags || '').split(' ');
              let matchFilter = true;
              if (f === 'pass') matchFilter = flags[0] === '';
              else if (f === 'fail') matchFilter = flags.some((fl) => ['no-h1','no-title','no-meta'].indexOf(fl) !== -1);
              else if (f !== 'all') matchFilter = flags.indexOf(f) !== -1;
              const show = matchSearch && matchFilter;
              r.style.display = show ? '' : 'none';
              const detail = r.nextElementSibling;
              if (detail && detail.classList.contains('pc-detail') && !show) {
                detail.classList.add('hidden');
                detail.style.display = 'none';
              } else if (detail && detail.classList.contains('pc-detail')) {
                detail.style.display = '';
              }
              if (show) visible++;
            });
            if (count) count.textContent = `Showing ${visible} pages`;
          };
          search.addEventListener('input', applyFilters);
          filter.addEventListener('change', applyFilters);
          applyFilters();
        })();
      </script>
    </div>
  )}

