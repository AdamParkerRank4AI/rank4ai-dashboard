---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Run an Audit">
  <div class="max-w-2xl">
    <div class="mb-6">
      <a href="/" class="text-sm text-gray-400 hover:text-gray-300 transition">
        &larr; Back to Dashboard
      </a>
    </div>

    <h1 class="text-2xl font-bold text-white mb-2">Run an AI Visibility Audit</h1>
    <p class="text-gray-400 mb-8">
      Kicks off a fresh audit on the Mac-hosted pipeline. The PDF is emailed
      when it finishes (typically 3 to 10 minutes depending on the version).
    </p>

    <form id="audit-form" class="p-6 rounded-lg bg-gray-900 border border-gray-800 space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1" for="url">Site URL</label>
        <input
          id="url"
          name="url"
          type="url"
          required
          placeholder="https://example.com"
          class="w-full rounded bg-gray-800 border border-gray-700 px-3 py-2 text-white placeholder-gray-500 focus:border-emerald-500 focus:outline-none"
          autocomplete="off"
        />
        <p class="text-xs text-gray-500 mt-1">Include https:// or http://</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1" for="lead_name">Lead or client name <span class="text-gray-500">(optional)</span></label>
        <input
          id="lead_name"
          name="lead_name"
          type="text"
          class="w-full rounded bg-gray-800 border border-gray-700 px-3 py-2 text-white placeholder-gray-500 focus:border-emerald-500 focus:outline-none"
          autocomplete="off"
        />
      </div>

      <fieldset>
        <legend class="block text-sm font-medium text-gray-300 mb-2">Audit version</legend>
        <div class="flex gap-3">
          <label class="flex-1 cursor-pointer p-3 rounded border border-gray-700 bg-gray-800 hover:border-emerald-500 transition has-[:checked]:border-emerald-500 has-[:checked]:bg-emerald-900/20">
            <input type="radio" name="version" value="v1" class="sr-only" checked />
            <div class="font-medium text-white">v1 quick</div>
            <div class="text-xs text-gray-400 mt-1">Faster. Surface audit plus external signals.</div>
          </label>
          <label class="flex-1 cursor-pointer p-3 rounded border border-gray-700 bg-gray-800 hover:border-emerald-500 transition has-[:checked]:border-emerald-500 has-[:checked]:bg-emerald-900/20">
            <input type="radio" name="version" value="v2" class="sr-only" />
            <div class="font-medium text-white">v2 deep</div>
            <div class="text-xs text-gray-400 mt-1">Slower. Adds interpretation plus prompt inclusion tests.</div>
          </label>
        </div>
      </fieldset>

      <button
        type="submit"
        id="run-btn"
        class="w-full rounded bg-emerald-600 hover:bg-emerald-500 disabled:bg-gray-700 disabled:cursor-not-allowed text-white font-medium py-3 px-4 transition"
      >
        Run audit
      </button>

      <div id="status" class="hidden text-sm p-4 rounded border"></div>
    </form>

    <div class="mt-8 p-4 rounded bg-gray-900/50 border border-gray-800">
      <h2 class="text-sm font-semibold text-gray-300 mb-2">How it works</h2>
      <ol class="text-xs text-gray-400 space-y-1 list-decimal list-inside">
        <li>Form sends the URL to a Cloudflare Pages Function.</li>
        <li>Function forwards it through the rank4ai-audit Cloudflare Tunnel to the Mac.</li>
        <li>Mac runs <code class="text-emerald-400">auditcheck.py</code> (v1) or <code class="text-emerald-400">auditcheck_v2.py</code> (v2).</li>
        <li>When the audit completes, the branded PDF is emailed to the team.</li>
      </ol>
    </div>
  </div>

  <script>
    const form = document.getElementById('audit-form');
    const btn = document.getElementById('run-btn');
    const statusEl = document.getElementById('status');

    function showStatus(message, variant) {
      if (!statusEl) return;
      statusEl.className = 'text-sm p-4 rounded border';
      if (variant === 'success') {
        statusEl.classList.add('bg-emerald-900/30', 'border-emerald-700', 'text-emerald-200');
      } else if (variant === 'error') {
        statusEl.classList.add('bg-red-900/30', 'border-red-700', 'text-red-200');
      } else {
        statusEl.classList.add('bg-gray-800', 'border-gray-700', 'text-gray-300');
      }
      statusEl.textContent = message;
      statusEl.classList.remove('hidden');
    }

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const payload = {
        url: String(data.get('url') || '').trim(),
        lead_name: String(data.get('lead_name') || '').trim(),
        version: String(data.get('version') || 'v1'),
      };

      btn.disabled = true;
      btn.textContent = 'Queuing audit...';
      showStatus('Contacting audit service...', 'info');

      try {
        const res = await fetch('/api/run-audit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const body = await res.json().catch(() => ({}));

        if (res.ok || res.status === 202) {
          showStatus(
            body.message ||
              'Audit queued. The PDF will arrive by email in a few minutes. You can close this tab.',
            'success'
          );
        } else if (res.status === 401) {
          showStatus('Unauthorised. Ask Adam to verify AUDIT_SECRET is set on both Cloudflare Pages and the Mac.', 'error');
        } else {
          showStatus(body.error || ('Audit service returned HTTP ' + res.status), 'error');
        }
      } catch (err) {
        showStatus('Network error: ' + (err?.message || err), 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Run audit';
      }
    });
  </script>
</DashboardLayout>
